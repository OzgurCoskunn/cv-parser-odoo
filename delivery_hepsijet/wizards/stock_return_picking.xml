<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_stock_return_picking_form" model="ir.ui.view">
    <field name="model">stock.return.picking</field>
    <field name="inherit_id" ref="stock.view_stock_return_picking_form"/>
    <field name="arch" type="xml">
        <xpath expr="//field[@name='product_return_moves']" position="after">
            <group invisible="not delivery_hepsijet_ok">
                <separator string="Pickup partner" colspan="2"/>
                <field name="delivery_hepsijet_partner_id" string="Partner" options="{'no_create': True, 'no_open': True}"/>
                <separator string="Schedule pickup dates" colspan="2"/>
                <field name="delivery_hepsijet_ok" invisible="0"/>
                <field name="delivery_hepsijet_connector_id" invisible="1"/>
                <field name="delivery_hepsijet_company_id" invisible="1"/>
                <field name="delivery_hepsijet_carrier_id" invisible="1"/>
                <field name="delivery_hepsijet_date_start" string="Start Date"/>
                <field name="delivery_hepsijet_date_end" string="End Date"/>
                <label for="delivery_hepsijet_date_suitable" string="Suitable Date"/>
                <div class="d-flex">
                    <field name="delivery_hepsijet_date_suitable" nolabel="1" class="oe_inline" string="Suitable Date" placeholder="No date selected..."/>
                    <label for="delivery_hepsijet_date_compute" string="Get Return Date" class="btn fw-bold btn-outline-primary text-uppercase ml4"/>
                    <field name="delivery_hepsijet_date_compute" nolabel="1" class="d-none" context="{'button': True}"/>
                </div>
            </group>
        </xpath>
    </field>
    </record>
</odoo>