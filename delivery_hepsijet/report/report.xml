<odoo>
    <template id="template_zpl_pdf">
        <t t-call="web.basic_layout">
            <div class="page w-100">
                <t t-foreach="docs" t-as="doc">
                    <!--<div align="center">
                        <t t-if="doc.carrier_tracking_ref">
                            <span t-field="doc.carrier_tracking_ref" t-options="{'widget': 'barcode', 'width': 700, 'height': 75, 'img_style': 'width:500px;height:75px;'}"/>
                            <br/>
                            <b>
                                <span t-field="doc.carrier_tracking_ref"/><br/>
