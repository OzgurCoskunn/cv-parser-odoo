                        </t>
                    </div>
                    <div class="mt-3"/>
                    <div class="border bg-100 rounded-2 p-2">
                        <h5 class="fw-bold" style="font-size: 14px;">RECIPIENT INFORMATION</h5>
                        <br/>
                        <table class="table table-borderless m-0 font-monospace" style="font-family: monospace; font-size: 10px;">
                            <tr>
                                <td class="text-nowrap py-0 px-2">Full Name</td>
                                <td class="py-0 px-2">:</td>
                                <td class="w-100 fw-bold py-0 px-2" t-esc="doc.partner_id.name"/>
                            </tr>
                            <tr>
                                <td class="text-nowrap py-0 px-2">Phone</td>
                                <td class="py-0 px-2">:</td>
                                <td class="fw-bold p-0" t-esc="doc.partner_id.mobile or doc.partner_id.phone"/>
                            </tr>
                            <tr>
                                <td class="text-nowrap py-0 px-2">Address</td>
                                <td class="py-0 px-2">:</td>
                                <td class="fw-bold py-0 px-2">
                                    <t t-if="doc.partner_id.street"><span t-esc="doc.partner_id.street.replace('i', 'İ').upper()"/><br/></t>
                                    <t t-if="doc.partner_id.street2"><span t-esc="doc.partner_id.street2.replace('i', 'İ').upper()"/><br/></t>
                                    <t t-if="doc.partner_id.street3"><span t-esc="doc.partner_id.street3.replace('i', 'İ').upper()"/><br/></t>
                                    <t t-if="doc.partner_id.city"><span t-esc="doc.partner_id.city.replace('i', 'İ').upper()"/></t>
                                    <t t-if="doc.partner_id.city and doc.partner_id.state_id"> / </t>
                                    <t t-if="doc.partner_id.state_id"><span t-esc="doc.partner_id.state_id.name.replace('i', 'İ').upper()"/></t>
                                    <t t-if="doc.partner_id.city or doc.partner_id.state_id"><br/></t>
                                    <t t-if="doc.partner_id.zip"><span t-esc="doc.partner_id.zip"/><br/></t>
                                    <t t-if="doc.partner_id.country_id"><span t-esc="doc.partner_id.country_id.name.replace('i', 'İ').upper()"/></t>
                                </td>
                            </tr>
                        </table>
                    </div>
                    <div class="border-top my-2"/>
                    <div class="border bg-100 rounded-2 p-2">
                        <h5 class="fw-bold" style="font-size: 14px;">SENDER INFORMATION</h5>
                        <br/>
                        <table class="table table-borderless m-0 font-monospace" style="font-family: monospace; font-size: 10px;">
                            <tr>
                                <td class="text-nowrap py-0 px-2">Full Name</td>
                                <td class="py-0 px-2">:</td>
                                <td class="w-100 fw-bold py-0 px-2" t-esc="doc.company_id.name"/>
                            </tr>
                            <tr>
                                <td class="text-nowrap py-0 px-2">Phone</td>
                                <td class="py-0 px-2">:</td>
                                <td class="fw-bold p-0" t-esc="doc.company_id.mobile or doc.company_id.phone"/>
                            </tr>
                            <tr>
                                <td class="text-nowrap py-0 px-2">Address</td>
                                <td class="py-0 px-2">:</td>
                                <td class="fw-bold py-0 px-2">
                                    <t t-if="doc.company_id.street"><span t-esc="doc.company_id.street.replace('i', 'İ').upper()"/><br/></t>
                                    <t t-if="doc.company_id.street2"><span t-esc="doc.company_id.street2.replace('i', 'İ').upper()"/><br/></t>
                                    <t t-if="doc.company_id.street3"><span t-esc="doc.company_id.street3.replace('i', 'İ').upper()"/><br/></t>
                                    <t t-if="doc.company_id.city"><span t-esc="doc.company_id.city.replace('i', 'İ').upper()"/></t>
                                    <t t-if="doc.company_id.city and doc.company_id.state_id"> / </t>
                                    <t t-if="doc.company_id.state_id"><span t-esc="doc.company_id.state_id.name.replace('i', 'İ').upper()"/></t>
                                    <t t-if="doc.company_id.city or doc.company_id.state_id"><br/></t>
                                    <t t-if="doc.company_id.zip"><span t-esc="doc.company_id.zip"/><br/></t>
                                    <t t-if="doc.company_id.country_id"><span t-esc="doc.company_id.country_id.name.replace('i', 'İ').upper()"/></t>
                                </td>
                            </tr>
                        </table>
                    </div>-->
                </t>
            </div>
        </t>
    </template>


