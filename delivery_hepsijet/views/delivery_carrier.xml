<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_delivery_carrier_form" model="ir.ui.view">
        <field name="model">delivery.carrier</field>
        <field name="inherit_id" ref="delivery.view_delivery_carrier_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook/page" position="before">
                <page string="HepsiJet" invisible="delivery_type != 'hepsijet'">
                    <group>
                        <group>
                            <separator string="Connector" colspan="2"/>
                            <field name="delivery_hepsijet_connector_id" string="Connector" options="{'no_create': True}" placeholder="No connector selected"/>                            
                            <separator string="Contract" colspan="2"/>
                            <field name="delivery_hepsijet_contract_id" string="Contract" placeholder="No contract selected" options="{'no_create': True}"/>
                            <field name="delivery_hepsijet_contract_product_id" string="Product" placeholder="No product selected"/>
                            <button name="action_view_hepsijet_contracts" type="object" string="View Contracts" class="btn-block text-primary text-uppercase" icon="fa-file-text-o mr8" colspan="2"/>
                            <separator string="Prefixes" colspan="2"/>
                            <field name="delivery_hepsijet_prefix_product" string="Product"/>
                            <field name="delivery_hepsijet_prefix_product_return" string="Product Return"/>
                            <field name="delivery_hepsijet_prefix_product_contract" string="Product + Contract"/>
                            <field name="delivery_hepsijet_prefix_contract" string="Contract"/>
                            <field name="delivery_hepsijet_prefix_egyg" string="EGYG"/>
                            <field name="delivery_hepsijet_prefix_egyg_return" string="EGYG Return"/>
                        </group>
                        <group>
                            <separator string="Credentials" colspan="2"/>
                            <field name="delivery_hepsijet_prod_username" string="Username" invisible="not prod_environment"/>
                            <field name="delivery_hepsijet_prod_password" string="Password" password="True" invisible="not prod_environment"/>
                            <field name="delivery_hepsijet_prod_company_name" string="Company Name" invisible="not prod_environment"/>
                            <field name="delivery_hepsijet_prod_company_id" string="Company ID" invisible="not prod_environment"/>
                            <field name="delivery_hepsijet_prod_address_code" string="Address Code" invisible="not prod_environment"/>
                            <field name="delivery_hepsijet_prod_address_code_return" string="Address Code Return" invisible="not prod_environment"/>
                            <field name="delivery_hepsijet_prod_abbreviation_code" string="Abbreviation Code" invisible="not prod_environment"/>
                            <field name="delivery_hepsijet_prod_contract_application_code" string="Contract Application Code" invisible="not prod_environment"/>
                            <field name="delivery_hepsijet_test_username" string="Username" invisible="prod_environment"/>
                            <field name="delivery_hepsijet_test_password" string="Password" password="True" invisible="prod_environment"/>
                            <field name="delivery_hepsijet_test_company_name" string="Company Name" placeholder="No company name entered" invisible="prod_environment"/>                            
                            <field name="delivery_hepsijet_test_company_id" string="Company ID" invisible="prod_environment"/>
                            <field name="delivery_hepsijet_test_address_code" string="Address Code" invisible="prod_environment"/>
                            <field name="delivery_hepsijet_test_address_code_return" string="Address Code Return" invisible="prod_environment"/>
                            <field name="delivery_hepsijet_test_abbreviation_code" string="Abbreviation Code" invisible="prod_environment"/>
                            <field name="delivery_hepsijet_test_contract_application_code" string="Contract Application Code" invisible="prod_environment"/>
                            <separator string="Options" colspan="2"/>
                            <label for="delivery_hepsijet_return_day_range" string="Date Range"/>
                            <div class="o_row">
                                <field name="delivery_hepsijet_return_day_range" class="oe_inline text-end" placeholder="0"/> Days
                            </div>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="tree_contract" model="ir.ui.view">
    <field name="name">delivery.carrier.hepsijet.contract.list</field>
    <field name="model">delivery.carrier.hepsijet.contract</field>
    <field name="arch" type="xml">
        <list decoration-muted="active == False">
            <field name="sequence" widget="handle"/>
            <field name="name" decoration-bf="1"/>
            <field name="version"/>
            <field name="active" widget="boolean_toggle"/>
        </list>
    </field>
    </record>

    <record id="contract_contract" model="ir.ui.view">
    <field name="name">delivery.carrier.hepsijet.contract.form</field>
    <field name="model">delivery.carrier.hepsijet.contract</field>
    <field name="arch" type="xml">
        <form>
            <sheet>
                <div class="row ml4 mr4">
                    <div class="col-md-8">
                        <field name="body" colspan="2" nolabel="1" options="{'codeview': true}"/>
                    </div>
                    <div class="col-md-4 shadow-sm table-bordered" style="position: sticky; top: 20px; border-radius: 10px;">
                        <separator string="Name"/>
                        <div class="d-flex justify-content-between">
                            <div>
                                <field name="name" placeholder="Enter a contract name..."/>
                            </div>
                            <div>
                                <span class="fst-italic mr8">Active</span>
                                <field name="active" string="Published" widget="boolean_toggle"/>
                            </div>
                        </div>
                        <separator string="Company" groups="base.group_multi_company,base.group_system"/>
                        <field name="company_id" colspan="2" nolabel="1" options="{'no_create': True, 'no_open': True}" groups="base.group_multi_company,base.group_system"/>
                        <separator string="Code"/>
                        <field name="code" colspan="2" nolabel="1" placeholder="STANDARD"/>
                        <separator string="Version"/>
                        <field name="version" colspan="2" nolabel="1" placeholder="1.0"/>
                        <!--<separator string="Help" class="mt16"/>
                        <div colspan="2">
                            <p class="mt16 mb4">Available variables;</p>
                            <ul class="list-inline">
                                <li><code>{{partner_name}}</code>: Partner name</li>
                                <li><code>{{partner_vat}}</code>: Partner VAT</li>
                                <li><code>{{partner_phone}}</code>: Partner phone number</li>
                                <li><code>{{partner_mobile}}</code>: Partner mobile number</li>
                                <li><code>{{partner_email}}</code>: Partner email address</li>
                                <li><code>{{partner_address}}</code>: Partner address</li>
                                <li><code>{{partner_card_number}}</code>: Partner card number</li>
                                <li><code>{{partner_card_holder}}</code>: Partner card holder</li>
                                <li><code>{{partner_iban_number}}</code>: Partner IBAN number</li>
                                <li><code>{{partner_iban_holder}}</code>: Partner IBAN holder</li>
                                <li><code>{{product_name}}</code>: Product name</li>
                                <li><code>{{product_quantity}}</code>: Product quantity</li>
                            </ul>
                        </div>-->
                    </div>
                </div>
            </sheet>
        </form>
    </field>
    </record>

    <record id="action_contract" model="ir.actions.act_window">
    <field name="name">Contracts</field>
    <field name="type">ir.actions.act_window</field>
    <field name="res_model">delivery.carrier.hepsijet.contract</field>
    <field name="view_mode">list,form</field>
    <field name="context">{'active_test': False}</field>
    <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
            No contracts yet
        </p>
        <p>
            Create a contracts then use them with deliveries
        </p>
    </field>
    </record>
</odoo>