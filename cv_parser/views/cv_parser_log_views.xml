<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_cv_parser_log_list" model="ir.ui.view">
        <field name="name">cv.parser.log.list</field>
        <field name="model">cv.parser.log</field>
        <field name="arch" type="xml">
            <list string="CV Parser Log" decoration-danger="status == 'error'">
                <field name="date"/>
                <field name="res_name" string="Aday"/>
                <field name="provider_id" string="Sağlayıcı"/>
                <field name="config_id" string="Konfigürasyon"/>
                <field name="llm_model" string="Model"/>
                <field name="prompt_tokens"/>
                <field name="completion_tokens"/>
                <field name="total_tokens"/>
                <field name="cost_usd" string="Maliyet (USD)" sum="Toplam Maliyet (USD)"/>
                <field name="status" widget="badge"
                    decoration-success="status == 'success'"
                    decoration-danger="status == 'error'"/>
            </list>
        </field>
    </record>

    <record id="view_cv_parser_log_form" model="ir.ui.view">
        <field name="name">cv.parser.log.form</field>
        <field name="model">cv.parser.log</field>
        <field name="arch" type="xml">
            <form string="CV Parser Log">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="res_name"/></h1>
                    </div>
                    <group>
                        <group string="Genel">
                            <field name="date"/>
                            <field name="provider_id" string="Sağlayıcı"/>
                            <field name="config_id" string="Konfigürasyon"/>
                            <field name="res_model" string="İlgili Model"/>
                            <field name="res_id" string="Kayıt ID"/>
                            <field name="llm_model" string="LLM Model"/>
                            <field name="status" widget="badge"/>
                        </group>
                        <group string="Token Kullanımı">
                            <field name="prompt_tokens"/>
                            <field name="completion_tokens"/>
                            <field name="total_tokens"/>
                            <field name="cost_usd" string="Tahmini Maliyet (USD)"/>
                        </group>
                    </group>
                    <group string="Hata Detayı" invisible="status == 'success'">
                        <field name="error_message" nolabel="1"/>
                    </group>
                    <group string="Gönderilen İstek">
                        <field name="request_payload" nolabel="1" colspan="2"/>
                    </group>
                    <group string="Dönen Yanıt">
                        <field name="response_payload" nolabel="1" colspan="2"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_cv_parser_log_search" model="ir.ui.view">
        <field name="name">cv.parser.log.search</field>
        <field name="model">cv.parser.log</field>
        <field name="arch" type="xml">
            <search>
                <field name="res_name" string="Aday"/>
                <field name="llm_model" string="Model"/>
                <field name="provider_id" string="Sağlayıcı"/>
                <field name="config_id" string="Konfigürasyon"/>
                <filter name="success" string="Başarılı" domain="[('status','=','success')]"/>
                <filter name="error" string="Hatalı" domain="[('status','=','error')]"/>
                <separator/>
                <filter name="this_week" string="Bu Hafta"
                    domain="[('date','&gt;=', (context_today() - relativedelta(weeks=1)).strftime('%Y-%m-%d'))]"/>
                <filter name="this_month" string="Bu Ay"
                    domain="[('date','&gt;=', context_today().strftime('%Y-%m-01'))]"/>
                <filter name="this_year" string="Bu Yıl"
                    domain="[('date','&gt;=', context_today().strftime('%Y-01-01'))]"/>
                <separator/>
                <filter name="group_provider" string="Sağlayıcıya Göre" context="{'group_by': 'provider_id'}"/>
                <filter name="group_config" string="Konfigürasyona Göre" context="{'group_by': 'config_id'}"/>
                <filter name="group_model" string="LLM Modele Göre" context="{'group_by': 'llm_model'}"/>
                <filter name="group_week" string="Haftaya Göre" context="{'group_by': 'date:week'}"/>
                <filter name="group_month" string="Aya Göre" context="{'group_by': 'date:month'}"/>
                <filter name="group_year" string="Yıla Göre" context="{'group_by': 'date:year'}"/>
            </search>
        </field>
    </record>

    <record id="view_cv_parser_log_graph" model="ir.ui.view">
        <field name="name">cv.parser.log.graph</field>
        <field name="model">cv.parser.log</field>
        <field name="arch" type="xml">
            <graph string="CV Parser Kullanım Raporu" type="bar">
                <field name="provider_id" type="row"/>
                <field name="cost_usd" type="measure"/>
                <field name="total_tokens" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_cv_parser_log_pivot" model="ir.ui.view">
        <field name="name">cv.parser.log.pivot</field>
        <field name="model">cv.parser.log</field>
        <field name="arch" type="xml">
            <pivot string="CV Parser Kullanım Özeti">
                <field name="provider_id" type="row"/>
                <field name="config_id" type="row"/>
                <field name="date" interval="month" type="col"/>
                <field name="cost_usd" type="measure"/>
                <field name="total_tokens" type="measure"/>
                <field name="prompt_tokens" type="measure"/>
                <field name="completion_tokens" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Kullanım Kayıtları: sadece başarılı, maliyet odaklı -->
    <record id="action_cv_parser_kullanim" model="ir.actions.act_window">
        <field name="name">Kullanım Kayıtları</field>
        <field name="res_model">cv.parser.log</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('status','=','success')]</field>
    </record>

    <!-- Loglar: tüm denemeler, hata dahil -->
    <record id="action_cv_parser_log" model="ir.actions.act_window">
        <field name="name">Loglar</field>
        <field name="res_model">cv.parser.log</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_cv_parser_log_report" model="ir.actions.act_window">
        <field name="name">Kullanım Raporu</field>
        <field name="res_model">cv.parser.log</field>
        <field name="view_mode">graph,pivot,list</field>
        <field name="domain">[('status','=','success')]</field>
    </record>

</odoo>
