<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_cv_parser_config_list" model="ir.ui.view">
        <field name="name">cv.parser.config.list</field>
        <field name="model">cv.parser.config</field>
        <field name="arch" type="xml">
            <list string="CV Parser Konfigürasyonları" decoration-muted="not active">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="provider_id"/>
                <field name="provider_model_id" string="Model"/>
                <field name="max_spend_usd" string="Maks. Harcama ($)"/>
                <field name="limit_action"/>
                <field name="deactivation_reason" string="Pasife Alınma Nedeni" optional="show"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_cv_parser_config_form" model="ir.ui.view">
        <field name="name">cv.parser.config.form</field>
        <field name="model">cv.parser.config</field>
        <field name="arch" type="xml">
            <form string="CV Parser Konfigürasyon">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group invisible="active">
                        <field name="deactivation_reason" string="Pasife Alınma Nedeni"
                            readonly="1"
                            style="color: #dc3545; font-weight: bold;"/>
                    </group>
                    <group>
                        <group string="AI Ayarları">
                            <field name="provider_id"/>
                            <field name="provider_model_id"
                                domain="[('provider_id', '=', provider_id)]"
                                string="Model"/>
                            <field name="llm_model" string="Model ID" readonly="1"/>
                            <field name="sequence" string="Öncelik"/>
                            <field name="active"/>
                        </group>
                        <group string="Harcama Limiti">
                            <field name="max_spend_usd" string="Maksimum Harcama ($)"/>
                            <field name="limit_action"/>
                        </group>
                    </group>
                    <group string="Prompt">
                        <field name="prompt" nolabel="1" rows="14"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_cv_parser_config_search" model="ir.ui.view">
        <field name="name">cv.parser.config.search</field>
        <field name="model">cv.parser.config</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Konfigürasyon"/>
                <field name="provider_id" string="Sağlayıcı"/>
                <filter name="active" string="Aktif" domain="[('active','=',True)]"/>
                <filter name="inactive" string="Pasif" domain="[('active','=',False)]"/>
                <separator/>
                <filter name="group_provider" string="Sağlayıcıya Göre" context="{'group_by': 'provider_id'}"/>
                <filter name="group_model" string="Modele Göre" context="{'group_by': 'provider_model_id'}"/>
            </search>
        </field>
    </record>

    <record id="action_cv_parser_config" model="ir.actions.act_window">
        <field name="name">CV Parser Konfigürasyonu</field>
        <field name="res_model">cv.parser.config</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'active_test': False}</field>
    </record>

</odoo>
