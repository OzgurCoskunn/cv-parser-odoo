<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_openrouter_log_list" model="ir.ui.view">
        <field name="name">openrouter.log.list</field>
        <field name="model">openrouter.log</field>
        <field name="arch" type="xml">
            <list string="OpenRouter Kullanım Kayıtları" decoration-danger="status == 'error'">
                <field name="date"/>
                <field name="res_name" string="Aday"/>
                <field name="provider_id" string="Sağlayıcı"/>
                <field name="config_id" string="Konfigürasyon"/>
                <field name="llm_model" string="Model"/>
                <field name="prompt_tokens"/>
                <field name="completion_tokens"/>
                <field name="total_tokens"/>
                <field name="cost_usd" string="Maliyet (USD)"/>
                <field name="status" widget="badge"
                    decoration-success="status == 'success'"
                    decoration-danger="status == 'error'"/>
            </list>
        </field>
    </record>

    <record id="view_openrouter_log_form" model="ir.ui.view">
        <field name="name">openrouter.log.form</field>
        <field name="model">openrouter.log</field>
        <field name="arch" type="xml">
            <form string="OpenRouter Kullanım Kaydı">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="res_name"/></h1>
                    </div>
                    <group>
                        <group string="Genel">
                            <field name="date"/>
                            <field name="provider_id" string="Sağlayıcı"/>
                            <field name="config_id" string="Konfigürasyon"/>
                            <field name="res_model"/>
                            <field name="res_id"/>
                            <field name="llm_model"/>
                            <field name="status" widget="badge"/>
                        </group>
                        <group string="Token Kullanımı">
                            <field name="prompt_tokens"/>
                            <field name="completion_tokens"/>
                            <field name="total_tokens"/>
                            <field name="cost_usd" string="Tahmini Maliyet (USD)"/>
                        </group>
                    </group>

                    <group invisible="status == 'success'">
                        <field name="error_message" string="Hata Detayı"/>
                    </group>
                    <group string="API Detayları">
                        <field name="request_payload" string="Gönderilen İstek"/>
                        <field name="response_payload" string="Dönen Yanıt"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_openrouter_log_search" model="ir.ui.view">
        <field name="name">openrouter.log.search</field>
        <field name="model">openrouter.log</field>
        <field name="arch" type="xml">
            <search>
                <field name="res_name" string="Aday"/>
                <field name="llm_model" string="Model"/>
                <field name="provider_id" string="Sağlayıcı"/>
                <field name="config_id" string="Konfigürasyon"/>
                <filter name="success" string="Başarılı" domain="[('status','=','success')]"/>
                <filter name="error" string="Hatalı" domain="[('status','=','error')]"/>
                <separator/>
                <filter name="group_provider" string="Sağlayıcıya Göre" context="{'group_by': 'provider_id'}"/>
                <filter name="group_config" string="Konfigürasyona Göre" context="{'group_by': 'config_id'}"/>
                <filter name="group_model" string="LLM Modele Göre" context="{'group_by': 'llm_model'}"/>
                <filter name="group_date" string="Aya Göre" context="{'group_by': 'date:month'}"/>
            </search>
        </field>
    </record>

    <record id="view_openrouter_log_graph" model="ir.ui.view">
        <field name="name">openrouter.log.graph</field>
        <field name="model">openrouter.log</field>
        <field name="arch" type="xml">
            <graph string="Kullanım Raporu" type="bar">
                <field name="provider_id" type="row"/>
                <field name="cost_usd" type="measure"/>
                <field name="total_tokens" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_openrouter_log_pivot" model="ir.ui.view">
        <field name="name">openrouter.log.pivot</field>
        <field name="model">openrouter.log</field>
        <field name="arch" type="xml">
            <pivot string="Kullanım Özeti">
                <field name="provider_id" type="row"/>
                <field name="config_id" type="row"/>
                <field name="date" interval="month" type="col"/>
                <field name="cost_usd" type="measure"/>
                <field name="total_tokens" type="measure"/>
                <field name="prompt_tokens" type="measure"/>
                <field name="completion_tokens" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_check_openrouter_balance" model="ir.actions.server">
        <field name="name">OpenRouter Bakiye Kontrol</field>
        <field name="model_id" ref="cv_parser.model_openrouter_log"/>
        <field name="binding_model_id" ref="cv_parser.model_openrouter_log"/>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">env['openrouter.log'].action_check_balance()</field>
    </record>

    <record id="action_openrouter_log" model="ir.actions.act_window">
        <field name="name">Kullanım Kayıtları</field>
        <field name="res_model">openrouter.log</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_openrouter_report" model="ir.actions.act_window">
        <field name="name">Kullanım Raporu</field>
        <field name="res_model">openrouter.log</field>
        <field name="view_mode">graph,pivot,list</field>
        <field name="domain">[('status','=','success')]</field>
        <field name="context">{'search_default_group_provider': 1}</field>
    </record>

</odoo>
