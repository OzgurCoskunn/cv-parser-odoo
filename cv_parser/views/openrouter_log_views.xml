<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_openrouter_log_list" model="ir.ui.view">
        <field name="name">openrouter.log.list</field>
        <field name="model">openrouter.log</field>
        <field name="arch" type="xml">
            <list string="OpenRouter Kullanım Kayıtları" decoration-danger="status == 'error'">
                <header>
                    <button name="action_check_balance" type="object" string="Bakiye Kontrol Et" class="btn btn-secondary"/>
                </header>
                <field name="date"/>
                <field name="res_name" string="Aday"/>
                <field name="llm_model" string="Model"/>
                <field name="prompt_tokens"/>
                <field name="completion_tokens"/>
                <field name="total_tokens"/>
                <field name="cost_usd" string="Maliyet (USD)"/>
                <field name="status" widget="badge"
                    decoration-success="status == 'success'"
                    decoration-danger="status == 'error'"/>
            </list>
        </field>
    </record>

    <record id="view_openrouter_log_form" model="ir.ui.view">
        <field name="name">openrouter.log.form</field>
        <field name="model">openrouter.log</field>
        <field name="arch" type="xml">
            <form string="OpenRouter Kullanım Kaydı">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="res_name"/></h1>
                    </div>
                    <group>
                        <group string="Genel">
                            <field name="date"/>
                            <field name="res_model"/>
                            <field name="res_id"/>
                            <field name="llm_model"/>
                            <field name="status" widget="badge"/>
                        </group>
                        <group string="Token Kullanımı">
                            <field name="prompt_tokens"/>
                            <field name="completion_tokens"/>
                            <field name="total_tokens"/>
                            <field name="cost_usd" string="Tahmini Maliyet (USD)"/>
                        </group>
                    </group>
                    <group string="İstatistikler (Tüm Zamanlar)">
                        <group>
                            <field name="total_requests" string="Toplam Başarılı İstek"/>
                            <field name="total_cost" string="Toplam Maliyet (USD)"/>
                            <field name="avg_cost" string="Ortalama Maliyet (USD)"/>
                        </group>
                    </group>
                    <group invisible="status == 'success'">
                        <field name="error_message" string="Hata Detayı"/>
                    </group>
                    <group string="API Detayları">
                        <field name="request_payload" string="Gönderilen İstek"/>
                        <field name="response_payload" string="Dönen Yanıt"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_openrouter_log_search" model="ir.ui.view">
        <field name="name">openrouter.log.search</field>
        <field name="model">openrouter.log</field>
        <field name="arch" type="xml">
            <search>
                <field name="res_name" string="Aday"/>
                <field name="llm_model" string="Model"/>
                <filter name="success" string="Başarılı" domain="[('status','=','success')]"/>
                <filter name="error" string="Hatalı" domain="[('status','=','error')]"/>
                <filter name="group_model" string="LLM Modele Göre" context="{'group_by': 'llm_model'}"/>
                <filter name="group_date" string="Aya Göre" context="{'group_by': 'date:month'}"/>
            </search>
        </field>
    </record>

    <record id="action_openrouter_log" model="ir.actions.act_window">
        <field name="name">OpenRouter Kullanım Kayıtları</field>
        <field name="res_model">openrouter.log</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_success': 1}</field>
    </record>

    <menuitem id="menu_openrouter_log"
        name="OpenRouter Kullanım Kayıtları"
        parent="hr_recruitment.menu_hr_recruitment_configuration"
        action="action_openrouter_log"
        sequence="100"
        groups="base.group_system"/>

</odoo>
