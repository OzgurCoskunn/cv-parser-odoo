<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_applicant_cv_parser_field" model="ir.ui.view">
        <field name="name">hr.applicant.cv.parser.field</field>
        <field name="model">hr.applicant</field>
        <field name="inherit_id" ref="hr_recruitment.hr_applicant_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_cv_logs" type="object"
                    class="oe_stat_button" icon="fa-list-alt"
                    invisible="cv_log_count == 0">
                    <field name="cv_log_count" widget="statinfo" string="CV Log"/>
                </button>
            </xpath>
            <xpath expr="//field[@name='categ_ids']" position="after">
                <field name="x_cv_parsed" string="CV Bilgisi Alındı"/>
            </xpath>
        </field>
    </record>

    <record id="action_parse_cv_with_llm" model="ir.actions.server">
        <field name="name">CV'den Bilgi Al</field>
        <field name="model_id" ref="hr_recruitment.model_hr_applicant"/>
        <field name="binding_model_id" ref="hr_recruitment.model_hr_applicant"/>
        <field name="binding_view_types">form,list</field>
        <field name="state">code</field>
        <field name="code">records.action_parse_cv_with_llm()</field>
    </record>

</odoo>
