<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_cv_parser_provider_list" model="ir.ui.view">
        <field name="name">cv.parser.provider.list</field>
        <field name="model">cv.parser.provider</field>
        <field name="arch" type="xml">
            <list string="AI Sağlayıcılar">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="api_url"/>
                <field name="status" widget="badge"
                    decoration-success="status == 'confirmed'"
                    decoration-danger="status == 'error'"
                    decoration-warning="status == 'draft'"/>
                <field name="model_count" string="Model Sayısı"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_cv_parser_provider_form" model="ir.ui.view">
        <field name="name">cv.parser.provider.form</field>
        <field name="model">cv.parser.provider</field>
        <field name="arch" type="xml">
            <form string="AI Sağlayıcı">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_test_connection" type="object"
                            string="Bağlantıyı Test Et" class="btn btn-primary"/>
                        <button name="action_check_balance" type="object"
                            string="Bakiye Kontrol Et" class="btn btn-secondary"/>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Bağlantı Bilgileri">
                            <field name="api_url" string="API URL"/>
                            <field name="balance_url" string="Bakiye URL"/>
                            <field name="models_url" string="Modeller URL"/>
                            <field name="api_key" string="API Key" password="True"/>
                        </group>
                        <group string="Durum">
                            <field name="status" widget="badge"
                                decoration-success="status == 'confirmed'"
                                decoration-danger="status == 'error'"
                                decoration-warning="status == 'draft'"/>
                            <field name="active"/>
                            <field name="sequence"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Modeller" name="models">
                            <field name="model_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="model_id" string="Model ID"/>
                                    <field name="name" string="Model Adı"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notlar" name="notes">
                            <field name="notes" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_cv_parser_provider" model="ir.actions.act_window">
        <field name="name">AI Sağlayıcılar</field>
        <field name="res_model">cv.parser.provider</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
