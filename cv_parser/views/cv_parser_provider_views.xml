<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_cv_parser_provider_list" model="ir.ui.view">
        <field name="name">cv.parser.provider.list</field>
        <field name="model">cv.parser.provider</field>
        <field name="arch" type="xml">
            <list string="AI Sağlayıcılar">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="api_url"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_cv_parser_provider_form" model="ir.ui.view">
        <field name="name">cv.parser.provider.form</field>
        <field name="model">cv.parser.provider</field>
        <field name="arch" type="xml">
            <form string="AI Sağlayıcı">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_check_balance" type="object"
                            string="Bakiye Kontrol Et" class="btn btn-primary"/>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Bağlantı Bilgileri">
                            <field name="api_url" string="API URL"/>
                            <field name="balance_url" string="Bakiye URL"/>
                            <field name="api_key" string="API Key" password="True"/>
                        </group>
                        <group string="Durum">
                            <field name="active"/>
                            <field name="sequence"/>
                        </group>
                    </group>
                    <group string="Notlar">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_cv_parser_provider" model="ir.actions.act_window">
        <field name="name">AI Sağlayıcılar</field>
        <field name="res_model">cv.parser.provider</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
