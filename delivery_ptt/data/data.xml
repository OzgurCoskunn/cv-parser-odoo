<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="delivery_carrier" model="delivery.carrier">
            <field name="name">Ptt</field>
            <field name="delivery_type">ptt</field>
            <field name="product_id" ref="delivery.product_product_delivery"/>
        </record>

        <record id="cron_update_order" model="ir.cron">
            <field name="name">Ptt Kargo: Update Deliveries</field>
            <field name="interval_number">15</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="model_id" ref="stock.model_stock_picking"/>
            <field name="code">model.update_delivery_ptt_state()</field>
            <field name="state">code</field>
        </record>

        <record id="seq_delivery_barcode" model="ir.sequence">
            <field name="name">PTT Delivery Barcode</field>
            <field name="code">delivery.barcode</field>
            <field name="prefix">2783199</field>
            <field name="padding">5</field>
            <field name="number_next">10000</field>
            <field name="number_increment">1</field>
        </record>

        <record id="status_mapping_collected" model="delivery.status.mapping">
            <field name="carrier_id" ref="delivery_carrier"/>
            <field name="status_id" ref="delivery_base.status_collected"/>
            <field name="code">1</field>
        </record>

        <record id="status_mapping_on_delivery_courier" model="delivery.status.mapping">
            <field name="carrier_id" ref="delivery_carrier"/>
            <field name="status_id" ref="delivery_base.status_on_delivery_courier"/>
            <field name="code">2</field>
        </record>

        <record id="status_mapping_delivered" model="delivery.status.mapping">
            <field name="carrier_id" ref="delivery_carrier"/>
            <field name="status_id" ref="delivery_base.status_delivered"/>
            <field name="code">TESLIM</field>
        </record>
    </data>
</odoo>
