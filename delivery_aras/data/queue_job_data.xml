<odoo>
    <!-- Dedicated channel for Aras Cargo updates to isolate load -->
    <record id="queue_job_channel_aras" model="queue.job.channel">
        <field name="name">aras</field>
        <field name="parent_id" ref="queue_job.channel_root"/>
    </record>

    <!-- Register job function so channel configuration and retry pattern can be managed -->
    <record id="queue_job_function_aras_update" model="queue.job.function">
        <field name="model_id" ref="stock.model_stock_picking"/>
        <field name="method">_update_delivery_aras_state</field>
        <field name="channel_id" ref="queue_job_channel_aras"/>
    </record>
    <record id="queue_job_function_aras_update_chunk" model="queue.job.function">
        <field name="model_id" ref="stock.model_stock_picking"/>
        <field name="method">_process_delivery_aras_state_chunk</field>
        <field name="channel_id" ref="queue_job_channel_aras"/>
    </record>
</odoo>