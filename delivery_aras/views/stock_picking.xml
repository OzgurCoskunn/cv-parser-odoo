<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_picking_form" model="ir.ui.view">
    <field name="model">stock.picking</field>
    <field name="inherit_id" ref="stock.view_picking_form"/>
    <field name="arch" type="xml">
        <xpath expr="//page[@name='note']" position="before">
            <page string="Aras Kargo" invisible="delivery_aras_ok == False">
                <div class="border-bottom d-flex justify-content-between align-items-center pb-3">
                    <div class="font-weight-bold text-primary d-flex align-items-center">
                        <span class="mr-3">Tracking Reference:</span>
                        <field name="delivery_aras_integration_code" class="text-monospace oe_inline m-0" nolabel="1" readonly="1"/>
                    </div>
                    <div class="font-weight-bold text-primary d-flex align-items-center">
                        <span class="mr-3">Delivery Status:</span>
                        <field name="delivery_aras_status" class="text-monospace oe_inline m-0" nolabel="1" readonly="1"/>
                    </div>
                    <button name="update_delivery_aras_state" type="object" string="Update" icon="fa-refresh" class="btn-secondary text-uppercase"/>
                </div>
                <group>
                    <group>
                        <separator string="Document Information" colspan="2"/>
                        <field name="delivery_aras_dispatch_number" string="Dispatch Number"/>
                        <field name="delivery_aras_invoice_number" string="Invoice Number"/>
                        <br colspan="2"/>
                        <separator string="Transfer Information" colspan="2"/>
                        <field name="delivery_aras_date_query" string="Date Query"/>
                        <field name="delivery_aras_privilege_order" string="Privilege Order" widget="boolean_toggle"/>
                        <field name="delivery_aras_export_ok" string="Export Order" widget="boolean_toggle"/>
                        <field name="delivery_aras_piece_count" string="Piece Count"/>
                        <field name="delivery_aras_payor_type_code" string="Type" widget="radio"/>
                        <br colspan="2"/>
                        <separator string="Cash On Delivery Information" colspan="2"/>
                        <field name="delivery_aras_cod_ok" string="Cash on Delivery" widget="radio" options="{'horizontal' : True}"/>
                        <field name="delivery_aras_cod_collection_type" string="Type" widget="radio" options="{'horizontal' : True}" invisible="delivery_aras_cod_ok == '0'"/>
                        <field name="delivery_aras_cod_amount" string="Amount" invisible="delivery_aras_cod_ok == '0'"/>
                        <field name="delivery_aras_cod_billing_type" string="Billing Type" invisible="1"/>
                        <br colspan="2"/>
                        <separator string="Receiver Information" colspan="2"/>
                        <field name="delivery_aras_receiver_name" string="Name"/>
                        <field name="delivery_aras_receiver_address" string="Address"/>
                        <field name="delivery_aras_receiver_phone" string="Phone"/>
                        <field name="delivery_aras_receiver_city" string="City"/>
                        <field name="delivery_aras_receiver_town" string="Town"/>
                        <field name="delivery_aras_tax_number" string="Tax Number"/>
                        <field name="delivery_aras_tax_office" string="Tax Office"/>
                        <br colspan="2"/>
                        <separator string="Descriptions" colspan="2"/>
                        <field name="delivery_aras_description" string="Description"/>
                        <field name="delivery_aras_special_field_1" string="Special Field 1"/>
                        <field name="delivery_aras_special_field_2" string="Special Field 2"/>
                        <field name="delivery_aras_special_field_3" string="Special Field 3"/>
                    </group>
                    <group>
                        <separator string="Order Status" colspan="2"/>
                        <field name="delivery_aras_date" string="Date"/>
                        <field name="delivery_aras_customer_code" string="Customer Code"/>
                        <field name="delivery_aras_waybill_number" string="Waybill Number"/>
                        <field name="delivery_aras_sender" string="Sender"/>
                        <field name="delivery_aras_receiver" string="Receiver"/>
                        <field name="delivery_aras_link_reference" string="Link Reference"/>
                        <field name="delivery_aras_tracking_reference" string="Tracking Reference"/>
                        <field name="delivery_aras_reference" string="Reference"/>
                        <field name="delivery_aras_export_code" string="Export"/>
                        <field name="delivery_aras_quantity" string="Quantity"/>
                        <field name="delivery_aras_volumetric_weight" string="Volumetric Weight"/>
                        <field name="delivery_aras_undelivered_reason" string="Undelivered Reason"/>
                        <br colspan="2"/>
                        <separator string="Departure Branch" colspan="2"/>
                        <field name="delivery_aras_departure_branch_name" string="Name"/>
                        <field name="delivery_aras_departure_branch_phone" string="Phone"/>
                        <field name="delivery_aras_departure_date" string="Date" invisible="1"/>
                        <field name="delivery_aras_departure_hour" string="Hour"/>
                        <br colspan="2"/>
                        <separator string="Arrival Branch" colspan="2"/>
                        <field name="delivery_aras_arrival_branch_name" string="Name" invisible="delivery_aras_cod_ok == '0'"/>
                        <field name="delivery_aras_arrival_branch_phone" string="Phone" invisible="delivery_aras_cod_ok == '0'"/>
                        <br colspan="2"/>
                        <separator string="Payment Status" colspan="2"/>
                        <field name="delivery_aras_currency_id" string="Currency" invisible="1"/>
                        <field name="delivery_aras_amount" string="Amount"/>
                        <br colspan="2"/>
                        <field name="delivery_aras_payment_amount" string="Payment Amount"/>
                        <field name="delivery_aras_payment_type" string="Payment Type"/>
                        <br colspan="2"/>
                        <field name="delivery_aras_collection_amount" string="Collection Amount"/>
                        <field name="delivery_aras_collection_type" string="Collection Type"/>
                        <field name="delivery_aras_collection_cancel" string="Collection Cancel"/>
                        <br colspan="2"/>
                        <separator string="Recipient Status" colspan="2"/>
                        <field name="delivery_aras_recipient_name" string="Recipient Name"/>
                        <field name="delivery_aras_recipient_date" string="Recipient Date"/>
                        <field name="delivery_aras_recipient_hour" string="Recipient Hour"/>
                        <field name="delivery_aras_type_code" string="Type Code"/>
                        <field name="delivery_aras_status" string="Status"/>
                        <field name="delivery_aras_status_code" string="Status Code"/>
                        <field name="delivery_aras_delivery_code" string="Delivery Code"/>
                        <field name="delivery_aras_status_en" string="Status (English)"/>
                        <field name="delivery_aras_value_date" string="Value Date"/>
                        <field name="delivery_aras_payment_date" string="Payment Date"/>
                        <field name="delivery_aras_return_reason" string="Return Reason"/>
                        <field name="delivery_aras_transfer_reason" string="Transfer Reason"/>
                        <field name="delivery_aras_transfer_code" string="Transfer Code"/>
                        <field name="delivery_aras_transfer_description" string="Transfer Description"/>
                        <br colspan="2"/>
                        <field name="delivery_aras_ok" invisible="1"/>
                    </group>
                </group>
            </page>
        </xpath>
        <xpath expr="//field[@name='move_ids_without_package']/form//field[@name='product_id']" position="after">
            <field name="delivery_aras_product_barcode" string="Product Barcode Number" readonly="1"/>
        </xpath>
    </field>
    </record>
</odoo>
