<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="cron_webhook" model="ir.cron">
            <field name="name">Field Service Management: Trigger Webhook</field>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="nextcall" eval="(DateTime.now().replace(second=0) + timedelta(minutes=1)).strftime('%Y-%m-%d %H:%M:%S')" />

            <field name="model_id" ref="model_fsm_api_webhook"/>
            <field name="code">model.trigger()</field>
            <field name="state">code</field>
        </record>
    </data>
</odoo>