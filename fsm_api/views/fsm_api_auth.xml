<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <record id="tree_api_auth" model="ir.ui.view">
    <field name="name">fsm.api.auth.list</field>
    <field name="model">fsm.api.auth</field>
    <field name="arch" type="xml">
        <list decoration-muted="active == False">
            <field name="sequence" widget="handle"/>
            <field name="name" decoration-bf="1"/>
            <field name="partner_id"/>
            <field name="api_key"/>
            <field name="active" widget="boolean_toggle"/>
        </list>
    </field>
    </record>

    <record id="form_api_auth" model="ir.ui.view">
    <field name="name">fsm.api.auth.form</field>
    <field name="model">fsm.api.auth</field>
    <field name="arch" type="xml">
        <form>
            <sheet>
                <div class="oe_title">
                    <label for="name"/>
                    <h1><field name="name" class="oe_inline"/></h1>
                </div>
                <group>
                    <group>
                        <field name="partner_id" options="{'no_create': True}"/>
                        <field name="project_id" options="{'no_create': True}" domain="[('partner_id', '=', partner_id)]"/>
                        <field name="customer_id" options="{'no_create': True}"/>
                        <field name="active" widget="boolean_toggle"/>
                    </group>
                    <group invisible="api_key != False">
                        <separator string="Keys" colspan="2"/>
                        <label for="api_key"/>
                        <div class="o_row text-400 font-italic">
                            API Key will be here
                        </div>
                        <label for="secret_key"/>
                        <div class="o_row text-400 font-italic">
                            Secret Key will be here
                        </div>
                    </group>
                    <group invisible="api_key == False">
                        <separator string="Keys" colspan="2"/>
                        <field name="api_key" widget="CopyClipboardChar" options="{'string': 'Copy API Key'}"/>
                        <field name="secret_key" widget="CopyClipboardChar" options="{'string': 'Copy Secret Key'}"/>
                        <separator string="Webhook" colspan="2"/>
                        <field name="webhook_url" string="URL" placeholder="https://example.com/webhook"/>
                        <field name="webhook_auth" string="Authorization" placeholder="No Auth"/>
                        <field name="webhook_username" string="Username" invisible="webhook_auth != 'basic'"/>
                        <field name="webhook_password" string="Password" password="True" invisible="webhook_auth != 'basic'"/>
                    </group>
                </group>
            </sheet>
        </form>
    </field>
    </record>

    <record id="action_api_auth" model="ir.actions.act_window">
    <field name="name">Authorizations</field>
    <field name="type">ir.actions.act_window</field>
    <field name="res_model">fsm.api.auth</field>
    <field name="view_mode">list,form</field>
    <field name="context">{'active_test': False}</field>
    <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
            No API authorization yet
        </p>
        <p>
            Create an API key and secret key then use them for making requests
        </p>
    </field>
    </record>
</odoo>