<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="form_task" model="ir.ui.view">
    <field name="model">fsm.task</field>
    <field name="inherit_id" ref="fsm.form_task"/>
    <field name="arch" type="xml">
        <xpath expr="//div[@name='button_box']" position="inside">
            <button name="action_view_api_log" type="object" class="oe_stat_button" icon="fa-file-text-o" invisible="api_log_count == 0" groups="fsm.group_manager">
                <div class="o_field_widget o_stat_info">
                    <span class="o_stat_value text-600 fw-bold">
                        <span>Count:</span>
                        <span class="float-end ml4"><field name="api_log_count" class="text-primary" nolabel="1" readonly="1"/> Records</span>
                    </span>
                    <span class="o_stat_value text-600 fw-bold">
                        <span>Done:</span>
                        <span class="float-end ml4"><field name="api_log_done" class="text-primary" nolabel="1" readonly="1"/> Records</span>
                    </span>
                    <span class="o_stat_text fw-bold">API Logs</span>
                </div>
            </button>
        </xpath>
    </field>
    </record>
</odoo>