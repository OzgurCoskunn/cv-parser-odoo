<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="tree_api_log" model="ir.ui.view">
    <field name="name">fsm.api.log.list</field>
    <field name="model">fsm.api.log</field>
    <field name="arch" type="xml">
        <list>
            <field name="create_date"/>
            <field name="partner_id" options="{'no_create': True, 'no_open': True}"/>
            <field name="auth_id" options="{'no_create': True, 'no_open': True}"/>
            <field name="service_id" options="{'no_create': True, 'no_open': True}"/>
            <field name="state" widget="badge" decoration-danger="status == False" decoration-success="status == True"/>
            <field name="message" optional="hide"/>
            <field name="company_id" groups="base.group_multi_company" options="{'no_create': True, 'no_open': True}"/>
            <field name="status" invisible="1"/>
        </list>
    </field>
    </record>

    <record id="form_api_log" model="ir.ui.view">
    <field name="name">fsm.api.log.form</field>
    <field name="model">fsm.api.log</field>
    <field name="arch" type="xml">
        <form>
            <header>
                <field name="state" widget="statusbar" statusbar_visible="success"/>
            </header>
            <sheet>
                <group>
                    <group>
                        <field name="service_id" options="{'no_create': True}"/>
                        <field name="partner_id" options="{'no_create': True}"/>
                        <field name="auth_id" options="{'no_create': True}"/>
                        <field name="status" invisible="1"/>
                    </group>
                    <group>
                        <field name="create_date" string="Date"/>
                        <!--<field name="reference" string="Reference"/>
                        <field name="environment" string="Environment" widget="radio" options="{'horizontal': True}"/>-->
                        <label for="duration"/>
                        <div class="o_row">
                            <field name="duration" nolabel="1"/>s
                        </div>
                        <field name="message"/>
                        <newline/>
                        <field name="company_id" groups="base.group_multi_company" options="{'no_create': True, 'no_open': True}"/>
                    </group>
                </group>
                <group class="mt-5">
                    <group string="Request">
                        <div colspan="2">
                            <field name="request_method" nolabel="1" class="oe_inline fw-bold mr8" widget="badge" decoration-success="request_method == 'GET'" decoration-warning="request_method == 'POST'" decoration-info="request_method == 'PUT'" decoration-primary="request_method == 'PATCH'" decoration-danger="request_method == 'DELETE'" decoration-muted="request_method == 'OPTIONS'"/> <field name="request_url" nolabel="1" class="oe_inline"/>
                        </div>
                        <br/>
                        <field name="request_data" nolabel="1" colspan="2"/>
                        <br/>
                        <field name="request_raw" nolabel="1" colspan="2" class="text-400"/>
                        <br/>
                        <field name="request_curl" nolabel="1" colspan="2" class="text-400"/>
                    </group>
                    <group string="Response" class="position-relative">
                        <div colspan="2">
                            <field name="response_code" nolabel="1" class="oe_inline fw-bold mr8" widget="badge" decoration-success="response_badge == '2'" decoration-warning="response_badge == '4'" decoration-info="response_badge == '1'" decoration-primary="response_badge == '3'" decoration-danger="response_badge == '5'" decoration-muted="response_badge == False"/> <field name="response_message" nolabel="1" class="oe_inline"/>
                            <field name="response_badge" invisible="1"/>
                        </div>
                        <br/>
                        <field name="response_data" nolabel="1" colspan="2"/>
                        <br/>
                        <field name="response_raw" nolabel="1" colspan="2" class="text-400"/>
                        <div class="position-absolute" style="top: 10px; right: 10px;">
                            <button name="action_toggle_debug" type="object" class="btn-sm btn-secondary bg-transparent border-0" string="Show Debug" invisible="debug_message == False or debug_ok != False"/>
                            <button name="action_toggle_debug" type="object" class="btn-sm btn-secondary bg-transparent border-0" string="Hide Debug" invisible="debug_message == False or debug_ok == False"/>
                        </div>
                        <br invisible="debug_message == False or debug_ok == False"/>
                        <field name="debug_message" nolabel="1" colspan="2" class="text-400" invisible="debug_message == False or debug_ok == False"/>
                        <field name="debug_ok" invisible="1"/>
                    </group>
                </group>
            </sheet>
        </form>
    </field>
    </record>

    <record id="search_api_log" model="ir.ui.view">
    <field name="name">fsm.api.log.search</field>
    <field name="model">fsm.api.log</field>
    <field name="arch" type="xml">
        <search>
            <field name="partner_id"/>
            <filter string="Failed Requests" name="filterby_error" domain="[('status', '=', False)]"/>
            <filter string="Successful Requests" name="filterby_success" domain="[('status', '=', True)]"/>
            <group>
                <filter string="Partner" name="groupby_partner" context="{'group_by': 'partner_id'}"/>
                <filter string="Status" name="groupby_status" context="{'group_by': 'status'}"/>
            </group>
        </search>
    </field>
    </record>

    <record id="action_api_log" model="ir.actions.act_window">
    <field name="name">Logs</field>
    <field name="res_model">fsm.api.log</field>
    <field name="view_mode">list,form</field>
    <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
            No logs yet
        </p>
        <p>
            Logs are listed here
        </p>
    </field>
    </record>
</odoo>
