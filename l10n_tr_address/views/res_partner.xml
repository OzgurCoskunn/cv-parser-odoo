<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form" model="ir.ui.view">
    <field name="model">res.partner</field>
    <field name="priority">20</field>
    <field name="inherit_id" ref="base.view_partner_form"/>
    <field name="arch" type="xml">
        <xpath expr="//field[@name='name']" position="before">
            <field name="field_town_selection" invisible="1"/>
            <field name="field_district_selection" invisible="1"/>
            <field name="field_street_selection" invisible="1"/>
            <field name="field_table_name_selection" invisible="1"/>
        </xpath>
        <xpath expr="//field[@name='city']" position="replace">
            <field name="city" placeholder="Town..." class="o_address_city" invisible="field_town_selection != False" readonly="type == 'contact' and parent_id != False"/>
            <field name="town_id" placeholder="Town..." class="o_address_city" options="{'no_create': True, 'no_open': True}" invisible="field_town_selection == False" readonly="type == 'contact' and parent_id != False"/>
        </xpath>
        <xpath expr="//field[@name='street']" position="replace"/>
        <xpath expr="//field[@name='street2']" position="replace">
            <field name="street3" class="o_address_street" placeholder="Apartment Number..." readonly="type == 'contact' and parent_id != False"/>
            <field name="street2" placeholder="Street..." class="o_address_street" invisible="field_street_selection != False" readonly="type == 'contact' and parent_id != False"/>
            <field name="street_id" placeholder="Street..." class="o_address_street" options="{'no_create': True, 'no_open': True}" invisible="field_street_selection == False" readonly="type == 'contact' and parent_id != False"/>
            <field name="street" placeholder="District..." class="o_address_street" invisible="field_district_selection != False" readonly="type == 'contact' and parent_id != False"/>
            <field name="district_id" placeholder="District..." class="o_address_street" options="{'no_create': True, 'no_open': True}" invisible="field_district_selection == False" readonly="type == 'contact' and parent_id != False"/>
        </xpath>
        <xpath expr="//field[@name='child_ids']/form//field[@name='city']" position="replace">
            <field name="city" placeholder="Town..." class="o_address_city" invisible="parent.field_town_selection != False"/>
            <field name="town_id" placeholder="Town..." class="o_address_city" options="{'no_create': True, 'no_open': True}" invisible="parent.field_town_selection == False"/>
        </xpath>
        <xpath expr="//field[@name='child_ids']/form//field[@name='street']" position="replace"/>
        <xpath expr="//field[@name='child_ids']/form//field[@name='street2']" position="replace">
            <field name="street3" placeholder="Apartment Number..." class="o_address_street" readonly="type == 'contact' and parent_id != False"/>
            <field name="street2" placeholder="Street..." class="o_address_street" invisible="parent.field_street_selection != False"/>
            <field name="street_id" placeholder="Street..." class="o_address_street" options="{'no_create': True, 'no_open': True}" invisible="parent.field_street_selection == False"/>
            <field name="street" placeholder="District..." class="o_address_street" invisible="parent.field_district_selection != False"/>
            <field name="district_id" placeholder="District..." class="o_address_street" options="{'no_create': True, 'no_open': True}" invisible="parent.field_district_selection == False"/>
        </xpath>
        <xpath expr="//field[@name='name']" position="after">
            <field name="table_name" placeholder="Table Name..." invisible="field_table_name_selection == False"/>
        </xpath>
        <xpath expr="//page[@name='geo_location']//label[@for='date_localization']" position="before">
            <field name="uavt_code"/>
        </xpath>
    </field>
    </record>
</odoo>