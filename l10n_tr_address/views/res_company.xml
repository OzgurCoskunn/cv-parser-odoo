<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_company_form" model="ir.ui.view">
    <field name="model">res.company</field>
    <field name="inherit_id" ref="base.view_company_form"/>
    <field name="arch" type="xml">
        <xpath expr="//field[@name='city']" position="replace">
            <field name="city" invisible="1"/>
            <field name="town_id" placeholder="Town..." class="o_address_city"/>
        </xpath>
        <xpath expr="//field[@name='street']" position="replace"/>
        <xpath expr="//field[@name='street2']" position="replace">
            <field name="street" invisible="1"/>
            <field name="street2" invisible="1"/>
            <field name="street3" placeholder="Apartment Number..." class="o_address_street"/>
            <field name="street_id" placeholder="Street" class="o_address_street"/>
            <field name="district_id" placeholder="District..." class="o_address_street"/>
        </xpath>
    </field>
    </record>
</odoo>