<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
    <field name="model">res.config.settings</field>
    <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
    <field name="arch" type="xml">
        <xpath expr="//div[@id='contacts_settings']" position="inside">
            <div class="row mt16 o_settings_container" name="contacts_setting_container">
                <div class="col-xs-12 col-md-6 o_setting_box">
                    <div class="o_setting_right_pane" id="partner_address_field_settings">
                        <div class="o_form_label">Partner Address Fields</div>
                        <div class="text-muted">Use more advanced options for partner address information</div>
                        <div class="content-group">
                            <div class="mt16">
                                <div class="border-top pt-2">
                                    <label for="field_town_selection" string="Town" class="col-5 fw-bold o_light_label"/>
                                    <span>Text</span>
                                    <field name="field_town_selection" widget="boolean_toggle" class="w-auto mx-2"/>
                                    <span>List</span>
                                </div>
                                <div class="border-top pt-2">
                                    <label for="field_district_selection" string="District" class="col-5 fw-bold o_light_label"/>
                                    <span>Text</span>
                                    <field name="field_district_selection" widget="boolean_toggle" class="w-auto mx-2"/>
                                    <span>List</span>
                                </div>
                                <div class="border-top pt-2">
                                    <label for="field_street_selection" string="Street" class="col-5 fw-bold o_light_label"/>
                                    <span>Text</span>
                                    <field name="field_street_selection" widget="boolean_toggle" class="w-auto mx-2"/>
                                    <span>List</span>
                                </div>
                                <div class="border-top pt-2">
                                    <label for="field_table_name_selection" string="Table_name" class="col-5 fw-bold o_light_label"/>
                                    <span>Show</span>
                                    <field name="field_table_name_selection" widget="boolean_toggle" class="w-auto mx-2"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </xpath>
    </field>
    </record>
</odoo>