<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_picking_form" model="ir.ui.view">
    <field name="model">stock.picking</field>
    <field name="inherit_id" ref="stock.view_picking_form"/>
    <field name="arch" type="xml">
        <xpath expr="//div[@name='button_box']" position="inside">
            <field name="delivery_method_ok" invisible="1"/>
            <button
                name="action_delivery_method_toggle"
                type="object"
                class="oe_stat_button"
                icon="fa-user-circle"
                groups="base.group_user"
                invisible="not delivery_method_ok or not carrier_tracking_ref or state in ('done', 'cancel')">
                <div class="o_form_field o_stat_info mr3">
                    <span class="o_stat_value">Delivery Method</span><span class="o_stat_text">Personal Sending</span>
                </div>
            </button>
            <button
                name="action_delivery_method_toggle"
                type="object"
                class="oe_stat_button"
                icon="fa-truck"
                groups="base.group_user"
                invisible="not delivery_method_ok or carrier_tracking_ref or state in ('done', 'cancel')">
                <div class="o_form_field o_stat_info mr3">
                    <span class="o_stat_value">Delivery Method</span><span class="o_stat_text">Cargo Sending</span>
                </div>
            </button>
        </xpath>
    </field>
    </record>
</odoo>