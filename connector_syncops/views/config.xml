<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="connector_list" model="ir.ui.view">
    <field name="name">syncops.connector.list</field>
    <field name="model">syncops.connector</field>
    <field name="arch" type="xml">
        <list decoration-muted="active == False" sample="1">
            <field name="name"/>
            <field name="username"/>
            <field name="token"/>
            <field name="line_ids"/>
            <field name="connected"/>
            <field name="active" widget="boolean_toggle"/>
            <field name="company_id" groups="base.group_multi_company" optional="hide"/>
        </list>
    </field>
    </record>

    <record id="connector_form" model="ir.ui.view">
    <field name="name">syncops.connector.form</field>
    <field name="model">syncops.connector</field>
    <field name="arch" type="xml">
        <form>
            <sheet>
                <div class="oe_button_box" name="button_box">
                    <button name="action_view_log" type="object" class="oe_stat_button" icon="fa-file-text-o" invisible="not connected" string="Logs"/>
                    <button name="action_connect" type="object" class="oe_stat_button text-danger" icon="fa-unlink" invisible="connected" string="Not Connected"/>
                    <button name="action_connect" type="object" class="oe_stat_button text-primary" icon="fa-chain" invisible="not connected" string="Connected"/>
                    <button name="action_toggle_environment" type="object" class="oe_stat_button text-muted" icon="fa-stop" invisible="not environment" string="Test"/>
                    <button name="action_toggle_environment" type="object" class="oe_stat_button text-primary" icon="fa-play" invisible="environment" string="Production"/>
                    <button name="action_toggle_active" type="object" class="oe_stat_button text-muted" icon="fa-toggle-off" invisible="active" string="Passive"/>
                    <button name="action_toggle_active" type="object" class="oe_stat_button text-primary" icon="fa-toggle-on" invisible="not active" string="Active"/>
                </div>
                <div class="oe_title">
                    <label for="name"/>
                    <h1>
                        <field name="name"/>
                    </h1>
                </div>
                <group>
                    <group>
                        <field name="username"/>
                        <field name="token"/>
                    </group>
                    <group>
                        <field name="company_id" groups="base.group_multi_company" readonly="1" force_save="1"/>
                        <field name="active" invisible="True"/>
                        <field name="environment" invisible="True"/>
                        <field name="connected" invisible="True" force_save="1"/>
                    </group>
                </group>
                <notebook>
                    <page string="Methods">
                        <div colspan="2" invisible="not connected">
                            <field name="line_ids" nolabel="1">
                                <list create="0" edit="0" delete="0">
                                    <field name="category" decoration-bf="1"/>
                                    <field name="name"/>
                                    <field name="input_ids"/>
                                    <field name="output_ids"/>
                                    <field name="method" invisible="True"/>
                                </list>
                                <form class="o_form_syncops_connector">
                                    <sheet>
                                        <group>
                                            <group>
                                                <div class="text-600 d-flex" colspan="2">
                                                    <div class="text-center px-4">
                                                        <i class="fa fa-info text-primary h1"/>
                                                    </div>
                                                    <div class="d-flex flex-column">
                                                        <div style="font-size: 0.9rem">
                                                            <p>Inputs and outputs are listed below. If you want to assign a default value, you can use edit buttons placed end of the lines.</p>
                                                            <p>Default values are linked to input values for inputs and outputs. Values can be left as it is, they can be set as a constant or they can run a python code.</p>
                                                        </div>
                                                    </div>
                                                </div>
                                            </group>
                                            <group class="o_config_connector">
                                                <div class="o_td_label">
                                                    <div class="o_config_type o_config_method">Method</div>
                                                </div>
                                                <div class="o_row">
                                                    <field name="name" nolabel="1" class="border-0 text-center" placeholder="Please select a method..."/>
                                                </div>
                                                <div name="config" colspan="2"/>
                                                <field name="method" invisible="True"/>
                                            </group>
                                        </group>
                                        <notebook>
                                            <page string="Inputs">
                                                <group class="d-flex">
                                                    <group>
                                                        <separator string="Match"/>
                                                        <field name="input_ids" nolabel="1" colspan="2"/>
                                                    </group>
                                                    <group class="h-25">
                                                        <separator string="Route"/>
                                                        <field name="input_route" nolabel="1" colspan="2" widget="ace" options="{'mode': 'python'}"/>
                                                        <separator string="Value"/>
                                                        <field name="input_value" nolabel="1" colspan="2" widget="ace" options="{'mode': 'python'}"/>
                                                    </group>
                                                </group>
                                            </page>
                                        </notebook>
                                        <notebook>
                                            <page string="Outputs">
                                                <group class="d-flex">
                                                    <group>
                                                        <separator string="Match"/>
                                                        <field name="output_ids" nolabel="1" colspan="2"/>
                                                    </group>
                                                    <group class="h-25">
                                                        <separator string="Route"/>
                                                        <field name="output_route" nolabel="1" colspan="2" widget="ace" options="{'mode': 'python'}"/>
                                                        <separator string="Value"/>
                                                        <field name="output_value" nolabel="1" colspan="2" widget="ace" options="{'mode': 'python'}"/>
                                                    </group>
                                                </group>
                                            </page>
                                        </notebook>
                                    </sheet>
                                </form>
                            </field>
                        </div>
                        <em class="text-muted" invisible="connected">Methods will be available after connection is successful</em>
                    </page>
                    <page string="Options" invisible="not connected">
                        <group>
                            <group>
                                <field name="variable_ids">
                                    <list editable="bottom">
                                        <field name="sequence" widget="handle"/>
                                        <field name="name" decoration-bf="1"/>
                                        <field name="value"/>
                                    </list>
                                    <form>
                                        <sheet>
                                            <group>
                                                <group>
                                                    <field name="name"/>
                                                </group>
                                                <group>
                                                    <field name="value"/>
                                                </group>
                                            </group>
                                        </sheet>
                                    </form>
                                </field>
                            </group>
                            <group>
                                <field name="company_ids" groups="base.group_multi_company" widget="many2many_tags" options="{'no_open': True, 'no_create': True}" placeholder="No company selected"/>
                            </group>
                        </group>
                    </page>
                    <page string="Hooks" invisible="not connected">
                        <field name="hook_ids" nolabel="1">
                            <list decoration-muted="active == False">
                                <field name="name" decoration-bf="1"/>
                                <field name="type" widget="badge" decoration-info="active == True"/>
                                <field name="hook" widget="badge" decoration-warning="hook == 'pre'" decoration-success="hook == 'post'"/>
                                <field name="active" invisible="True"/>
                                <field name="method" invisible="True"/>
                                <field name="method_id" invisible="True"/>
                                <field name="method_ids" invisible="True"/>
                                <field name="method_compute" invisible="True"/>
                            </list>
                            <form class="o_form_syncops_connector">
                                <sheet>
                                    <group>
                                        <group>
                                            <div class="text-600 d-flex" colspan="2">
                                                <div class="text-center px-4">
                                                    <i class="fa fa-info text-primary h1"/>
                                                </div>
                                                <div class="d-flex flex-column">
                                                    <div style="font-size: 0.9rem">
                                                        <p>You can define hooks to run after or before synchronization.</p>
                                                        <p>If code field is blank, then default code will be executed.</p>
                                                    </div>
                                                </div>
                                            </div>
                                        </group>
                                        <group class="o_config_connector">
                                            <div class="o_td_label">
                                                <div class="o_config_type o_config_method">Method</div>
                                            </div>
                                            <div class="o_row">
                                                <field name="method_id" nolabel="1" class="border-0 text-center" placeholder="Please select a method..." options="{'no_create': True, 'no_open': True}"/>
                                                <field name="name" invisible="1"/>
                                                <field name="method" invisible="1"/>
                                                <field name="method_ids" invisible="1"/>
                                                <field name="method_compute" invisible="1"/>
                                            </div>
                                            <div name="config" colspan="2">
                                                <div>
                                                    <table class="table table-sm o_config_connector_table">
                                                        <tr class="o_config_connector_table_header">
                                                            <td class="text-center font-weight-bold" colspan="3">Configuration</td>
                                                        </tr>
                                                        <tr class="o_config_connector_table_option">
                                                            <td class="text-right pr-2"><i class="fa fa-toggle-on"/></td>
                                                            <td class="text-left font-weight-bold">Active</td>
                                                            <td class="text-center text-nowrap"><field name="active" nolabel="1" widget="boolean_toggle"/></td>
                                                        </tr>
                                                        <tr class="o_config_connector_table_option">
                                                            <td class="text-right pr-2"><i class="fa fa-magic"/></td>
                                                            <td class="text-left font-weight-bold">Hook</td>
                                                            <td class="text-center text-nowrap"><field name="hook" nolabel="1" required="1" widget="radio" options="{'horizontal': True}"/></td>
                                                        </tr>
                                                        <tr class="o_config_connector_table_option">
                                                            <td class="text-right pr-2"><i class="fa fa-wrench"/></td>
                                                            <td class="text-left font-weight-bold">Type</td>
                                                            <td class="text-center text-nowrap"><field name="type" nolabel="1" required="1" widget="radio" options="{'horizontal': True}"/></td>
                                                        </tr>
                                                        <tr class="o_config_connector_table_option" invisible="not type">
                                                            <td class="text-right pr-2"><i class="fa fa-filter"/></td>
                                                            <td class="text-left font-weight-bold">Subtype</td>
                                                            <td class="text-center text-nowrap"><field name="subtype" nolabel="1" placeholder="No Subtype"/></td>
                                                        </tr>
                                                    </table>
                                                </div>
                                            </div>
                                        </group>
                                    </group>
                                    <notebook>
                                        <page string="Code">
                                            <field name="code" nolabel="1" colspan="2" widget="ace" options="{'mode': 'python'}"/>
                                        </page>
                                    </notebook>
                                </sheet>
                            </form>
                        </field>
                    </page>
                </notebook>
            </sheet>
        </form>
    </field>
    </record>

    <record id="connector_line_input_tree" model="ir.ui.view">
    <field name="name">syncops.connector.line.input.tree</field>
    <field name="model">syncops.connector.line.input</field>
    <field name="arch" type="xml">
        <list>
            <field name="name"/>
            <field name="input" decoration-bf="1"/>
            <field name="direction" string="→" decoration-bf="1" column_invisible="not parent.method"/>
            <field name="output" decoration-bf="1" column_invisible="not parent.method"/>
            <button name="action_default" type="object" icon="fa-edit" invisible="default_type not in ('const', 'code')"/>
            <button name="action_default" type="object" icon="fa-edit" invisible="default_type in ('const', 'code')" class="text-300"/>
            <field name="default_type" invisible="True"/>
        </list>
    </field>
    </record>

    <record id="connector_line_input_form" model="ir.ui.view">
    <field name="name">syncops.connector.line.input.form</field>
    <field name="model">syncops.connector.line.input</field>
    <field name="arch" type="xml">
        <form>
            <sheet>
                <div class="oe_title">
                    <label for="name"/>
                    <h1>
                        <field name="name"/>
                    </h1>
                </div>
                <group>
                    <group>
                        <separator string="Input"/>
                        <field name="input" string="Value"/>
                        <field name="input_type" string="Type"/>
                        <separator string="Output" invisible="not parent.method"/>
                        <field name="output" string="Value" invisible="not parent.method"/>
                        <field name="output_type" string="Type" invisible="not parent.method"/>
                    </group>
                    <group string="Defaults">
                        <field name="default_type" widget="radio" options="{'horizontal': True}" class="justify-content-around mb-3" nolabel="1" colspan="2"/>
                        <field name="default_const" invisible="default_type != 'const'" class="text-center font-weight-bold d-block" placeholder="Enter a constant value..." nolabel="1" colspan="2"/>
                        <field name="default_code" invisible="default_type != 'code'" nolabel="1" colspan="2" widget="ace" options="{'mode': 'python'}"/>
                        <button name="action_default" type="object" icon="fa-edit" string="Set Defaults" class="btn-secondary d-flex mx-auto align-items-center text-uppercase mt-3" style="gap:5px"/>
                    </group>
                </group>
            </sheet>
        </form>
    </field>
    </record>

    <record id="connector_line_output_tree" model="ir.ui.view">
    <field name="name">syncops.connector.line.output.tree</field>
    <field name="model">syncops.connector.line.output</field>
    <field name="arch" type="xml">
        <list>
            <field name="name"/>
            <field name="input" decoration-bf="1" column_invisible="not parent.method"/>
            <field name="direction" string="→" decoration-bf="1" column_invisible="not parent.method"/>
            <field name="output" decoration-bf="1"/>
            <button name="action_default" type="object" icon="fa-edit" invisible="default_type not in ('const', 'code')"/>
            <button name="action_default" type="object" icon="fa-edit" invisible="default_type in ('const', 'code')" class="text-300"/>
            <field name="default_type" invisible="True"/>
        </list>
    </field>
    </record>

    <record id="connector_line_output_form" model="ir.ui.view">
    <field name="name">syncops.connector.line.output.form</field>
    <field name="model">syncops.connector.line.output</field>
    <field name="arch" type="xml">
        <form>
            <sheet>
                <div class="oe_title">
                    <label for="name"/>
                    <h1>
                        <field name="name"/>
                    </h1>
                </div>
                <group>
                    <group>
                        <separator string="Input" invisible="not parent.method"/>
                        <field name="input" string="Value" invisible="not parent.method"/>
                        <field name="input_type" string="Type" invisible="not parent.method"/>
                        <separator string="Output"/>
                        <field name="output" string="Value"/>
                        <field name="output_type" string="Type"/>
                    </group>
                    <group string="Defaults">
                        <field name="default_type" widget="radio" options="{'horizontal': True}" class="justify-content-around mb-3" nolabel="1" colspan="2"/>
                        <field name="default_const" invisible="default_type != 'const'" class="text-center font-weight-bold d-block" placeholder="Enter a constant value..." nolabel="1" colspan="2"/>
                        <field name="default_code" invisible="default_type != 'code'" nolabel="1" colspan="2" widget="ace" options="{'mode': 'python'}"/>
                        <button name="action_default" type="object" icon="fa-edit" string="Set Defaults" class="btn-secondary d-flex mx-auto align-items-center text-uppercase mt-3" style="gap:5px"/>
                    </group>
                </group>
            </sheet>
        </form>
    </field>
    </record>

    <record id="connector_line_default_form" model="ir.ui.view">
    <field name="name">syncops.connector.line.default.form</field>
    <field name="model">syncops.connector.line.default</field>
    <field name="arch" type="xml">
        <form create="0" class="o_form_syncops_connector_line_default">
            <sheet>
                <group>
                    <field name="type" widget="radio" options="{'horizontal': True}" class="justify-content-between mb-3" nolabel="1" colspan="2"/>
                    <field name="const" invisible="type != 'const'" class="text-center font-weight-bold d-block" placeholder="Enter a constant value..." nolabel="1" colspan="2"/>
                    <field name="code" invisible="type != 'code'" placeholder="Enter python code..." nolabel="1" colspan="2" widget="ace" options="{'mode': 'python'}"/>
                    <field name="input_id" invisible="True"/>
                    <field name="output_id" invisible="True"/>
                </group>
            </sheet>
        </form>
    </field>
    </record>

    <record id="log_tree" model="ir.ui.view">
    <field name="name">syncops.log.tree</field>
    <field name="model">syncops.log</field>
    <field name="arch" type="xml">
        <list>
            <field name="date"/>
            <field name="partner_name"/>
            <field name="token_name"/>
            <field name="connector_name"/>
            <field name="method_name"/>
            <field name="state" widget="badge" decoration-danger="status == False" decoration-success="status == True"/>
            <field name="message" optional="hide"/>
            <field name="status" invisible="True"/>
        </list>
    </field>
    </record>

    <record id="log_form" model="ir.ui.view">
    <field name="name">syncops.log.form</field>
    <field name="model">syncops.log</field>
    <field name="arch" type="xml">
        <form>
            <header>
                <field name="state" widget="statusbar" statusbar_visible="success"/>
            </header>
            <sheet>
                <group>
                    <group>
                        <field name="partner_name"/>
                        <field name="connector_name"/>
                        <field name="method_name"/>
                        <field name="token_name"/>
                        <field name="status" invisible="1"/>
                    </group>
                    <group>
                        <field name="date"/>
                        <label for="duration"/>
                        <div class="o_row">
                            <field name="duration" nolabel="1"/>s
                        </div>
                        <field name="message"/>
                    </group>
                </group>
                <group class="mt-5">
                    <group string="Request">
                        <div colspan="2">
                            <field name="request_method" nolabel="1" class="oe_inline fw-bold mr8" widget="badge" decoration-success="request_method == 'get'" decoration-warning="request_method == 'post'" decoration-info="request_method == 'put'" decoration-primary="request_method == 'patch'" decoration-danger="request_method == 'delete'" decoration-muted="request_method == 'options'"/> <field name="request_url" nolabel="1" class="oe_inline"/>
                        </div>
                        <br/>
                        <field name="request_data" nolabel="1" colspan="2"/>
                        <br/>
                        <field name="request_raw" nolabel="1" colspan="2" class="text-400"/>
                    </group>
                    <group string="Response">
                        <div colspan="2">
                            <field name="response_code" nolabel="1" class="oe_inline fw-bold mr8" widget="badge" decoration-success="response_badge == '2'" decoration-warning="response_badge == '4'" decoration-info="response_badge == '1'" decoration-primary="response_badge == '3'" decoration-danger="response_badge == '5'" decoration-muted="response_badge == False"/> <field name="response_message" nolabel="1" class="oe_inline"/>
                            <field name="response_badge" invisible="True"/>
                        </div>
                        <br/>
                        <field name="response_data" nolabel="1" colspan="2"/>
                        <br/>
                        <field name="response_raw" nolabel="1" colspan="2" class="text-400"/>
                    </group>
                </group>
            </sheet>
        </form>
    </field>
    </record>

    <record id="log_search" model="ir.ui.view">
    <field name="name">syncops.log.search</field>
    <field name="model">syncops.log</field>
    <field name="arch" type="xml">
        <search>
            <filter string="Failed Requests" name="filterby_error" domain="[('status', '=', False)]"/>
            <filter string="Successful Requests" name="filterby_success" domain="[('status', '=', True)]"/>
            <group>
                <filter string="Status" name="groupby_status" context="{'group_by': 'state'}"/>
            </group>
        </search>
    </field>
    </record>

    <record id="action_connector" model="ir.actions.act_window">
    <field name="name">syncOPS Integrations</field>
    <field name="res_model">syncops.connector</field>
    <field name="view_mode">list,form</field>
    <field name="domain">['|',('active','=',False),('active','=',True)]</field>
    <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
            No syncOPS integrations yet
        </p>
        <p>
            syncOPS integrations are listed here
        </p>
    </field>
    </record>

    <record id="action_log" model="ir.actions.act_window">
    <field name="name">Logs</field>
    <field name="res_model">syncops.log</field>
    <field name="view_mode">list,form</field>
    <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
            No logs yet
        </p>
        <p>
            Logs are listed here
        </p>
    </field>
    </record>

    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.syncops</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="SyncOPS" name="connector_syncops">
                    <block title="Connection" name="syncops_connection_setting_container">
                        <setting id="syncops_url_setting" help="Endpoint URL for SyncOPS">
                            <field name="syncops_url"/>
                            <div class="mt16" groups="base.group_no_one">
                                <button name="%(connector_syncops.action_connector)d" 
                                    icon="oi-arrow-right" 
                                    type="action" 
                                    string="Integrations" 
                                    class="btn-link"/>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

    <record id="action_syncops_config_settings" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="context">{'module' : 'connector_syncops'}</field>
    </record>
</odoo>
