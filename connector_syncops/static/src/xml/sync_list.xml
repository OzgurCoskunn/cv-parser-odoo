<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="connector_syncops.SyncListButtons" t-inherit="web.ListView.Buttons" t-inherit-mode="primary" owl="1">
        <xpath expr="." position="inside">
            <div class="d-flex o_list_buttons" role="toolbar" aria-label="Main actions">
                <button type="button" class="btn btn-primary" title="Sync" accesskey="s" t-on-click="onSync">
                    Sync
                </button>
                <button type="button" class="btn btn-secondary ml-2" title="Discard" accesskey="j" t-on-click="onClose">
                    Discard
                </button>
            </div>
        </xpath>
    </t>
</templates>
