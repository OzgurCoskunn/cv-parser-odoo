<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Module Categories -->
        <record id="module_category" model="ir.module.category">
            <field name="name">Field Service</field>
            <field name="description">Field Service</field>
            <field name="parent_id" ref="base.module_category_services"/>
            <field name="sequence">5</field>
        </record>
        <record id="module_technical" model="ir.module.category">
            <field name="name">Field Service: Technical</field>
            <field name="description">Field Service: Technical</field>
            <field name="sequence">6</field>
        </record>

        <!-- Privileges -->
        <record model="res.groups.privilege" id="privilege_field_service">
            <field name="name">Field Service</field>
            <field name="category_id" ref="module_category"/>
        </record>

        <record model="res.groups.privilege" id="privilege_technical">
            <field name="name">Technical Features</field>
            <field name="category_id" ref="module_technical"/>
        </record>

        <!-- Technical Groups -->
        <record model="res.groups" id="group_chatter_message">
            <field name="name">Access Message Button on Chatter</field>
            <field name="privilege_id" ref="privilege_technical"/>
            <field name="user_ids" eval="[Command.link(ref('base.user_root')), Command.link(ref('base.user_admin'))]"/>
        </record>
        <record model="res.groups" id="group_chatter_note">
            <field name="name">Access Note Button on Chatter</field>
            <field name="privilege_id" ref="privilege_technical"/>
            <field name="user_ids" eval="[Command.link(ref('base.user_root')), Command.link(ref('base.user_admin'))]"/>
        </record>
        <record model="res.groups" id="group_chatter_activity">
            <field name="name">Access Activity Button on Chatter</field>
            <field name="privilege_id" ref="privilege_technical"/>
            <field name="user_ids" eval="[Command.link(ref('base.user_root')), Command.link(ref('base.user_admin'))]"/>
        </record>
        <record model="res.groups" id="group_chatter_attachment">
            <field name="name">Access Attachment Button on Chatter</field>
            <field name="privilege_id" ref="privilege_technical"/>
            <field name="user_ids" eval="[Command.link(ref('base.user_root')), Command.link(ref('base.user_admin'))]"/>
        </record>
        <record model="res.groups" id="group_chatter_follower">
            <field name="name">Access Follower Button on Chatter</field>
            <field name="privilege_id" ref="privilege_technical"/>
            <field name="user_ids" eval="[Command.link(ref('base.user_root')), Command.link(ref('base.user_admin'))]"/>
        </record>
        <record model="res.groups" id="group_chatter_log">
            <field name="name">Access Logs on Chatter</field>
            <field name="privilege_id" ref="privilege_technical"/>
            <field name="user_ids" eval="[Command.link(ref('base.user_root')), Command.link(ref('base.user_admin'))]"/>
        </record>
        <record model="res.groups" id="group_action_print">
            <field name="name">Access Print Button</field>
            <field name="privilege_id" ref="privilege_technical"/>
            <field name="user_ids" eval="[Command.link(ref('base.user_root')), Command.link(ref('base.user_admin'))]"/>
        </record>
        <record model="res.groups" id="group_action_button">
            <field name="name">Access Action Button</field>
            <field name="privilege_id" ref="privilege_technical"/>
            <field name="user_ids" eval="[Command.link(ref('base.user_root')), Command.link(ref('base.user_admin'))]"/>
        </record>
        <record model="res.groups" id="group_action_archieve">
            <field name="name">Access Archieve Action</field>
            <field name="privilege_id" ref="privilege_technical"/>
            <field name="user_ids" eval="[Command.link(ref('base.user_root')), Command.link(ref('base.user_admin'))]"/>
        </record>
        <record model="res.groups" id="group_action_export">
            <field name="name">Access Export Action</field>
            <field name="privilege_id" ref="privilege_technical"/>
            <field name="user_ids" eval="[Command.link(ref('base.user_root')), Command.link(ref('base.user_admin'))]"/>
        </record>
        <record model="res.groups" id="group_action_import">
            <field name="name">Access Import Action</field>
            <field name="privilege_id" ref="privilege_technical"/>
            <field name="user_ids" eval="[Command.link(ref('base.user_root')), Command.link(ref('base.user_admin'))]"/>
        </record>

        <!-- Field Service Groups -->
        <record model="res.groups" id="group_base">
            <field name="name">Base User</field>
            <field name="privilege_id" ref="privilege_field_service"/>
            <field name="implied_ids" eval="[Command.link(ref('base.group_user'))]"/>
        </record>
        <record model="res.groups" id="group_user">
            <field name="name">Field Technician</field>
            <field name="privilege_id" ref="privilege_field_service"/>
            <field name="implied_ids" eval="[Command.link(ref('group_base')), Command.link(ref('group_action_print')), Command.link(ref('base.group_partner_manager'))]"/>
        </record>
        <record model="res.groups" id="group_operator">
            <field name="name">Zone Operation Expert</field>
            <field name="privilege_id" ref="privilege_field_service"/>
            <field name="implied_ids" eval="[Command.link(ref('group_user')), Command.link(ref('group_action_button')), Command.link(ref('group_action_export'))]"/>
        </record>
        <record model="res.groups" id="group_officer">
            <field name="name">Zone Manager</field>
            <field name="privilege_id" ref="privilege_field_service"/>
            <field name="implied_ids" eval="[Command.link(ref('group_operator'))]"/>
        </record>
        <record model="res.groups" id="group_manager">
            <field name="name">Central Operation Manager</field>
            <field name="privilege_id" ref="privilege_field_service"/>
            <field name="implied_ids" eval="[Command.link(ref('group_officer'))]"/>
        </record>
        <record model="res.groups" id="group_administrator">
            <field name="name">Administrator</field>
            <field name="privilege_id" ref="privilege_field_service"/>
            <field name="implied_ids" eval="[Command.link(ref('group_manager')), Command.link(ref('group_action_import')), Command.link(ref('group_action_archieve'))]"/>
            <field name="user_ids" eval="[Command.link(ref('base.user_root')), Command.link(ref('base.user_admin'))]"/>
        </record>
    </data>

    <data noupdate="0"><!-- TODO: set to 1 -->
        <!-- rules -->
        <record id="rule_task_user" model="ir.rule">
            <field name="name">Access only related tasks for users</field>
            <field name="domain_force">['|', ('user_id', '=', user.id), '&amp;', ('team_ids', 'in', user.mapped('crm_team_member_ids.crm_team_id').ids), '|', ('user_id', '=', False), ('stage_type', '=', '2')]</field>
            <field name="groups" eval="[(4, ref('fsm.group_user'))]"/>
            <field name="model_id" ref="fsm.model_fsm_task"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
        <record id="rule_task_operator" model="ir.rule">
            <field name="name">Access only related tasks for operators</field>
            <field name="domain_force">[('team_ids', 'in', user.mapped('crm_team_member_ids.crm_team_id').ids)]</field>
            <field name="groups" eval="[(4, ref('fsm.group_operator'))]"/>
            <field name="model_id" ref="fsm.model_fsm_task"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
        <record id="rule_task_manager" model="ir.rule">
            <field name="name">Access only related tasks for administrators</field>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('fsm.group_administrator'))]"/>
            <field name="model_id" ref="fsm.model_fsm_task"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
        <record id="rule_stock_location_user" model="ir.rule">
            <field name="name">Access only related stock locations for users</field>
            <field name="domain_force">['|', ('usage', 'in', ('view', 'customer')), ('fsm_user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('fsm.group_user'))]"/>
            <field name="model_id" ref="stock.model_stock_location"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
        <record id="rule_stock_location_manager" model="ir.rule">
            <field name="name">Access only related stock locations for administrators</field>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('fsm.group_administrator'))]"/>
            <field name="model_id" ref="stock.model_stock_location"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
        <record id="rule_stock_quant_user" model="ir.rule">
            <field name="name">Access only related stock quantities for users</field>
            <field name="domain_force">[('location_id.fsm_user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('fsm.group_user'))]"/>
            <field name="model_id" ref="stock.model_stock_quant"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
        <record id="rule_stock_quant_manager" model="ir.rule">
            <field name="name">Access only related stock quantities for administrators</field>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('fsm.group_administrator'))]"/>
            <field name="model_id" ref="stock.model_stock_quant"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
        <record id="rule_stock_picking_type_user" model="ir.rule">
            <field name="name">Access only related stock picking types for users</field>
            <field name="domain_force">['&amp;', ('warehouse_id', 'in', user.fsm_warehouse_ids.ids), '|', ('sequence_code', 'not in', ('POS', 'IN')), '&amp;', ('sequence_code', '=', 'IN'), ('return_picking_type_id', '=', False)]</field>
            <field name="groups" eval="[(4, ref('fsm.group_user'))]"/>
            <field name="model_id" ref="stock.model_stock_picking_type"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
        <record id="rule_stock_picking_type_manager" model="ir.rule">
            <field name="name">Access only related stock picking types for administrators</field>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('fsm.group_administrator'))]"/>
            <field name="model_id" ref="stock.model_stock_picking_type"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
        <record id="rule_stock_picking_user" model="ir.rule">
            <field name="name">Access only related stock picking for users</field>
            <field name="domain_force">['&amp;', ('fsm_pending', '=', False), '|', '|', '|', ('location_id.fsm_user_id', '=', user.id), ('location_id.fsm_users_id', 'in', user.ids), ('location_dest_id.fsm_user_id', '=', user.id), ('location_dest_id.fsm_users_id', 'in', user.ids)]</field>
            <field name="groups" eval="[(4, ref('fsm.group_user'))]"/>
            <field name="model_id" ref="stock.model_stock_picking"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
        <record id="rule_stock_picking_operator" model="ir.rule">
            <field name="name">Access only related stock picking for operators</field>
            <field name="domain_force">['&amp;', ('fsm_pending', '=', False), '|', '|', '|', ('location_id.fsm_user_id', 'in', user.mapped('crm_team_member_ids.crm_team_id.crm_team_member_ids.user_id').ids), ('location_id.fsm_users_id', 'in', user.mapped('crm_team_member_ids.crm_team_id.crm_team_member_ids.user_id').ids), ('location_dest_id.fsm_user_id', 'in', user.mapped('crm_team_member_ids.crm_team_id.crm_team_member_ids.user_id').ids), ('location_dest_id.fsm_users_id', 'in', user.mapped('crm_team_member_ids.crm_team_id.crm_team_member_ids.user_id').ids)]</field>
            <field name="groups" eval="[(4, ref('fsm.group_operator'))]"/>
            <field name="model_id" ref="stock.model_stock_picking"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
        <record id="rule_stock_picking_manager" model="ir.rule">
            <field name="name">Access only related stock picking for administrators</field>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('fsm.group_administrator'))]"/>
            <field name="model_id" ref="stock.model_stock_picking"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
        <record id="rule_sla_ticket_user" model="ir.rule">
            <field name="name">Access only related tickets for users</field>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('fsm.group_user'))]"/>
            <field name="model_id" ref="sla.model_sla_ticket"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
        <record id="rule_sla_ticket_operator" model="ir.rule">
            <field name="name">Access only related tickets for operators</field>
            <field name="domain_force">['|', '|', ('partner_id', 'in', user.mapped('crm_team_member_ids.crm_team_id.crm_team_member_ids.user_id.fsm_task_ids.partner_id').ids), ('team_id', 'in', user.mapped('crm_team_member_ids.crm_team_id').ids), ('user_id', 'in', user.mapped('crm_team_member_ids.crm_team_id.crm_team_member_ids').ids)]</field>
            <field name="groups" eval="[(4, ref('fsm.group_operator'))]"/>
            <field name="model_id" ref="sla.model_sla_ticket"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
        <record id="rule_sla_ticket_manager" model="ir.rule">
            <field name="name">Access only related tickets for managers</field>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('fsm.group_manager'))]"/>
            <field name="model_id" ref="sla.model_sla_ticket"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
    </data>
</odoo>
