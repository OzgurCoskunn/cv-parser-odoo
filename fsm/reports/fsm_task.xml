<?xml version="1.0"?>
<odoo>
    <template id="report_template_task">
		<t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <div t-out="doc.uid" style="padding:2mm 0 0 0;text-align:center" t-options="{'widget': 'barcode', 'quiet': 0, 'symbology': 'auto', 'img_style': 'width:70mm;height:10mm'}"/>
                <div class="o_label_name" style="background-color:transparent;text-align:center;font-family:sans-serif">
                    <span t-out="doc.uid"/>
                </div>
            </t>
		</t>
    </template>

    <record id="report_task" model="ir.actions.report">
        <field name="name">Barcode</field>
        <field name="model">fsm.task</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">fsm.report_template_task</field>
        <field name="report_file">fsm.report_template_task</field>
        <field name="binding_model_id" ref="fsm.model_fsm_task"/>
        <field name="binding_type">report</field>
    </record>
</odoo>
