<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="tree_package" model="ir.ui.view">
    <field name="name">fsm.package.list</field>
    <field name="model">fsm.package</field>
    <field name="arch" type="xml">
        <list string="Packages" editable="top">
            <field name="sequence" widget="handle" invisible="1"/>
            <field name="name"/>
            <field name="code" invisible="1"/>
        </list>
    </field>
    </record>

    <record id="action_package" model="ir.actions.act_window">
    <field name="name">Packages</field>
    <field name="type">ir.actions.act_window</field>
    <field name="res_model">fsm.package</field>
    <field name="view_mode">list</field>
    </record>
</odoo>
