<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="tree_stage" model="ir.ui.view">
    <field name="name">fsm.stage.list</field>
    <field name="model">fsm.stage</field>
    <field name="arch" type="xml">
        <list string="Stages" editable="top">
            <field name="sequence" widget="handle"/>
            <field name="name"/>
            <field name="code"/>
            <field name="description"/>
            <field name="type" widget="radio" options="{'horizontal': True}"/>
        </list>
    </field>
    </record>

    <record id="action_stage" model="ir.actions.act_window">
    <field name="name">Stages</field>
    <field name="type">ir.actions.act_window</field>
    <field name="res_model">fsm.stage</field>
    <field name="view_mode">list</field>
    </record>
</odoo>