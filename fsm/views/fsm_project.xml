<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="list_project" model="ir.ui.view">
    <field name="name">fsm.project.list</field>
    <field name="model">fsm.project</field>
    <field name="arch" type="xml">
        <list string="Projects" sample="1">
            <field name="name" decoration-bf="1"/>
            <field name="create_date"/>
            <field name="partner_id"/>
            <field name="product_ids" widget="many2many_tags"/>
            <field name="spare_ids"/>
            <field name="type_ids" widget="many2many_tags"/>
            <field name="state" widget="badge" decoration-success="state == 'confirm'"/>
            <field name="company_id" invisible="1"/>
        </list>
    </field>
    </record>

    <record id="list_project_item" model="ir.ui.view">
    <field name="name">fsm.project.item.list</field>
    <field name="model">fsm.project.item</field>
    <field name="arch" type="xml">
        <list string="Project Follow-Ups" sample="1">
            <field name="name" decoration-bf="1"/>
            <field name="create_date"/>
            <field name="partner_id"/>
            <field name="company_id" invisible="1"/>
        </list>
    </field>
    </record>
 
    <record id="form_project" model="ir.ui.view">
    <field name="name">fsm.project.form</field>
    <field name="model">fsm.project</field>
    <field name="arch" type="xml">
        <form string="Projects">
            <header>
                <button name="action_confirm" type="object" class="btn-primary" string="Confirm" invisible="state != 'draft'"/>
                <button name="action_task" type="object" class="btn-primary" string="Create Task" invisible="state == 'draft'"/>
                <button name="action_draft" type="object" class="btn-secondary" string="Set to Draft" invisible="state == 'draft'"/>
                <field name="state" widget="statusbar" statusbar_visible="draft,confirm"/>
            </header>
            <sheet>
                <div class="oe_button_box" name="button_box">
                    <button name="action_view_tasks" type="object" class="oe_stat_button" icon="fa-suitcase" invisible="id == False">
                        <div class="o_field_widget o_stat_info">
                            <span class="o_stat_value">
                                <field name="task_count" widget="statinfo" nolabel="1"/>
                            </span>
                            <span class="o_stat_text">Tasks</span>
                        </div>
                    </button>
                    <button name="action_view_items" type="object" class="oe_stat_button" icon="fa-tasks" invisible="id == False">
                        <div class="o_field_widget o_stat_info">
                            <span class="o_stat_value">
                                <field name="item_count" widget="statinfo" nolabel="1"/>
                            </span>
                            <span class="o_stat_text">Follow-Ups</span>
                        </div>
                    </button>
                    <button name="action_view_flows" type="object" class="oe_stat_button" icon="fa-random" invisible="id == False">
                        <div class="o_field_widget o_stat_info">
                            <span class="o_stat_value">
                                <field name="flow_count" widget="statinfo" nolabel="1"/>
                            </span>
                            <span class="o_stat_text">Flows</span>
                        </div>
                    </button>
                </div>
                <div class="oe_title">
                    <label for="name"/>
                    <h1><field name="name" class="oe_inline" readonly="state != 'draft'"/></h1>
                    <h5><field name="code" class="oe_inline text-muted mt-n3" placeholder="Project Code"/></h5>
                    <h3 class="text-muted">#<field name="uid" class="oe_inline text-muted mt-n3" invisible="uid == False"/></h3>
                </div>
                <group>
                    <group>
                        <separator string="Partners" colspan="2"/>
                        <field name="partner_id" options="{'no_create': True}" readonly="state != 'draft'"/>
                        <field name="sla_ids" widget="many2many_tags" options="{'no_create': True}" readonly="state != 'draft'"/>
                        <field name="subpartner_ids" class="o_fsm_project_list_headless" readonly="state != 'draft'"/>
                        <separator string="Users" colspan="2"/>
                        <field name="team_ids" widget="many2many_tags" options="{'no_create': True}" readonly="state != 'draft'"/>
                        <field name="user_ids" widget="many2many_tags" options="{'no_create': True}" readonly="state != 'draft'"/>
                        <separator string="Products" colspan="2"/>
                        <field name="warehouse_ids" widget="many2many_tags" options="{'no_create': True}" readonly="state != 'draft'"/>
                        <field name="product_ids" widget="many2many_tags" options="{'no_create': True}" readonly="state != 'draft'"/>
                        <field name="spare_ids" options="{'no_create': True}" class="o_fsm_project_list_headless" readonly="state != 'draft'">
                            <list>
                                <field name="display_name" string="Name"/>
                            </list>
                        </field>
                    </group>
                    <group>
                        <separator string="Types" colspan="2"/>
                        <field name="type_ids" nolabel="1" colspan="2" class="o_fsm_project_list_headless" readonly="state != 'draft'"/>
                        <!--<field name="type_ids" nolabel="1" colspan="2" widget="many2many_checkboxes" options="{'no_create': True, 'no_open': True}" readonly="state != 'draft'"/>-->
                        <separator string="Stages" colspan="2"/>
                        <field name="stage_ids" nolabel="1" colspan="2" widget="many2many_checkboxes" options="{'no_create': True, 'no_open': True}" readonly="state != 'draft'"/>
                        <separator string="Appointments" colspan="2"/>
                        <field name="appointment_date_ok" widget="boolean_toggle" string="Restrict Date" readonly="state != 'draft'"/>
                        <br invisible="appointment_date_ok == False"/>
                        <div class="fst-italic" invisible="appointment_date_ok == False">
                            <span>Do not create appointment after </span>
                            <field name="appointment_date_value" nolabel="1" class="oe_inline text-end ml4 mr4" readonly="state != 'draft'" required="appointment_date_ok != False"/>
                            <field name="appointment_date_period" nolabel="1" class="oe_inline ml4 mr4" readonly="state != 'draft'" required="appointment_date_ok != False"/>
                            <span> from today</span>
                        </div>
                    </group>
                </group>
                <group>
                    <group>
                        <separator string="Other" colspan="2"/>
                        <field name="sequence_id" options="{'no_quick_create': True, 'no_open': True}" readonly="state != 'draft'"/>
                    </group>
                </group>
            </sheet>
            <chatter/>
        </form>
    </field>
    </record>
 
    <record id="form_project_item" model="ir.ui.view">
    <field name="name">fsm.project.item.form</field>
    <field name="model">fsm.project.item</field>
    <field name="arch" type="xml">
        <form string="Project Follow-Up">
            <header>
                <button name="action_confirm" type="object" class="btn-primary" string="Confirm" invisible="state != 'draft'"/>
                <button name="action_task" type="object" class="btn-primary" string="Create Task" invisible="state == 'draft'"/>
                <button name="action_draft" type="object" class="btn-secondary" string="Set to Draft" invisible="state == 'draft'"/>
                <field name="state" widget="statusbar" statusbar_visible="draft,confirm"/>
            </header>
            <sheet>
                <div class="oe_button_box" name="button_box">
                    <button name="action_view_tasks" type="object" class="oe_stat_button" icon="fa-suitcase" invisible="id == False">
                        <div class="o_field_widget o_stat_info">
                            <span class="o_stat_value">
                                <field name="task_count" widget="statinfo" nolabel="1"/>
                            </span>
                            <span class="o_stat_text">Tasks</span>
                        </div>
                    </button>
                </div>
                <div class="oe_title">
                    <label for="name"/>
                    <h1><field name="name" class="oe_inline" readonly="state != 'draft'"/></h1>
                    <h3 class="text-muted">#<field name="uid" class="oe_inline" invisible="uid == False"/></h3>
                </div>
                <group>
                    <group>
                        <separator string="Partner" colspan="2"/>
                        <field name="partner_id" options="{'no_create': True}"/>
                        <field name="sla_id" options="{'no_create': True}" readonly="state != 'draft'"/>
                    </group>
                    <group>
                        <separator string="Options" colspan="2"/>
                        <field name="date_start" readonly="state != 'draft'"/>
                        <field name="date_end" readonly="state != 'draft'"/>
                        <field name="task_maximum" readonly="state != 'draft'"/>
                    </group>
                </group>
                <field name="project_id" invisible="1"/>
            </sheet>
            <chatter/>
        </form>
    </field>
    </record>

    <record id="list_project_type" model="ir.ui.view">
    <field name="name">fsm.project.type.list</field>
    <field name="model">fsm.project.type</field>
    <field name="arch" type="xml">
        <list string="Project Types" editable="bottom" sample="1">
            <field name="sequence" widget="handle"/>
            <field name="type_id" decoration-bf="1" options="{'no_create': True, 'no_open': True}" placeholder="Type"/>
            <field name="subtype_ids" widget="many2many_tags" options="{'no_create': True, 'no_open': True}" placeholder="Subtypes"/>
        </list>
    </field>
    </record>
 
    <record id="form_project_type" model="ir.ui.view">
    <field name="name">fsm.project.type.form</field>
    <field name="model">fsm.project.type</field>
    <field name="arch" type="xml">
        <form string="Project Types">
            <sheet>
                <group>
                    <group>
                        <field name="type_id" options="{'no_create': True, 'no_open': True}"/>
                    </group>
                    <group>
                        <field name="subtype_ids" widget="many2many_tags" options="{'no_create': True, 'no_open': True}"/>
                    </group>
                </group>
            </sheet>
        </form>
    </field>
    </record>

    <record id="list_project_subpartner" model="ir.ui.view">
    <field name="name">fsm.project.subpartner.list</field>
    <field name="model">fsm.project.subpartner</field>
    <field name="arch" type="xml">
        <list string="Project Subpartners" editable="bottom" sample="1">
            <field name="sequence" widget="handle"/>
            <field name="partner_id" decoration-bf="1" options="{'no_create': True, 'no_open': True}" placeholder="Subpartner"/>
            <field name="location_ids" widget="many2many_tags" options="{'no_create': True, 'no_open': True}" placeholder="Locations"/>
        </list>
    </field>
    </record>
 
    <record id="form_project_subpartner" model="ir.ui.view">
    <field name="name">fsm.project.subpartner.form</field>
    <field name="model">fsm.project.subpartner</field>
    <field name="arch" type="xml">
        <form string="Project Subpartners">
            <sheet>
                <group>
                    <group>
                        <field name="partner_id" options="{'no_create': True, 'no_open': True}"/>
                    </group>
                    <group>
                        <field name="location_ids" widget="many2many_tags" options="{'no_create': True, 'no_open': True}"/>
                    </group>
                </group>
            </sheet>
        </form>
    </field>
    </record>

    <record id="action_project" model="ir.actions.act_window">
    <field name="name">Projects</field>
    <field name="type">ir.actions.act_window</field>
    <field name="res_model">fsm.project</field>
    <field name="view_mode">list,form</field>
    <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
            No projects yet
        </p>
        <p>
            Create projects and track their tasks efficiently
        </p>
    </field>
    </record>

    <record id="action_project_item" model="ir.actions.act_window">
    <field name="name">Project Follow-Ups</field>
    <field name="type">ir.actions.act_window</field>
    <field name="res_model">fsm.project.item</field>
    <field name="view_mode">list,form</field>
    <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
            No project follow-up yet
        </p>
        <p>
            Create project follow-ups and track their tasks efficiently
        </p>
    </field>
    </record>
</odoo>