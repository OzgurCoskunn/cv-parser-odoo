<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="tree_reason" model="ir.ui.view">
    <field name="name">fsm.reason.list</field>
    <field name="model">fsm.reason</field>
    <field name="arch" type="xml">
        <list string="Reasons" editable="top">
            <field name="sequence" widget="handle"/>
            <field name="name"/>
            <field name="code"/>
            <field name="status"/>
            <field name="description" widget="boolean_toggle"/>
            <field name="project_ids" widget="many2many_tags" options="{'no_create': True, 'no_open': True}"/>
            <field name="company_id" invisible="1"/>
        </list>
    </field>
    </record>

    <record id="action_reason" model="ir.actions.act_window">
    <field name="name">Reasons</field>
    <field name="type">ir.actions.act_window</field>
    <field name="res_model">fsm.reason</field>
    <field name="view_mode">list</field>
    </record>
</odoo>