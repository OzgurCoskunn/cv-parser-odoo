<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="form_stock_location" model="ir.ui.view">
    <field name="model">stock.location</field>
    <field name="inherit_id" ref="stock.view_location_form"/>
    <field name="arch" type="xml">
        <xpath expr="//group[@name='additional_info']" position="inside">
            <separator string="Address"/>
            <field name="fsm_country_id" options="{'no_create': True}" string="Country"/>
            <field name="fsm_state_id" options="{'no_create': True}" string="State/City"/>
            <field name="fsm_town_id" options="{'no_create': True}" string="Town"/>
            <field name="fsm_user_id" options="{'no_create': True}" widget="many2one_avatar_user" string="User"/>
            <field name="fsm_users_id" options="{'no_create': True}" widget="many2many_avatar_user" string="Users"/>
            <field name="fsm_user_type" options="{'horizontal': True}" widget="radio" string="Type"/>
            <newline/>
        </xpath>
    </field>
    </record>
</odoo>