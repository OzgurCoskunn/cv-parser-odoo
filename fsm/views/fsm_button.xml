<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="tree_button" model="ir.ui.view">
    <field name="name">fsm.button.list</field>
    <field name="model">fsm.button</field>
    <field name="arch" type="xml">
        <list string="Buttons">
            <field name="sequence" widget="handle"/>
            <field name="name" decoration-bf="1"/>
            <field name="action_ids" widget="many2many_tags"/>
            <field name="description" decoration-it="1"/>
        </list>
    </field>
    </record>

    <record id="form_button" model="ir.ui.view">
    <field name="name">fsm.button.form</field>
    <field name="model">fsm.button</field>
    <field name="arch" type="xml">
        <form string="Buttons">
            <sheet>
                <div class="oe_title">
                    <label for="name"/>
                    <h1><field name="name" class="oe_inline"/></h1>
                </div>
                <notebook>
                    <page name="action" string="Actions">
                        <field name="action_ids" mode="kanban"/>
                    </page>
                    <page name="condition" string="Condition">
                        <group>
                            <label for="visible_ok" string="Always Visible"/>
                            <div>
                                <field name="visible_ok"  class="oe_inline" nolabel="1" widget="boolean_toggle"/>
                            </div>
                        </group>
                        <field name="visible_code" widget="ace" options="{'mode': 'python'}" placeholder="Enter python code here." invisible="visible_ok != False"/>
                        <div style="margin-top: 16px;" invisible="visible_ok != False">
                            <h3>Help with Python expressions</h3>
                            <p>Various fields may use Python code or Python expressions. The following variables can be used:</p>
                            <ul>
                                <li><code>env</code>: Odoo Environment on which the action is triggered</li>
                                <li><code>tasks</code>: tasks on which the action is triggered</li>
                                <li><code>time</code>, <code>datetime</code>, <code>dateutil</code>, <code>timezone</code>: useful Python libraries</li>
                                <li>To specify visibility, assign: <code>visible = &lt;boolean&gt;</code></li>
                            </ul>
                        </div>
                    </page>
                    <page name="custom" string="Customization">
                        <group>
                            <group>
                                <field name="custom_theme" widget="radio"/>
                            </group>
                            <group>
                                <field name="custom_class" placeholder="btn-primary btn-lg"/>
                                <field name="custom_style" placeholder="{ font-size: 2em; }"/>
                            </group>
                        </group>
                    </page>
                    <page name="group" string="Groups">
                        <field name="group_ids"/>
                    </page>
                    <page name="desc" string="Description">
                        <field name="description"/>
                    </page>
                </notebook>
            </sheet>
        </form>
    </field>
    </record>

    <record id="kanban_button_action" model="ir.ui.view">
    <field name="name">fsm.button.action.kanban</field>
    <field name="model">fsm.button.action</field>
    <field name="arch" type="xml">
        <kanban>
            <field name="name"/>
            <field name="type"/>
            <field name="code"/>
            <field name="stage_id"/>
            <field name="stage_type"/>
            <field name="action_id"/>
            <field name="display_name"/>
            <field name="picking_location_id"/>
            <field name="picking_location_dest_id"/>
            <field name="sequence" widget="handle"/>
            <templates>
                <t t-name="card">
                    <div class="oe_kanban_card oe_kanban_global_click overflow-hidden p-0 rounded-2">
                        <div class="oe_kanban_content">
                            <div class="o_kanban_record_top bg-100 border-4 border-primary border-start mx-4 my-3 p-2 rounded-2 shadow-sm text-center">
                                <div class="o_kanban_record_headings">
                                    <div class="o_kanban_record_title d-flex flex-column">
                                        <field name="type" class="h3 text-700"/>
                                        <span class="mt-n2 small text-500">Type</span>
                                    </div>
                                </div>
                            </div>
                            <div class="o_kanban_record_body px-4 text-truncate">
                                <t t-if="record.type?.raw_value === 'code'">
                                    <code t-esc="record.code.raw_value and record.code.raw_value.split('\n', 1)[0] or '# No Code'"/>
                                </t>
                                <t t-elif="record.type?.raw_value === 'stage'">
                                    <div class="h5 d-block text-600 text-center">
                                        <i t-if="record.stage_type?.raw_value === '2'" class="fa fa-flag-checkered mx-3"/>
                                        <i t-else="" class="fa fa-flag mx-3"/>
                                        <span t-esc="record.stage_id?.value"/>
                                    </div>
                                </t>
                                <t t-elif="record.type?.raw_value === 'picking'">
                                    <div class="h5 d-block text-600 text-center">
                                        <span t-esc="record.picking_location_id?.value or ''"/>
                                        <i class="fa fa-truck fa-flip-horizontal mx-3"/>
                                        <span t-esc="record.picking_location_dest_id?.value or ''"/>
                                    </div>
                                </t>
                                <t t-elif="record.type?.raw_value === 'action'">
                                    <div class="h5 d-block text-600 text-center">
                                        <t t-if="record.action_id?.raw_value?.resModel === 'ir.actions.report'">
                                            <span>Report</span>
                                            <i class="fa fa-file-text mx-3"/>
                                            <span t-esc="record.action_id?.value"/>
                                        </t>
                                        <t t-elif="record.action_id?.raw_value?.resModel === 'ir.actions.server'">
                                            <span>Server</span>
                                            <i class="fa fa-server mx-3"/>
                                            <span t-esc="record.action_id?.value"/>
                                        </t>
                                        <t t-elif="record.action_id?.raw_value?.resModel === 'ir.actions.client'">
                                            <span>Client</span>
                                            <i class="fa fa-user mx-3"/>
                                            <span t-esc="record.action_id?.value"/>
                                        </t>
                                        <t t-elif="record.action_id?.raw_value?.resModel === 'ir.actions.act_url'">
                                            <span>Address</span>
                                            <i class="fa fa-code mx-3"/>
                                            <span t-esc="record.action_id?.value"/>
                                        </t>
                                        <t t-elif="record.action_id?.raw_value?.resModel === 'ir.actions.act_window'">
                                            <span>Window</span>
                                            <i class="fa fa-window-restore mx-3"/>
                                            <span t-esc="record.action_id?.value"/>
                                        </t>
                                    </div>
                                </t>
                            </div>
                            <div class="o_kanban_record_bottom"/>
                        </div>
                        <div class="clearfix"/>
                    </div>
                </t>
            </templates>
        </kanban>
    </field>
    </record>

    <record id="tree_button_action" model="ir.ui.view">
    <field name="name">fsm.button.action.list</field>
    <field name="model">fsm.button.action</field>
    <field name="arch" type="xml">
        <list>
            <field name="sequence" widget="handle"/>
            <field name="name" decoration-bf="1"/>
            <field name="type" widget="badge"/>
        </list>
    </field>
    </record>

    <record id="form_button_action" model="ir.ui.view">
    <field name="name">fsm.button.action.form</field>
    <field name="model">fsm.button.action</field>
    <field name="arch" type="xml">
        <form>
            <sheet>
                <group>
                    <group>
                        <field name="type" widget="radio"/>
                        <field name="name" invisible="1"/>
                    </group>
                    <group>
                        <field name="stage_id" string="Stage" options="{'no_create': True, 'no_open': True}" required="type == 'stage'" invisible="1"/>
                        <field name="flow_stage_id" string="Stage" options="{'no_create': True, 'no_open': True}" invisible="type != 'stage'" required="type == 'stage'"/>
                        <field name="flow_stage_ids" invisible="1"/>
                        <field name="reason_id" string="Reason" options="{'no_create': True, 'no_open': True}" invisible="type != 'stage'"/>
                        <field name="reason_desc" invisible="1"/>
                        <field name="stage_success" string="Success" widget="boolean_toggle" invisible="(type != 'stage' or stage_type != '2')"/>
                        <field name="stage_type" invisible="1"/>
                        <field name="picking_type_id" string="Type" options="{'no_create': True, 'no_open': True}" invisible="type != 'picking'" required="type == 'picking'"/>
                        <field name="picking_location_id" string="Location" options="{'no_create': True, 'no_open': True}" invisible="type != 'picking'"/>
                        <field name="picking_location_dest_id" string="Destination" options="{'no_create': True, 'no_open': True}" invisible="type != 'picking'"/>
                        <field name="picking_product_id" string="Product" options="{'no_create': True, 'no_open': True}" invisible="type != 'picking'"/>
                        <label for="picking_carrier_ok" string="Send with Carrier" invisible="type != 'picking'"/>
                        <div class="d-flex" invisible="type != 'picking'">
                            <field name="picking_carrier_ok" nolabel="1" class="oe_inline"  widget="boolean_toggle"/>
                            <field name="picking_carrier_id" placeholder="Carrier..." options="{'no_create': True, 'no_open': True}" invisible="picking_carrier_ok == False"/>
                        </div>
                        <field name="picking_carrier_type" invisible="1"/>
                        <field name="picking_return_ok" string="Mark as Return" widget="boolean_toggle" invisible="type != 'picking'"/>
                        <field name="picking_done" string="Mark as Done" widget="boolean_toggle" invisible="type != 'picking'"/>
                        <field name="picking_type_company_id" invisible="1"/>
                        <field name="action_id" string="Action" invisible="type != 'action'" required="type == 'action'" context="{'model': 'fsm.task'}"/>
                    </group>
                </group>
                <notebook>
                    <page name="code" string="Code" invisible="type != 'code'">
                        <field name="code" widget="ace" options="{'mode': 'python'}" placeholder="Enter python code here. You can take a look at Help tab for available expressions."/>
                    </page>
                    <page name="help" string="Help" invisible="type != 'code'">
                        <div style="margin-top: 4px;">
                            <h3>Help with Python expressions</h3>
                            <p>Various fields may use Python code or Python expressions. The following variables can be used:</p>
                            <ul>
                                <li><code>env</code>: Odoo Environment on which the action is triggered</li>
                                <li><code>tasks</code>: tasks on which the action is triggered</li>
                                <li><code>time</code>, <code>datetime</code>, <code>dateutil</code>, <code>timezone</code>: useful Python libraries</li>
                                <li><code>UserError</code>: Warning Exception to use with <code>raise</code></li>
                                <li><code>Command</code>: x2Many commands namespace</li>
                                <li>To return an action, assign: <code>action = {...}</code></li>
                            </ul>
                        </div>
                    </page>
                </notebook>
            </sheet>
        </form>
    </field>
    </record>

    <record id="action_button" model="ir.actions.act_window">
    <field name="name">Buttons</field>
    <field name="type">ir.actions.act_window</field>
    <field name="res_model">fsm.button</field>
    <field name="view_mode">list,form</field>
    </record>
</odoo>