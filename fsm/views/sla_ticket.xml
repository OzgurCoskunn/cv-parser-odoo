<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="form_ticket" model="ir.ui.view">
    <field name="model">sla.ticket</field>
    <field name="inherit_id" ref="sla.form_ticket"/>
    <field name="arch" type="xml">
        <xpath expr="//div[@name='button_box']" position="inside">
            <button name="action_view_task" type="object" class="oe_stat_button" icon="fa-suitcase" invisible="fsm_task_id == False">
                <div class="o_field_widget o_stat_info">
                    <span class="o_stat_value">1</span>
                    <span class="o_stat_text">Task</span>
                </div>
            </button>
            <field name="fsm_task_id" invisible="1"/>
        </xpath>
    </field>
    </record>
</odoo>