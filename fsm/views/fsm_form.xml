<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="tree_form" model="ir.ui.view">
    <field name="name">fsm.form.list</field>
    <field name="model">fsm.form</field>
    <field name="arch" type="xml">
        <list decoration-muted="active == False">
            <field name="sequence" widget="handle"/>
            <field name="name" decoration-bf="1"/>
            <field name="version"/>
            <field name="active" widget="boolean_toggle"/>
        </list>
    </field>
    </record>

    <record id="form_form" model="ir.ui.view">
    <field name="name">fsm.form.form</field>
    <field name="model">fsm.form</field>
    <field name="arch" type="xml">
        <form class="o_form_fsm_form">
            <sheet>
                <div class="row ml4 mr4">
                    <div class="col-md-8">
                        <field name="body" colspan="2" nolabel="1" options="{'codeview': true}"/>
                    </div>
                    <div class="col-md-4 shadow-sm table-bordered" style="position: sticky; top: 20px; border-radius: 10px;">
                        <separator string="Name"/>
                        <div class="d-flex justify-content-between">
                            <div>
                                <field name="name" placeholder="Enter a form name..."/>
                            </div>
                            <div>
                                <span class="fst-italic mr8">Active</span>
                                <field name="active" string="Published" widget="boolean_toggle"/>
                            </div>
                        </div>
                        <separator string="Company" groups="base.group_multi_company,base.group_system"/>
                        <field name="company_id" colspan="2" nolabel="1" options="{'no_create': True, 'no_open': True}" groups="base.group_multi_company,base.group_system"/>
                        <separator string="Code"/>
                        <field name="code" colspan="2" nolabel="1" placeholder="STANDARD"/>
                        <separator string="Version"/>
                        <field name="version" colspan="2" nolabel="1" placeholder="1.0"/>
                        <!--<separator string="Help" class="mt16"/>
                        <div colspan="2">
                            <p class="mt16 mb4">Available variables;</p>
                            <ul class="list-inline">
                                <li><code>{{var}}</code>: Table of variables</li>
                            </ul>
                        </div>-->
                    </div>
                </div>
            </sheet>
        </form>
    </field>
    </record>

    <record id="action_form" model="ir.actions.act_window">
    <field name="name">Forms</field>
    <field name="type">ir.actions.act_window</field>
    <field name="res_model">fsm.form</field>
    <field name="view_mode">list,form</field>
    <field name="context">{'active_test': False}</field>
    <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
            No forms yet
        </p>
        <p>
            Create a form then use them in tasks
        </p>
    </field>
    </record>
</odoo>