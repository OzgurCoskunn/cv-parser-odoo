<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="form_product_template" model="ir.ui.view">
    <field name="model">product.template</field>
    <field name="inherit_id" ref="product.product_template_form_view"/>
    <field name="arch" type="xml">
        <xpath expr="//page[@name='inventory']" position="before">
            <page name="fsm" string="Field Service">
                <group>
                    <group string="Settings">
                        <field name="fsm_ok"/>
                        <field name="fsm_os" invisible="fsm_ok == False"/>
                        <field name="fsm_product_type" invisible="fsm_ok == False"/>
                    </group>
                    <group string="Owners">
                        <field name="fsm_partner_id" options="{'no_create': True}" string="Owner"/>
                        <field name="fsm_subpartner_id" options="{'no_create': True}" string="Subpartner"/>
                        <field name="fsm_subpartner_ids" invisible="1"/>
                    </group>
                </group>
            </page>
        </xpath>
    </field>
    </record>

    <record id="action_product_template" model="ir.actions.act_window">
    <field name="name">Products</field>
    <field name="type">ir.actions.act_window</field>
    <field name="res_model">product.template</field>
    <field name="domain">[('fsm_ok', '=', True)]</field>
    <field name="context">{'default_fsm_ok': True}</field>
    <field name="view_mode">kanban,list,form</field>
    </record>
</odoo>