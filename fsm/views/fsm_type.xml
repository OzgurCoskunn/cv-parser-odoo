<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="tree_type" model="ir.ui.view">
    <field name="name">fsm.type.list</field>
    <field name="model">fsm.type</field>
    <field name="arch" type="xml">
        <list string="Types" editable="top">
            <field name="sequence" widget="handle"/>
            <field name="name"/>
            <field name="code"/>
            <field name="description"/>
        </list>
    </field>
    </record>

    <record id="action_type" model="ir.actions.act_window">
    <field name="name">Types</field>
    <field name="type">ir.actions.act_window</field>
    <field name="res_model">fsm.type</field>
    <field name="view_mode">list</field>
    </record>
</odoo>