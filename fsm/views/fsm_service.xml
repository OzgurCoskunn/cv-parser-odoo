<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="tree_service_zone" model="ir.ui.view">
    <field name="name">fsm.service.zone.list</field>
    <field name="model">fsm.service.zone</field>
    <field name="arch" type="xml">
        <list string="Service Zones" editable="top" sample="1">
            <field name="state_id" options="{'no_create': True}" domain="[('country_id.code', '=', 'TR')]"/>
            <field name="town_id" options="{'no_create': True}" domain="[('state_id', '=', state_id)]"/>
            <field name="type_id" options="{'no_create': True}"/>
            <field name="location_id" options="{'no_create': True}" required="1"/>
            <field name="team_ids" widget="many2many_tags" options="{'no_create': True}" required="1"/>
            <field name="sla_id" options="{'no_create': True}" optional="hide" invisible="context.get('default_sla_id')"/>
            <field name="value" widget="float_time"/>
        </list>
    </field>
    </record>

    <record id="form_service_zone" model="ir.ui.view">
    <field name="name">fsm.service.zone.form</field>
    <field name="model">fsm.service.zone</field>
    <field name="arch" type="xml">
        <form string="Service Zone">
            <sheet>
                <group>
                    <group>
                        <field name="name"/>
                    </group>
                    <group>
                        <field name="value" widget="float_time"/>
                    </group>
                </group>
            </sheet>
        </form>
    </field>
    </record>

    <record id="tree_service_type" model="ir.ui.view">
    <field name="name">fsm.service.type.list</field>
    <field name="model">fsm.service.type</field>
    <field name="arch" type="xml">
        <list string="Service Types" editable="top">
            <field name="sequence" widget="handle"/>
            <field name="name"/>
            <field name="code"/>
        </list>
    </field>
    </record>

    <record id="action_service_zone" model="ir.actions.act_window">
    <field name="name">Service Zones</field>
    <field name="type">ir.actions.act_window</field>
    <field name="res_model">fsm.service.zone</field>
    <field name="context">{'group_by': ['sla_id']}</field>
    <field name="view_mode">list</field>
    </record>

    <record id="action_service_type" model="ir.actions.act_window">
    <field name="name">Service Types</field>
    <field name="type">ir.actions.act_window</field>
    <field name="res_model">fsm.service.type</field>
    <field name="view_mode">list</field>
    </record>
</odoo>