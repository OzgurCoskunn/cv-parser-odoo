<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="partner_category_fsm" model="res.partner.category">
            <field name="name">Field Service</field>
            <field name="color">5</field>
            <field name="active" eval="True"/>
        </record>
    </data>

    <data>
        <record id="cron_auto" model="ir.cron">
            <field name="name">Field Service Management: Automation Cron</field>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="nextcall" eval="(DateTime.now().replace(second=0) + timedelta(minutes=1)).strftime('%Y-%m-%d %H:%M:%S')" />
            <field name="model_id" ref="model_fsm_auto"/>
            <field name="code">model.run_cron()</field>
            <field name="state">code</field>
        </record>
    </data>
</odoo>