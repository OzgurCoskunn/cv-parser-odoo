<?xml version="1.0" encoding="utf-8"?>
<odoo> 
    <record id="form_project_confirm" model="ir.ui.view">
    <field name="name">fsm.project.confirm.form</field>
    <field name="model">fsm.project.confirm</field>
    <field name="arch" type="xml">
        <form string="Confirm Project">
            <sheet>
                <group>
                    <group>
                        <p class="h4 text-center" colspan="2">
                            Please specify which stages will be used within this project.
                        </p>
                    </group>
                    <group>
                        <field name="stage_ids" widget="many2many_checkboxes" options="{'no_create': True, 'no_open': True}"/>
                        <field name="project_id" invisible="1"/>
                    </group>
                </group>
            </sheet>
            <footer>
                <!--<button name="action_confirm" type="object" class="btn-primary" string="Confirm"/>-->
                <button name="action_cancel" special="cancel" class="btn-secondary" string="Cancel"/>
            </footer>
        </form>
    </field>
    </record>

    <record id="action_project_confirm" model="ir.actions.act_window">
    <field name="name">Confirm Project</field>
    <field name="type">ir.actions.act_window</field>
    <field name="res_model">fsm.project.confirm</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
    </record>
</odoo>