<?xml version="1.0" encoding="utf-8"?>
<odoo> 
    <record id="form_task_user_assign" model="ir.ui.view">
    <field name="name">fsm.task.user.assign.form</field>
    <field name="model">fsm.task.user.assign</field>
    <field name="arch" type="xml">
        <form>
            <sheet>
                <group invisible="task_one == False">
                    <group>
                        <p class="h3 mx-5 text-600 text-center" colspan="2">
                            Please select a user to assign.
                        </p>
                    </group>
                    <group>
                        <field name="user_id" string="Technician" options="{'no_create': True, 'no_open': True}" widget="many2one_avatar_user"/>
                        <field name="user_ids" invisible="1"/>
                    </group>
                </group>
                <group invisible="task_one != False">
                    <group>
                        <p class="h3 mx-5 my-2 text-600 text-center" colspan="2">
                            Please select a user per task to assign.
                        </p>
                    </group>
                    <group>
                        <field name="line_ids" nolabel="1" colspan="2">
                            <list editable="bottom" create="0" delete="0">
                                <field name="task_id" string="Task" options="{'no_create': True, 'no_open': True}" optional="hide" force_save="1"/>
                                <field name="service_zone_id" string="Zone" options="{'no_create': True, 'no_open': True}" optional="show"/>
                                <field name="user_id" string="Technician" options="{'no_create': True, 'no_open': True}" widget="many2one_avatar_user"/>
                                <field name="user_ids" invisible="1"/>
                            </list>
                            <form create="0" delete="0">
                                <sheet>
                                    <group>
                                        <field name="task_id" string="Task" options="{'no_create': True, 'no_open': True}" force_save="1"/>
                                        <field name="service_zone_id" string="Zone" options="{'no_create': True, 'no_open': True}"/>
                                        <field name="user_id" string="Technician" options="{'no_create': True, 'no_open': True}" widget="many2one_avatar_user"/>
                                        <field name="user_ids" invisible="1"/>
                                    </group>
                                </sheet>
                            </form>
                        </field>
                    </group>
                </group>
                <field name="task_one" invisible="1"/>
                <field name="task_ids" invisible="1"/>
                <field name="button_action_id" invisible="1"/>
            </sheet>
            <footer>
                <button name="confirm" type="object" class="btn-primary" string="Confirm"/>
                <button name="cancel" special="cancel" class="btn-secondary" string="Cancel"/>
            </footer>
        </form>
    </field>
    </record>

    <record id="action_task_user_assign" model="ir.actions.act_window">
    <field name="name">Assign Technician</field>
    <field name="type">ir.actions.act_window</field>
    <field name="res_model">fsm.task.user.assign</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
    </record>
</odoo>