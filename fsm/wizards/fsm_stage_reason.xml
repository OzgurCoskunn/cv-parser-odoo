<?xml version="1.0" encoding="utf-8"?>
<odoo> 
    <record id="form_stage_reason" model="ir.ui.view">
    <field name="name">fsm.stage.reason.form</field>
    <field name="model">fsm.stage.reason</field>
    <field name="arch" type="xml">
        <form>
            <sheet>
                <group>
                    <group>
                        <p class="h3 mx-5 text-600 text-center" colspan="2" invisible="stage_type == '2'">
                            Please specify a reason for changing stage.
                        </p>
                        <p class="h3 mx-5 text-600 text-center" colspan="2" invisible="stage_type != '2'">
                            Please specify whether task has been successfully closed.
                        </p>
                        <field name="contact_id" string="Contact" invisible="(not task_one or stage_type != '2')" context="{'default_type': 'contact', 'default_parent_id': merchant_id, 'default_is_company': False, 'form_view_ref': 'fsm.form_partner_basic'}"/>
                        <field name="contact_ids" invisible="1"/>
                    </group>
                    <group>
                        <field name="stage_success" string="Successful" widget="boolean_toggle" invisible="stage_type != '2'" readonly="stage_success_readonly == True" force_save="1"/>
                        <field name="reason_id" options="{'no_create': True, 'no_open': True}" invisible="field_reason_id == 0" required="field_reason_id == 2"/>
                        <field name="reason_desc" invisible="field_reason_desc == 0" required="field_reason_desc == 2"/>
                        <field name="reason_desc_ok" invisible="1"/>
                        <field name="reason_ids" invisible="1"/>
                        <field name="task_ids" invisible="1"/>
                        <field name="task_one" invisible="1"/>
                        <field name="merchant_id" invisible="1"/>
                        <field name="stage_id" invisible="1"/>
                        <field name="stage_type" invisible="1"/>
                        <field name="stage_success_readonly" invisible="1"/>
                        <field name="field_reason_id" invisible="1"/>
                        <field name="field_reason_desc" invisible="1"/>
                        <field name="button_action_id" invisible="1"/>
                    </group>
                </group>
            </sheet>
            <footer>
                <button name="confirm" type="object" class="btn-primary" string="Confirm"/>
                <button name="cancel" special="cancel" class="btn-secondary" string="Cancel"/>
            </footer>
        </form>
    </field>
    </record>

    <record id="action_stage_reason" model="ir.actions.act_window">
    <field name="name">Stage Reason</field>
    <field name="type">ir.actions.act_window</field>
    <field name="res_model">fsm.stage.reason</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
    </record>
</odoo>