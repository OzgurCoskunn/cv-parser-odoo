<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="form_task_import" model="ir.ui.view">
    <field name="name">fsm.task.import.form</field>
    <field name="model">fsm.task.import</field>
    <field name="arch" type="xml">
        <form>
            <group>
                <group>
                    <p class="h4 my-5 text-700 text-center" colspan="2">Please upload a task list</p>
                    <field name="file" filename="filename" colspan="2" nolabel="1" class="d-flex justify-content-center my-3 px-5"/>
                    <field name="filename" invisible="1" colspan="2" nolabel="1"/>
                </group>
                <group>
                    <field name="line_ids" readonly="1" colspan="2" nolabel="1" force_save="1">
                        <list create="0" edit="0" delete="0">
                            <field name="project_id" force_save="1"/>
                            <field name="type_id" force_save="1"/>
                            <field name="sla_id" force_save="1"/>
                            <field name="setup_key" force_save="1" optional="hide"/>
                            <field name="setup_uid" force_save="1" optional="hide"/>
                            <field name="setup_merchant_uid" force_save="1" optional="hide"/>
                            <field name="merchant_id" force_save="1"/>
                            <field name="product_id" force_save="1"/>
                            <field name="product_lot_id" force_save="1" optional="hide"/>
                            <field name="product_lot_ref" force_save="1" optional="hide"/>
                            <field name="company_id" invisible="1" force_save="1"/>
                        </list>
                        <form>
                            <sheet>
                                <group>
                                    <group>
                                        <field name="project_id" force_save="1"/>
                                        <field name="type_id" force_save="1"/>
                                        <field name="sla_id" force_save="1"/>
                                        <field name="setup_key" force_save="1"/>
                                        <field name="setup_uid" force_save="1"/>
                                        <field name="setup_merchant_uid" force_save="1"/>
                                    </group>
                                    <group>
                                        <field name="merchant_id" force_save="1"/>
                                        <field name="product_id" force_save="1"/>
                                        <field name="product_lot_id" force_save="1"/>
                                        <field name="product_lot_ref" force_save="1"/>
                                        <field name="company_id" invisible="1" force_save="1"/>
                                    </group>
                                </group>
                            </sheet>
                            <footer style="display: none;"/>
                        </form>
                    </field>
                </group>
            </group>
            <footer>
                <button name="confirm" type="object" class="btn-primary" string="Import" icon="fa-upload"/>
                <button special="cancel" class="btn-secondary" string="Close" icon="fa-times"/>
            </footer>
        </form>
    </field>
    </record>

    <record id="action_task_import" model="ir.actions.act_window">
    <field name="name">Import Tasks</field>
    <field name="res_model">fsm.task.import</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
    </record>
</odoo>
