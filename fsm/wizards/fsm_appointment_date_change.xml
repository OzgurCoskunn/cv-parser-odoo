<?xml version="1.0" encoding="utf-8"?>
<odoo> 
    <record id="form_appointment_date" model="ir.ui.view">
    <field name="name">fsm.appointment.date.change.form</field>
    <field name="model">fsm.appointment.date.change</field>
    <field name="arch" type="xml">
        <form>
            <sheet>
                <group>
                    <group>
                        <p class="h3 mx-5 text-600 text-center" colspan="2">
                            Please specify a date to be set.
                        </p>
                    </group>
                    <group>
                        <field name="date"/>
                        <field name="appointment_id" invisible="1"/>
                    </group>
                </group>
            </sheet>
            <footer>
                <button name="confirm" type="object" class="btn-primary" string="Confirm"/>
                <button name="cancel" special="cancel" class="btn-secondary" string="Cancel"/>
            </footer>
        </form>
    </field>
    </record>

    <record id="action_appointment_date_change" model="ir.actions.act_window">
    <field name="name">Change Appointment Date</field>
    <field name="type">ir.actions.act_window</field>
    <field name="res_model">fsm.appointment.date.change</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
    </record>
</odoo>