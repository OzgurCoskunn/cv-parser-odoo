<?xml version="1.0" encoding="utf-8"?>
<odoo> 
    <record id="form_task_delivery_select" model="ir.ui.view">
    <field name="name">fsm.task.delivery.select.form</field>
    <field name="model">fsm.task.delivery.select</field>
    <field name="arch" type="xml">
        <form string="Select Delivery Carrier">
            <sheet>
                <group>
                    <group>
                        <p class="h3 mx-5 my-4 text-600 text-center" colspan="2">
                            Please specify which carrier will be used for this action.
                        </p>
                    </group>
                    <group string="Delivery Carriers">
                        <field name="carrier_id" nolabel="1" colspan="2" options="{'no_create': True, 'no_open': True}" widget="radio"/>
                        <field name="carrier_ids" invisible="1"/>
                        <field name="task_ids" invisible="1"/>
                        <field name="button_id" invisible="1"/>
                        <field name="button_action_id" invisible="1"/>
                    </group>
                </group>
            </sheet>
            <footer>
                <button name="confirm" type="object" class="btn-primary" string="Confirm"/>
                <button name="cancel" special="cancel" class="btn-secondary" string="Cancel"/>
            </footer>
        </form>
    </field>
    </record>

    <record id="action_task_delivery_select" model="ir.actions.act_window">
    <field name="name">Select Delivery Carrier</field>
    <field name="type">ir.actions.act_window</field>
    <field name="res_model">fsm.task.delivery.select</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
    </record>
</odoo>