<?xml version="1.0" encoding="utf-8"?>
<odoo> 
    <record id="form_reason_change" model="ir.ui.view">
    <field name="name">fsm.reason.change.form</field>
    <field name="model">fsm.reason.change</field>
    <field name="arch" type="xml">
        <form>
            <sheet>
                <group>
                    <group>
                        <p class="h3 mx-5 text-600 text-center" colspan="2">
                            Please specify a reason.
                        </p>
                    </group>
                    <group>
                        <field name="reason_id" options="{'no_create': True, 'no_open': True}"/>
                        <field name="reason_desc" invisible="not reason_desc_ok"/>
                        <field name="reason_ids" invisible="1"/>
                        <field name="reason_desc_ok" invisible="1"/>
                        <field name="button_action_id" invisible="1"/>
                        <field name="task_ids" invisible="1"/>
                    </group>
                </group>
            </sheet>
            <footer>
                <button name="confirm" type="object" class="btn-primary" string="Confirm"/>
                <button name="cancel" special="cancel" class="btn-secondary" string="Cancel"/>
            </footer>
        </form>
    </field>
    </record>

    <record id="action_reason_change" model="ir.actions.act_window">
    <field name="name">Change Reason</field>
    <field name="type">ir.actions.act_window</field>
    <field name="res_model">fsm.reason.change</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
    </record>
</odoo>