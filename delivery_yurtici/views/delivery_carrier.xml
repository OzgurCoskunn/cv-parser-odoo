<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_delivery_carrier_form" model="ir.ui.view">
        <field name="model">delivery.carrier</field>
        <field name="inherit_id" ref="delivery.view_delivery_carrier_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position='inside'>
                <page string="Yurtiçi Kargo" invisible="delivery_type != 'yurtici'">
                    <group>
                        <group>
                            <field name="delivery_yurtici_connector_id" string="Connector"/>
                            <field name="delivery_yurtici_prod_username"/>
                            <field name="delivery_yurtici_prod_password" password="True"/>
                            <field name="delivery_yurtici_test_username"/>
                            <field name="delivery_yurtici_test_password" password="True"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
