<?xml version="1.0" encoding="UTF-8"?>

<templates xml:space="preserve">
    <t t-name="barcode_wms.EditMove" owl="1">
        <div class="popup">
            <div class="popup-header">
                <div class="popup-back text-700" t-on-click="back">
                    <i class="fa fa-angle-left"/>
                </div>
            </div>
            <div class="popup-body">
                <div class="product-info-container">
                    <div class="bg-light border p-3 shadow-sm">
                        <h1 class="text-secondary">
                            <span t-esc="props.move.product_id.display_name"/>
                        </h1>
                    </div>
                    <div class="d-flex justify-content-between flex-wrap-reverse mt-4">
                        <div class="flex-fill">
                            <div class="d-flex justify-content-center justify-content-md-start">
                                <div class="calculator pb-3 border mt-3">
                                    <div class="d-flex">
                                        <input type="text" class="calculator-screen z-depth-1" t-att-value="state.quantity" disabled="disabled"/>
                                    </div>
                                    <div class="d-flex">
                                        <div class="calculator-buttons">
                                            <button type="button" value="7" class="operator btn btn-primary rounded-0" t-on-click="digitValue">7</button>
                                            <button type="button" value="8" class="operator btn btn-primary rounded-0" t-on-click="digitValue">8</button>
                                            <button type="button" value="9" class="operator btn btn-primary rounded-0" t-on-click="digitValue">9</button>

                                            <button type="button" value="4" class="operator btn btn-primary rounded-0" t-on-click="digitValue">4</button>
                                            <button type="button" value="5" class="operator btn btn-primary rounded-0" t-on-click="digitValue">5</button>
                                            <button type="button" value="6" class="operator btn btn-primary rounded-0" t-on-click="digitValue">6</button>

                                            <button type="button" value="1" class="operator btn btn-primary rounded-0" t-on-click="digitValue">1</button>
                                            <button type="button" value="2" class="operator btn btn-primary rounded-0" t-on-click="digitValue">2</button>
                                            <button type="button" value="3" class="operator btn btn-primary rounded-0" t-on-click="digitValue">3</button>

                                            <button type="button" value="0" class="operator btn btn-primary rounded-0" t-on-click="digitValue">0</button>
                                            <button type="button" class="decimal function btn btn-secondary rounded-0" value="." t-on-click="selectDot">.</button>
                                            <button type="button" class="all-clear function btn btn-danger btn-sm rounded-0" value="clear" t-on-click="clearLastDigit"><i class="fa fa-arrow-left"/></button>
                                        </div>
                                        <div class="calculator-increment">
                                            <button type="button" value="2" class="operator btn btn-primary rounded-0" t-on-click="plusOne">+1</button>
                                            <button type="button" value="3" class="operator btn btn-primary rounded-0" t-on-click="minusOne">-1</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="flex-fill">
                            <div class="d-flex justify-content-center">
                                <div class="product-info-image">
                                    <img t-attf-src="{{ imageSrc(state.details.product.id) }}"/>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="w-100 my-2 mx-0">
                        <table class="product-table-responsive w-100">
                            <t t-if="props.settings.edit_location">
                                <t t-set="fieldLocation" t-value="props.fields.location"/>
                                <t t-if="fieldLocation === 'src'">
                                    <tr>
                                        <td>Location</td>
                                        <td>
                                            <select class="o_barcode_editable" t-on-change="(ev) => this.changeLocation('src', ev.target.value)">
                                                <t t-foreach="props.locations.src" t-as="location" t-key="location[0]">
                                                    <option t-if="location[0]" t-att-value="location[0]" t-esc="location[1]" t-att-data-id="location[0]" t-att-data-name="location[1]" t-att-selected="props.move['location_id'][0] === location[0] ? 'selected' : undefined"/>
                                                </t>
                                            </select>
                                        </td>
                                    </tr>
                                </t>
                                <t t-elif="fieldLocation === 'dest'">
                                    <tr>
                                        <td>Location</td>
                                        <td>
                                            <select class="o_barcode_editable" t-on-change="(ev) => this.changeLocation('dest', ev.target.value)">
                                                <t t-foreach="props.locations.dest" t-as="location" t-key="location[0]">
                                                    <option t-if="location[0]" t-att-value="location[0]" t-esc="location[1]" t-att-data-id="location[0]" t-att-data-name="location[1]" t-att-selected="props.move['location_dest_id'][0] === location[0] ? 'selected' : undefined"/>
                                                </t>
                                            </select>
                                        </td>
                                    </tr>
                                </t>
                                <t t-else="">
                                    <tr>
                                        <td>Source Location</td>
                                        <td>
                                            <select class="o_barcode_editable" t-on-change="(ev) => this.changeLocation('src', ev.target.value)">
                                                <t t-foreach="props.locations.src" t-as="location" t-key="location[0]">
                                                    <option t-if="location[0]" t-att-value="location[0]" t-esc="location[1]" t-att-data-id="location[0]" t-att-data-name="location[1]" t-att-selected="props.move['location_id'][0] === location[0] ? 'selected' : undefined"/>
                                                </t>
                                            </select>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>Destination Location</td>
                                        <td>
                                            <select class="o_barcode_editable" t-on-change="(ev) => this.changeLocation('dest', ev.target.value)">
                                                <t t-foreach="props.locations.dest" t-as="location" t-key="location[0]">
                                                    <option t-if="location[0]" t-att-value="location[0]" t-esc="location[1]" t-att-data-id="location[0]" t-att-data-name="location[1]" t-att-selected="props.move['location_dest_id'][0] === location[0] ? 'selected' : undefined"/>
                                                </t>
                                            </select>
                                        </td>
                                    </tr>
                                </t>
                            </t>
                            <tr t-if="props.settings.edit_package and !props.move.lines.length">
                                <td>Package</td>
                                <td>
                                    <select class="o_barcode_editable" t-on-change="changePackage">
                                        <t t-set="fieldPackage" t-value="props.fields.package"/>
                                        <option t-att-value="0" data-id="0" data-name="-" data-number="-" data-qty="1" t-att-selected="!props.move[fieldPackage]?.length or props.move[fieldPackage][0] === 0 ? 'selected' : undefined">-</option>
                                        <t t-foreach="state.details.packages" t-as="package" t-key="package[0]">
                                            <option t-att-value="package[0]" t-esc="package[1]" t-att-data-id="package[0]" t-att-data-name="package[1]" t-att-data-number="package[2]" t-att-data-qty="package[3]" t-att-selected="props.move[fieldPackage]?.length and props.move[fieldPackage][0] === package[0] ? 'selected' : undefined"/>
                                        </t>
                                    </select>
                                </td>
                            </tr>
                            <tr>
                                <td>Product Type</td>
                                <td><span t-esc="state.details.product.type"/></td>
                            </tr>
                            <tr>
                                <td>Part No</td>
                                <td><span t-esc="state.details.product.default_code"/></td>
                            </tr>
                            <tr>
                                <td>Category</td>
                                <td><span t-esc="state.details.product.categ_id"/></td>
                            </tr>
                            <tr>
                                <td>Barcode</td>
                                <td class="d-flex align-items-center o_barcode gap-2">
                                    <span t-esc="state.barcode.value" t-att-class="{'d-none': state.barcode.edit}"/>
                                    <input type="text" t-model="state.barcode.value" class="o_barcode_input" t-att-class="{'d-none': !state.barcode.edit}"/>
                                    <i class="fa fa-save btn btn-primary rounded-0" t-att-class="{'d-none': !state.barcode.edit, 'disabled': state.barcode.disable}" t-on-click="saveBarcode"/>
                                    <i class="fa fa-pencil btn btn-primary rounded-0" t-att-class="{'d-none': state.barcode.edit, 'disabled': state.barcode.disable}" t-on-click="enableBarcode"/>
                                    <i class="fa fa-times btn btn-danger rounded-0" t-att-class="{'d-none': !state.barcode.edit, 'disabled': state.barcode.disable}" t-on-click="readBarcode"/>
                                </td>
                            </tr>
                            <tr>
                                <td>Sales Description</td>
                                <td><span t-esc="state.details.product.description_sale"/></td>
                            </tr>
                            </table>
                        </div>
                    <div>
                        <WarehouseDetails details="state.details"/>
                    </div>
                    <div class="product-info-clearfix"/>
                </div>
                <div class="position-fixed w-100 bottom">
                    <div class="d-flex flex-wrap">
                        <button class="confirm-button" t-on-click="back">Back</button>
                        <button class="confirm-button border-start" t-on-click="confirm">Confirm</button>
                    </div>
                </div>
            </div>
            <div class="position-fixed w-100 bottom">
                <div class="d-flex flex-wrap">
                    <button class="confirm-button" t-on-click="back">Back</button>
                    <button class="confirm-button border-start" t-on-click="confirm">Confirm</button>
                </div>
            </div>
        </div>
    </t>
</templates>
