<?xml version="1.0" encoding="UTF-8"?>

<templates xml:space="preserve">
    <t t-name="barcode_wms.Components" owl="1">
        <div class="o_barcode_action">
            <div t-if="state.popup.error" class="popup-overlay">
                <div>
                    <div class="popup-dialog border-danger">
                        <main>
                            <h2 class="py-5 text-700" t-esc="state.popup.error.message"/>
                        </main>
                        <footer>
                            <button class="btn btn-secondary shadow-sm" t-on-click="() => this.closePopup('error')">Close</button>
                        </footer>
                    </div>
                </div>
            </div>
            <div t-if="state.popup.confirm" class="popup-overlay">
                <div>
                    <div t-attf-class="popup-dialog border-{{ state.popup.confirm.type or 'primary' }}">
                        <main>
                            <h2 class="py-5 text-700" t-esc="state.popup.confirm.message"/>
                        </main>
                        <footer>
                            <button class="btn btn-secondary shadow-sm" t-on-click="() => this.closePopup('confirm')">Close</button>
                            <button t-attf-class="btn btn-{{ state.popup.confirm.type or 'primary' }} shadow-sm" t-on-click="state.popup.confirm.method">Yes</button>
                        </footer>
                    </div>
                </div>
            </div>
            <div t-if="state.popup.validate" class="popup-overlay">
                <div>
                    <div class="popup-dialog">
                        <main>
                            <h2 class="py-5 text-700">Do you want to save the changes?</h2>
                        </main>
                        <footer>
                            <button class="btn btn-secondary shadow-sm" t-on-click="() => this.closePopup('validate')">Discard</button>
                            <button t-if="state.groups.group_stock_user" class="btn btn-primary shadow-sm" t-on-click="applyTransfer">Yes</button>
                            <button t-if="state.groups.group_stock_user" class="btn btn-primary shadow-sm" t-on-click="applyValidateTransfer">Validate</button>
                        </footer>
                    </div>
                </div>
            </div>
            <div t-if="state.popup.addLocation" class="popup-overlay">
                <div>
                    <div class="popup-dialog">
                        <header class="bg-100 border-bottom py-3">
                            <h2 class="font-weight-bold">Add Location</h2>
                        </header>
                        <main>
                            <div>
                                <SelectDropdownLocationAdd data="locations.all" selected="state.location.add || {}" text="'Location'" trigger="'select-add-location'"/>
                            </div>
                        </main>
                        <footer>
                            <button class="btn btn-secondary shadow-sm" t-on-click="() => this.closePopup('addLocation')">Discard</button>
                        </footer>
                    </div>
                </div>
            </div>
            <div t-if="state.popup.changeOperation" class="popup-overlay">
                <div>
                    <div class="popup-dialog">
                        <main class="text-center">
                            <h2 class="py-5 text-700">Do you want to change the operation type?</h2>
                            <em>This will erase the progress.</em>
                        </main>
                        <footer>
                            <button class="btn btn-secondary shadow-sm" t-on-click="() => this.closePopup('changeOperation')">Discard</button>
                            <button class="btn btn-primary shadow-sm" t-on-click="() => this.applyOperationType()">Yes</button>
                        </footer>
                    </div>
                </div>
            </div>

            <t t-if="state.popup.addMove">
                <AddMove/>
            </t>
            <t t-elif="state.popup.editMove">
                <EditMove move="getMove(state.move)" locations="locations" fields="getFields()" settings="settings"/>
            </t>
            <t t-elif="state.popup.editLine">
                <EditLine line="getLine(state.line)" locations="locations" fields="getFields()" settings="settings"/>
            </t>
            <t t-else="">
                <t t-set="pages" t-value="getPages()"/>
                <t t-set="moves" t-value="getMoves()"/>
                <div class="scanning-screen"/>
            </t>

            <NotificationSound t-if="state.sound.src" sound="state.sound"/>      
        </div>
    </t>
</templates>
