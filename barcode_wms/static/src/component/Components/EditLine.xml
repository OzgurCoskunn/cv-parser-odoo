<?xml version="1.0" encoding="UTF-8"?>

<templates xml:space="preserve">
    <t t-name="barcode_wms.EditLine" owl="1">
        <div class="popup">
            <div class="popup-header">
                <div class="popup-back text-700" t-on-click="back">
                    <i class="fa fa-angle-left"/>
                </div>
            </div>
            <div class="o_form_view o_barcode_line_form o_form_nosheet o_form_editable">
                <div class="row mt-5 mb-4">
                    <div class="col-12 d-flex align-items-baseline fa-2x">
                        <i class="fa fa-fw fa-lg fa-tags mr16" title="Product"/>
                        <button class="btn btn-link" t-on-click="showProduct">
                            <span class="font-weight-normal h1 text-primary" t-esc="props.line.product_id.display_name"/>
                        </button>
                    </div>
                </div>
                <div class="row">
                    <div class="col-6 my-2 d-flex align-items-baseline">
                        <i class="fa fa-fw fa-lg fa-cube mr16" title="Quantity"/>
                        <input type="number" class="o_field_float o_field_number o_field_widget o_barcode_editable o_input w-50 w-md-100 text-end rounded-0" t-att-value="state.quantity" placeholder="Quantity" autocomplete="off" t-on-change="onChangeQty"/>
                        <button class="o_button_qty_done d-flex btn btn-primary o_widget rounded-0" t-on-click="onClickQty"> / <span class="ml4" t-esc="props.line.qty">1</span>
                            <span class="text-capitalize ml4">Units</span>
                        </button>
                    </div>
                </div>
                <div class="row">
                    <t t-set="fieldLocation" t-value="props.fields.location"/>
                    <t t-if="fieldLocation === 'src'">
                        <div class="col-12 col-md-6 my-2 d-flex align-items-baseline">
                            <i class="fa fa-fw fa-lg fa-long-arrow-right mr16" title="Location"/>
                            <select class="o_barcode_editable" t-on-change="(ev) => this.changeLocation('src', ev.target.value)">
                                <t t-foreach="props.locations.src" t-as="location" t-key="location[0]">
                                    <option t-if="location[0]" t-att-value="location[0]" t-esc="location[1]" t-att-data-id="location[0]" t-att-data-name="location[1]" t-att-selected="props.line.location_id[0] === location[0] ? 'selected' : undefined"/>
                                </t>
                            </select>
                        </div>
                    </t>
                    <t t-elif="fieldLocation === 'dest'">
                        <div class="col-12 col-md-6 my-2 d-flex align-items-baseline">
                            <i class="fa fa-fw fa-lg fa-long-arrow-right mr16" title="Location"/>
                            <select class="o_barcode_editable" t-on-change="(ev) => this.changeLocation('dest', ev.target.value)">
                                <t t-foreach="props.locations.dest" t-as="location" t-key="location[0]">
                                    <option t-if="location[0]" t-att-value="location[0]" t-esc="location[1]" t-att-data-id="location[0]" t-att-data-name="location[1]" t-att-selected="props.line.location_dest_id[0] === location[0] ? 'selected' : undefined"/>
                                </t>
                            </select>
                        </div>
                    </t>
                    <t t-else="">
                        <div class="col-12 col-md-6 my-2 d-flex align-items-baseline">
                            <i class="fa fa-fw fa-lg fa-long-arrow-right mr16" title="Source Location"/>
                            <select class="o_barcode_editable" t-on-change="(ev) => this.changeLocation('src', ev.target.value)">
                                <t t-foreach="props.locations.src" t-as="location" t-key="location[0]">
                                    <option t-if="location[0]" t-att-value="location[0]" t-esc="location[1]" t-att-data-id="location[0]" t-att-data-name="location[1]" t-att-selected="props.line.location_id[0] === location[0] ? 'selected' : undefined"/>
                                </t>
                            </select>
                        </div>
                        <div class="col-12 col-md-6 my-2 d-flex align-items-baseline">
                            <i class="fa fa-fw fa-lg fa-long-arrow-right mr16 ml16" title="Destination Location"/>
                            <select class="o_barcode_editable" t-on-change="(ev) => this.changeLocation('dest', ev.target.value)">
                                <t t-foreach="props.locations.dest" t-as="location" t-key="location[0]">
                                    <option t-if="location[0]" t-att-value="location[0]" t-esc="location[1]" t-att-data-id="location[0]" t-att-data-name="location[1]" t-att-selected="props.line.location_dest_id[0] === location[0] ? 'selected' : undefined"/>
                                </t>
                            </select>
                        </div>
                    </t>
                </div>
                <div t-if="['lot', 'serial'].includes(props.line.product_id.tracking)" class="row">
                    <div class="col-12 col-md-6 my-2 d-flex align-items-baseline">
                        <i class="fa fa-fw fa-lg fa-barcode mr16" title="Serial/Lot Number"/>
                        <input class="o_field_char o_field_widget o_quick_editable o_input o_barcode_editable rounded-0" t-on-change="onChangeNumber" t-att-value="state.number" placeholder="Serial/Lot Number" type="text" autocomplete="off"/>
                    </div>
                </div>
                <div t-if="props.settings.edit_package" class="row">
                    <div class="col-12 col-md-6 my-2 d-flex align-items-baseline">
                        <i class="fa fa-fw fa-lg fa-cube mr16" title="Package"/>
                        <select class="o_barcode_editable" t-on-change="onChangePackage">
                            <t t-set="fieldPackage" t-value="props.fields.package"/>
                            <option t-att-value="0" data-id="0" data-name="-" data-number="-" data-qty="1" t-att-selected="!props.line[fieldPackage]?.length or props.line[fieldPackage][0] === 0 ? 'selected' : undefined">-</option>
                            <t t-foreach="state.details.packages" t-as="package" t-key="package[0]">
                                <option t-att-value="package[0]" t-esc="package[1]" t-att-data-id="package[0]" t-att-data-name="package[1]" t-att-data-number="package[2]" t-att-data-qty="package[3]" t-att-selected="props.line[fieldPackage]?.length and props.line[fieldPackage][0] === package[0] ? 'selected' : undefined"/>
                            </t>
                        </select>
                    </div>
                </div>
            </div>
            <div class="position-fixed w-100 bottom">
                <div class="d-flex flex-wrap">
                    <button class="confirm-button" t-on-click="back">Back</button>
                    <button class="confirm-button border-start" t-on-click="confirm">Confirm</button>
                </div>
            </div>
        </div>
    </t>
</templates>
