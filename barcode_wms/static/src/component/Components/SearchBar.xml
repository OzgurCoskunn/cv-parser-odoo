<?xml version="1.0" encoding="UTF-8"?>

<templates xml:space="preserve">
    <t t-name="barcode_wms.SearchBar" owl="1">
        <div class="search-bar-container" t-ref="root" t-att-class="{'m-0 justify-content-center': !props.visible}">
            <div class="input-group">
                <input type="text" class="search-bar-input form-control" t-att-class="{'bg-white': !props.visible}" placeholder="Search The Product..." t-on-input="setQuery" t-on-click="onFocus"/>
                <div class="input-group-append">
                    <button class="btn btn-secondary h-100" type="button" t-on-click="onClickCamera">
                        <i class="fa fa-camera"/>
                    </button>
                </div>
            </div>
            <t t-if="state.visible">
                <div class="search-bar-list search-bar-list-product">
                    <t t-if="state.products.length">
                        <div class="search-bar-grid-product">
                            <t t-foreach="state.products" t-as="product" t-key="product.id">
                                <div class="search-bar-item-product" t-att-class="{'w-auto': !props.visible}" t-on-click="() => this.selectProduct(product)">
                                    <div>
                                        <div class="search-bar-item-product-box">
                                            <img t-attf-src="{{ imageSrc(product.id) }}"/>
                                        </div>
                                        <div class="search-bar-item-product-text my-0 mx-2">
                                            <p t-if="product.default_code" class="search-bar-item-product-code">
                                                <t t-esc="product.default_code"/>
                                            </p>
                                            <p class="search-bar-item-product-name">
                                                <t t-esc="product.name"/>
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </t>
                    <t t-if="!state.products.length">
                        <div class="text-center">
                            <h2 class="py-5 text-600">No results</h2>
                        </div>
                    </t>
                </div>
            </t>
        </div>
    </t>
</templates>