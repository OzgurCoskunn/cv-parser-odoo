<?xml version="1.0" encoding="UTF-8"?>

<templates xml:space="preserve">
    <t t-name="barcode_wms.AddMove" owl="1">
        <div class="popup">
            <t t-if="state.available">
                <div class="popup-header justify-content-between">
                    <div class="popup-back text-700" t-on-click="back">
                        <i class="fa fa-angle-left"/>
                    </div>
                    <div class="d-flex mr4">
                        <SearchBar/>
                    </div>
                </div>
                <div class="popup-body">
                    <div class="product-info-container">
                        <div class="bg-light border p-3 shadow-sm">
                            <h1 class="text-secondary">
                                <span t-esc="state.details.product.display_name"/>
                            </h1>
                        </div>
                        <div class="d-flex justify-content-between flex-wrap-reverse mt-4">
                            <div class="flex-fill">
                                <div class="d-flex justify-content-center justify-content-md-start">
                                    <div class="calculator pb-3 border mt-3">
                                        <div class="d-flex">
                                            <input type="text" class="calculator-screen z-depth-1" t-att-value="state.quantity" disabled="disabled"/>
                                        </div>
                                        <div class="d-flex">
                                            <div class="calculator-buttons">
                                                <button type="button" value="7" class="operator btn btn-primary rounded-0" t-on-click="digitValue">7</button>
                                                <button type="button" value="8" class="operator btn btn-primary rounded-0" t-on-click="digitValue">8</button>
                                                <button type="button" value="9" class="operator btn btn-primary rounded-0" t-on-click="digitValue">9</button>

                                                <button type="button" value="4" class="operator btn btn-primary rounded-0" t-on-click="digitValue">4</button>
                                                <button type="button" value="5" class="operator btn btn-primary rounded-0" t-on-click="digitValue">5</button>
                                                <button type="button" value="6" class="operator btn btn-primary rounded-0" t-on-click="digitValue">6</button>

                                                <button type="button" value="1" class="operator btn btn-primary rounded-0" t-on-click="digitValue">1</button>
                                                <button type="button" value="2" class="operator btn btn-primary rounded-0" t-on-click="digitValue">2</button>
                                                <button type="button" value="3" class="operator btn btn-primary rounded-0" t-on-click="digitValue">3</button>

                                                <button type="button" value="0" class="operator btn btn-primary rounded-0" t-on-click="digitValue">0</button>
                                                <button type="button" class="decimal function btn btn-secondary rounded-0" value="." t-on-click="selectDot">.</button>
                                                <button type="button" class="all-clear function btn btn-danger btn-sm rounded-0" value="clear" t-on-click="clearLastDigit"><i class="fa fa-arrow-left"/></button>
                                            </div>
                                            <div class="calculator-increment">
                                                <button type="button" value="2" class="operator btn btn-primary rounded-0" t-on-click="plusOne">+1</button>
                                                <button type="button" value="3" class="operator btn btn-primary rounded-0" t-on-click="minusOne">-1</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="flex-fill">
                                <div class="d-flex justify-content-center">
                                    <div class="product-info-image">
                                        <img t-attf-src="{{ imageSrc(state.details.product.id) }}"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="w-100 my-2 mx-0">
                            <table class="product-table-responsive w-100">
                                <tr>
                                    <td>Product Type</td>
                                    <td><span t-esc="state.details.product.type"/></td>
                                </tr>
                                <tr>
                                    <td>Part No</td>
                                    <td><span t-esc="state.details.product.default_code"/></td>
                                </tr>
                                <tr>
                                    <td>Category</td>
                                    <td><span t-esc="state.details.product.categ_id"/></td>
                                </tr>
                                <tr>
                                    <td>Barcode</td>
                                    <td><span t-esc="state.details.product.barcode"/></td>
                                </tr>
                                <tr>
                                    <td>Sales Description</td>
                                    <td><span t-esc="state.details.product.description_sale"/></td>
                                </tr>
                            </table>
                        </div>
                        <WarehouseDetails details="state.details"/>
                        <div class="product-info-clearfix"/>
                    </div>
                </div>
                <div class="position-fixed w-100 bottom">
                    <button class="confirm-button" t-on-click="back">Back</button>
                    <button class="confirm-button border-start" t-on-click="confirm">Confirm</button>
                </div>
            </t>
            <t t-else="">
                <div class="h-100">
                    <div class="popup-header">
                        <div class="popup-back text-700" t-on-click="back">
                            <i class="fa fa-angle-left"/>
                        </div>
                    </div>
                    <div class="w-100 d-flex flex-row flex-wrap justify-content-center align-items-center">
                        <div class="w-100">
                            <SearchBar visible="true"/>
                        </div>
                    </div>
                </div>
            </t>
        </div>
     </t>
</templates>