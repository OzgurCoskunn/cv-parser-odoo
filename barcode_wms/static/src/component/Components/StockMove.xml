<?xml version="1.0" encoding="UTF-8"?>

<templates xml:space="preserve">
    <div t-name="barcode_wms.StockMove" owl="1">
        <t t-if="state.moves.length">
            <t t-foreach="state.moves" t-as="move" t-key="move.id">
                <t t-set="fieldLocation" t-value="props.fields.location"/>
                <t t-set="fieldPackage" t-value="props.fields.package"/>
                <t t-set="showLocation" t-value="!props.page"/>
                <t t-set="moveCreated" t-value="move.new"/>
                <t t-set="moveWarned" t-value="props.warning and typeof move.qty === 'number' and move.qty lt move.qty_done"/>
                <t t-set="moveSelected" t-value="props.move.id === move.id"/>
                <t t-set="showLines" t-value="moveSelected and props.line.show"/>
                <t t-set="hasLines" t-value="move.lines?.length > 1 or ['lot','serial'].includes(move.product_id.tracking)"/>

                <div class="stock-move" t-attf-id="barcode_move_{{move.id}}" t-att-class="{'selected': moveSelected, 'created warned': moveCreated, 'warned': moveWarned}">
                    <div class="d-flex flex-column flex-lg-row flex-wrap justify-content-between" t-on-click="() => this.onSelect(move)">
                        <div class="d-flex flex-column flex-fill flex-sm-row">
                            <div class="stock-move-image align-self-center">
                                <img t-attf-src="{{ imageSrc(move.product_id.id) }}"/>
                            </div>
                            <div>
                                <h4 class="text-start font-weight-normal text-700">
                                    <span t-esc="move.product_id.display_name"/>
                                </h4>
                                <div class="d-flex font-size-20 gap-2 text-700 text-start">
                                    <div class="bg-primary border border-primary d-flex">
                                        <span t-esc="move.qty_done" class="py-1 px-2 bg-light-gray text-primary"/>
                                        <span t-if="move.qty" t-esc="move.qty" class="py-1 px-2 bg-primary text-white"/>
                                    </div>
                                    <div class="stock-move-info d-flex gap-2">
                                        <t t-if="showLocation">
                                            <span t-if="['int', 'src'].includes(fieldLocation)" class="py-1 px-2 bg-primary text-white">
                                                <i class="fa fa-fw fa-sign-out mr4"/>
                                                <span class="ml8" t-esc="move.location_id?.[1] or '-'"/>
                                            </span>
                                            <span t-if="['int', 'dest'].includes(fieldLocation)" class="py-1 px-2 bg-primary text-white">
                                                <i class="fa fa-fw fa-sign-in mr4"/>
                                                <span class="ml8" t-esc="move.location_dest_id?.[1] or '-'"/>
                                            </span>
                                        </t>
                                        <span t-if="!hasLines and move[fieldPackage]?.length" class="py-1 px-2 bg-primary text-white">
                                            <i class="fa fa-cube"/> <span t-esc="move[fieldPackage][1]"/>
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="mt-3 mt-lg-0 stock-move-button" t-att-class="{'column-3': props.buttons?.reset or (props.buttons?.done and move.qty > 0), 'lg-up': !moveSelected}">
                            <button t-if="props.buttons?.done and move.qty > 0" class="btn btn-lg hidden"/>
                            <button t-if="hasLines" class="btn btn-lg btn-primary rounded-0">
                                <i class="fa fa-2x" t-att-class="{'fa-caret-down': !showLines, 'fa-caret-up': showLines}"/>
                            </button>
                            <button t-else="" class="btn btn-lg btn-danger rounded-0" t-att-class="{'hidden': !moveSelected or hasLines or move.qty}" t-on-click="() => this.onRemove(move)">
                                <i class="fa fa-2x fa-times"/>
                            </button>
                            <button class="btn btn-lg btn-primary rounded-0" t-on-click="() => this.onEdit(move)">
                                <i class="fa fa-2x fa-pencil"/>
                            </button>
                            <button t-if="props.buttons?.check" class="btn btn-lg btn-primary rounded-0" t-att-class="{'hidden': !moveSelected or hasLines}" t-on-click="() => this.onCheck(move)">
                                <i t-if="move.checked" class="fa fa-2x fa-check-square"/>
                                <i t-else="" class="fa fa-2x fa-square"/>
                            </button>
                            <button class="btn btn-lg btn-lg btn-primary rounded-0" t-att-class="{'hidden': !moveSelected or hasLines}" t-on-click="() => this.onMinus(move)">-1</button>
                            <button class="btn btn-lg btn-lg btn-primary rounded-0" t-att-class="{'hidden': !moveSelected or hasLines}" t-on-click="() => this.onPlus(move)">+1</button>
                            <button t-if="props.buttons?.reset" class="btn btn-lg btn-lg btn-primary rounded-0" t-att-class="{'hidden': !moveSelected or hasLines}" t-on-click="() => this.onReset(move)" t-esc="-move.qty_done"></button>
                            <button t-if="props.buttons?.done and move.qty > 0" class="btn btn-lg btn-lg btn-primary rounded-0" t-att-class="{'hidden': !moveSelected or hasLines}" t-on-click="() => this.onDone(move)">
                                <t t-if="move.qty > move.qty_done" t-esc="'+'"/>
                                <t t-esc="move.qty - move.qty_done"/>
                            </button>
                        </div>
                    </div>
                    <div t-if="moveSelected and hasLines and showLines" class="stock-move-lines">
                        <div t-foreach="move.lines" t-as="line" t-key="line.id" t-attf-id="barcode_line_{{line.id}}" class="stock-move-line d-flex flex-nowrap flex-row" t-att-class="{'border-primary selected': props.line.id === line.id}" t-on-click="() => this.onSelectLine(line)">
                            <t t-set="lineSelected" t-value="props.line.id === line.id"/>
                            <div class="flex-fill flex-column flex-nowrap">
                                <div class="text-start mb8">
                                    <i class="fa fa-fw fa-cube mr4"/>
                                    <span class="o_barcode_scanner_qty text-monospace badge">
                                        <span t-esc="line.qty_done">0</span>
                                        <span t-if="line.qty" class="mx-2">/</span>
                                        <span t-if="line.qty" t-esc="line.qty"/>
                                    </span>
                                    <span>Units</span>
                                </div>
                                <div t-if="['int', 'src'].includes(fieldLocation)" class="text-start mb8">
                                        <i class="fa fa-fw fa-sign-out mr4"/>
                                        <span class="ml8" t-esc="line.location_id?.[1] or '-'"/>
                                </div>
                                <div t-if="['int', 'dest'].includes(fieldLocation)" class="text-start mb8">
                                    <i class="fa fa-fw fa-sign-in mr4"/>
                                    <span class="ml8" t-esc="line.location_dest_id?.[1] or '-'"/>
                                </div>
                                <div t-if="['lot','serial'].includes(move.product_id.tracking)" class="text-start mb8">
                                    <i class="fa fa-fw fa-barcode mr4"/>
                                    <span class="ml8" t-esc="line.number or '-'"/>
                                </div>
                                <div t-if="line[fieldPackage]?.length" class="text-start mb8">
                                    <i class="fa fa-fw fa-cube mr4"/>
                                    <span class="ml8" t-esc="line[fieldPackage][1]"/><button class="bg-transparent border-0 p-0" t-on-click="() => this.onPrintLine(line[fieldPackage][1])"><i class="fa fa-print ml8"/></button>
                                </div> 
                            </div>
                            <div class="mt-3 mt-lg-0 stock-move-button" t-att-class="{'column-3': props.buttons?.done and line.qty > 0, 'lg-up': !lineSelected}">
                                <button t-if="props.buttons?.done and line.qty > 0" class="btn btn-lg hidden"/>
                                <button class="btn btn-lg btn-danger rounded-0" t-att-class="{'hidden': !props.buttons?.remove and (!lineSelected or line.qty)}" t-on-click="() => this.onRemoveLine(line)">
                                    <i class="fa fa-2x fa-times"/>
                                </button>
                                <button class="btn btn-lg btn-primary rounded-0" t-on-click="() => this.onEditLine(line)">
                                    <i class="fa fa-2x fa-pencil"/>
                                </button>
                                <button class="btn btn-lg btn-lg btn-primary rounded-0" t-att-class="{'hidden': !lineSelected}" t-on-click="() => this.onMinusLine(line)">-1</button>
                                <button class="btn btn-lg btn-lg btn-primary rounded-0" t-att-class="{'hidden': !lineSelected}" t-on-click="() => this.onPlusLine(line)">+1</button>
                                <button t-if="props.buttons?.done and line.qty > 0" class="btn btn-lg btn-lg btn-primary rounded-0" t-att-class="{'hidden': !lineSelected}" t-on-click="() => this.onDoneLine(line)">
                                    <t t-if="line.qty > line.qty_done" t-esc="'+'"/>
                                    <t t-esc="line.qty - line.qty_done"/>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </t>
        </t>
        <t t-else="">
            <span class="d-block h1 mt-5 text-muted">No lines found</span>
        </t>
    </div>
 </templates>
