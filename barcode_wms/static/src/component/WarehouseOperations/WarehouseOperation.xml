<?xml version="1.0" encoding="UTF-8"?>

<templates xml:space="preserve">
    <t t-name="barcode_wms.WarehouseOperation" t-inherit="barcode_wms.Components" t-inherit-mode="primary" owl="1">
        <xpath expr="//div[@class='popup-overlay']" position="after">
            <div t-if="state.popup.printReport" class="popup-overlay">
                <div>
                    <div class="popup-dialog">
                        <header class="bg-100 border-bottom py-3">
                            <h2 class="font-weight-bold">Print</h2>
                        </header>
                        <main>
                            <t t-foreach="state.reports" t-as="report" t-key="report.id">
                                <div class="d-flex align-items-center justify-content-between py-2" t-att-id="report.id">
                                    <span t-esc="report.name"/>
                                    <button class="btn btn-primary" t-on-click="() => this.clickReportLine(report.id)">Print</button>
                                </div>
                            </t>
                        </main>
                        <footer>
                            <button class="btn btn-secondary shadow-sm" t-on-click="() => this.closePopup('printReport')">Discard</button>
                        </footer>
                    </div>
                </div>
            </div>
        </xpath>
        <xpath expr="//div[@class='scanning-screen']" position="inside">
            <t t-set="editable" t-value="!['done', 'cancel'].includes(picking.state)"/>
            <div class="scanning-screen-bar flex-column flex-sm-row gap-2">
                <div class="d-flex flex-fill align-items-center">
                    <div t-on-click="onBack" class="back-button-left">
                        <i class="fa fa-angle-left"/>
                    </div>
                    <div class="align-items-center d-flex gap-2">
                        <h2 class="picking-name"><t t-esc="picking.name"/></h2>
                        <span class="text-capitalize badge" t-att-class="{
                            'bg-success text-white': picking.state == 'done',
                            'bg-warning text-black': picking.state == 'assigned',
                            'bg-danger text-white': picking.state == 'cancel',
                            'bg-light text-black': !['done', 'assigned', 'cancel'].includes(picking.state),
                        }">
                            <t t-if="picking.state === 'draft'">Draft</t>
                            <t t-elif="picking.state === 'waiting'">Waiting</t>
                            <t t-elif="picking.state === 'confirmed'">Confirmed</t>
                            <t t-elif="picking.state === 'assigned'">Ready</t>
                            <t t-elif="picking.state === 'done'">Done</t>
                            <t t-elif="picking.state === 'cancel'">Cancelled</t>
                            <t t-else="" t-esc="picking.state"/>
                        </span>
                    </div>
                </div>
                <div class="d-flex flex-fill align-items-center justify-content-center justify-content-sm-end">
                    <div t-if="picking.state === 'done'" class="scanning-screen-bar-item" t-on-click="() => this.openPopup('printReport')">
                        <button title="Print"><i class="fa fa-print"/></button>
                    </div>
                    <div t-if="editable and state.groups.group_tracking_lot" class="scanning-screen-bar-item" t-on-click="listInventory">
                        <button title="See Details"><i class="fa fa-list"/></button>
                    </div>
                    <div t-if="editable and state.groups.group_tracking_lot" class="scanning-screen-bar-item" t-on-click="onPack">
                        <button title="Put in Pack"><i class="fa fa-cube"/></button>
                    </div>
                    <div t-if="editable" class="scanning-screen-bar-item lg-up">
                        <SearchBar filter="(value) => this.filterMove(value)"/>
                    </div>
                    <div t-if="editable" class="scanning-screen-bar-item" t-on-click="() => this.openPopup('addLocation')">
                        <button><i class="fa fa-plus"/></button>
                    </div>
                    <div t-if="editable and state.operation.id and state.operation.src" class="scanning-screen-bar-item">
                        <SelectDropdownLocationSrc data="locations.src" selected="state.location.src" trigger="'select-source-location'"/>
                    </div>
                    <div t-if="editable and state.operation.id and state.operation.dest" class="scanning-screen-bar-item">
                        <SelectDropdownLocationDest data="locations.dest" selected="state.location.dest" trigger="'select-destination-location'"/>
                    </div>
                    <div t-if="editable" class="scanning-screen-bar-item lg-up">
                        <div class="h-100">
                            <Pagination current="pages.current" total="pages.total"/>
                        </div>
                    </div>
                </div>
            </div>
            <div class="scanning-screen-subbar md-down">
                <div class="align-items-center d-flex">
                    <div class="scanning-screen-subbar-item p-2">
                        <SearchBar filter="(value) => this.filterMove(value)"/>
                    </div>
                </div>
                <div class="align-items-center d-flex">
                    <div class="scanning-screen-subbar-item">
                        <div class="h-100">
                            <Pagination current="pages.current" total="pages.total"/>
                        </div>
                    </div>
                </div>
            </div>
            <div class="scanning-screen-body">
                <t t-if="picking.state == 'cancel'">
                    <div class="scanning-screen-notification">
                        <i class="fa fa-2x fa-exclamation-triangle"/>
                        <p>This picking has been cancelled</p>
                    </div>
                </t>
                <t t-elif="picking.state == 'done'">
                    <div class="scanning-screen-notification">
                        <i class="fa fa-2x fa-exclamation-triangle"/>
                        <p>This picking has been done</p>
                    </div>
                </t>
                <div id="barcode_move" class="scanning-screen-line w-100 h-100 overflow-auto">
                    <StockMove moves="moves" move="state.move" line="state.line" page="pages.current" groups="state.groups" fields="getFields()" warning="true" buttons="{ done: true }"/>
                </div>
                <div class="w-100 bottom border-top">
                    <button class="confirm-button" t-on-click="() => this.openPopup('addMove')" t-att-disabled="state.location.src.length and state.location.dest.length ? undefined : 'disabled'">Add Products</button>
                    <button class="border-start confirm-button" t-on-click="() => this.openPopup('validate')" t-att-disabled="moves.length ? undefined : 'disabled'">Validate</button>
                </div>
            </div>
        </xpath>
    </t>
</templates>
