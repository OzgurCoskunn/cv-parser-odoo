<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
    <field name="model">res.config.settings</field>
    <field name="inherit_id" ref="stock.res_config_settings_view_form"/>
    <field name="arch" type="xml">
        <block name="barcode_setting_container" position="inside">
            <setting id="save_operations_barcodes" string="Save Operations Before Closing" help="Saving changes before closing current operations">
                <field name="barcode_save_before_closing"/>
            </setting>
            <setting id="process_operations_barcodes_wms" string="Warehouse Operations Line Creation Method" help="Specify the process when creating new lines on barcode warehouse operations">
                <div class="content-group mt16">
                    <field name="barcode_warehouse_create_method" widget="radio"/>
                </div>
            </setting>
        </block>
    </field>
    </record>
</odoo>