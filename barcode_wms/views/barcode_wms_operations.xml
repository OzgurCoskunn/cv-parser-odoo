<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="stock_picking_type_kanban_barcode" model="ir.ui.view">
        <field name="name">stock.picking.type.kanban.barcode</field>
        <field name="model">stock.picking.type</field>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <kanban create="0" can_open="0" import="0" class="o_kanban_mobile o_barcode_wms_kanban">
                <field name="name"/>
                <field name="code"/>
                <field name="count_picking_ready"/>
                <templates>
                    <t t-name="card">
                        <div t-attf-class="oe_kanban_global_click o_kanban_record_has_image_fill o_stock_picking_type_kanban_record">
                            <div class="o_kanban_card_header d-flex justify-content-between align-items-center p-3">
                                <div class="o_kanban_card_header_title">
                                    <div class="h3 o_primary fw-bold text-uppercase mb-0">
                                        <field name="name"/>
                                    </div>
                                    <div class="text-muted text-uppercase small">
                                        <field name="code"/>
                                    </div>
                                </div>
                                <div class="o_kanban_manage_button_section">
                                    <span class="badge rounded-pill bg-primary fs-4 px-3 py-2">
                                        <field name="count_picking_ready"/>
                                    </span>
                                </div>
                            </div>
                            <div class="container o_kanban_card_content p-3 mt-auto">
                                <div class="row">
                                    <div class="col-12">
                                        <button name="get_action_picking_tree_ready" type="object" class="btn btn-primary w-100 py-3 text-uppercase fw-bold fs-5 shadow-sm">
                                            Process
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="stock_picking_type_action_kanban" model="ir.actions.act_window">
        <field name="name">Operations</field>
        <field name="res_model">stock.picking.type</field>
        <field name="view_mode">kanban</field>
        <field name="view_id" ref="stock_picking_type_kanban_barcode"/>
        <field name="target">fullscreen</field>
        <field name="domain">[]</field>
        <field name="context">{'barcode_view': True}</field>
        <field name="help" type="html">
          <p class="o_view_nocontent_smiling_face">
            Create a new operation type
          </p>
        </field>
    </record>

</odoo>
