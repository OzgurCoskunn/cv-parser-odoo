<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_picking_type_form" model="ir.ui.view">
    <field name="model">stock.picking.type</field>
    <field name="inherit_id" ref="stock.view_picking_type_form"/>
    <field name="arch" type="xml">
        <xpath expr="//field[@name='default_location_src_id']/.." position="after">
            <group string="Barcode">
                <field name="barcode_lot_create_method" string="Serial/Lot Line Creation Method" widget="radio" groups="stock.group_production_lot"/>
                <field name="barcode_show_all_lines"/>
            </group>
        </xpath>
    </field>
    </record>
</odoo>