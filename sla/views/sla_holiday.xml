<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="list_holiday" model="ir.ui.view">
    <field name="name">sla.holiday.list</field>
    <field name="model">sla.holiday</field>
    <field name="arch" type="xml">
        <list string="Holidays" editable="top">
            <field name="name"/>
            <field name="date_from"/>
            <field name="date_to"/>
            <field name="company_id" invisible="1"/>
        </list>
    </field>
    </record>

    <record id="action_holiday" model="ir.actions.act_window">
    <field name="name">Holidays</field>
    <field name="type">ir.actions.act_window</field>
    <field name="res_model">sla.holiday</field>
    <field name="view_mode">list</field>
    </record>
</odoo>