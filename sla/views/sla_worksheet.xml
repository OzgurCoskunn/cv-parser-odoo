<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="list_worksheet" model="ir.ui.view">
    <field name="name">sla.worksheet.list</field>
    <field name="model">sla.worksheet</field>
    <field name="arch" type="xml">
        <list string="Worksheets">
            <field name="sequence" widget="handle"/>
            <field name="name" decoration-bf="1"/>
            <field name="tz"/>
            <field name="company_id" invisible="1"/>
        </list>
    </field>
    </record>

    <record id="form_worksheet" model="ir.ui.view">
    <field name="name">sla.worksheet.form</field>
    <field name="model">sla.worksheet</field>
    <field name="arch" type="xml">
        <form string="Worksheets">
            <sheet>
                <div class="oe_title">
                    <label for="name"/>
                    <h1><field name="name" class="oe_inline"/></h1>
                </div>
                <field name="active" invisible="1"/>
                <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active == True"/>
                <group>
                    <group>
                        <field name="tz"/>
                        <field name="tz_offset" invisible="1"/>
                    </group>
                    <group>
                        <field name="hour_average" widget="float_time"/>
                        <field name="hour_threshold" widget="float_time"/>
                        <field name="company_id" invisible="1" options="{'no_create': True}"/>
                    </group>
                </group>
                <notebook>
                    <page name="line" string="Calendar">
                        <field name="line_ids" mode="list"/>
                    </page>
                </notebook>
            </sheet>
        </form>
    </field>
    </record>

    <record id="list_worksheet_line" model="ir.ui.view">
    <field name="name">sla.worksheet.line.list</field>
    <field name="model">sla.worksheet.line</field>
    <field name="arch" type="xml">
        <list string="Working Time" editable="top">
            <field name="sequence" widget="handle"/>
            <field name="name"/>
            <field name="day"/>
            <field name="period"/>
            <field name="hour_from" widget="float_time"/>
            <field name="hour_to" widget="float_time"/>
        </list>
    </field>
    </record>

    <record id="form_worksheet_line" model="ir.ui.view">
    <field name="name">sla.worksheet.line.form</field>
    <field name="model">sla.worksheet.line</field>
    <field name="arch" type="xml">
        <form string="Working Time">
            <sheet>
                <group>
                    <field name="name"/>
                    <field name="day"/>
                    <label for="hour_from" string="Hours"/>
                    <div class="o_row">
                        <field name="hour_from" widget="float_time"/> -
                        <field name="hour_to" widget="float_time"/>
                    </div>
                    <field name="period"/>
                </group>
            </sheet>
        </form>
    </field>
    </record>

    <record id="action_worksheet" model="ir.actions.act_window">
    <field name="name">Worksheets</field>
    <field name="type">ir.actions.act_window</field>
    <field name="res_model">sla.worksheet</field>
    <field name="view_mode">list,form</field>
    <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
            No worksheets yet
        </p>
        <p>
            Create worksheets for tickets easily
        </p>
    </field>
    </record>
</odoo>