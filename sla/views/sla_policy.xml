<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="list_policy" model="ir.ui.view">
    <field name="name">sla.policy.list</field>
    <field name="model">sla.policy</field>
    <field name="arch" type="xml">
        <list string="Policies" decoration-muted="active == False" sample="1">
            <field name="sequence" widget="handle"/>
            <field name="name"/>
            <field name="worksheet_id"/>
            <field name="stage_ids"/>
            <field name="active" invisible="1"/>
        </list>
    </field>
    </record>

    <record id="form_policy" model="ir.ui.view">
    <field name="name">sla.policy.form</field>
    <field name="model">sla.policy</field>
    <field name="arch" type="xml">
        <form string="Policies">
            <sheet>
                <div class="oe_title">
                    <label for="name"/>
                    <h1><field name="name" class="oe_inline"/></h1>
                </div>
                <field name="active" invisible="1"/>
                <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active == True"/>
                <group>
                    <group>
                        <separator string="Options" colspan="2"/>
                        <field name="worksheet_id" options="{'no_create': True}"/>
                        <field name="hour_total" widget="float_time"/>
                    </group>
                    <group class="position-relative">
                        <separator string="Stages" colspan="2"/>
                        <label for="stage_model_id"/>
                        <div class="d-flex">
                            <field name="stage_model_id" class="oe_inline fw-bold flex-fill" options="{'no_create': True}" placeholder="No model specified"/>
                            <label for="stage_model_apply" string="Apply" class="btn btn-secondary fw-bold" invisible="stage_model_show == False"/>
                            <field name="stage_model_apply" class="d-none"/>
                        </div>
                        <field name="stage_model_name" invisible="1"/>
                        <field name="stage_model_show" invisible="1"/>
                        <div class="position-absolute" style="top: 10px; right: 0;">
                            <label for="stage_reset" string="Reset" class="btn fw-bold o_form_label text-500 text-uppercase"/>
                            <field name="stage_reset" class="d-none"/>
                        </div>
                        <field name="stage_ids" mode="list" nolabel="1" colspan="2">
                            <list editable="bottom">
                                <field name="sequence" widget="handle"/>
                                <field name="name" decoration-bf="1" column_invisible="parent.stage_model_name != False"/>
                                <field name="stage_ref" string="Name" options="{'no_create': True}" decoration-bf="1" column_invisible="parent.stage_model_name == False" class="o_sla_policy_stage_ref"/>
                                <field name="stage_id" invisible="1"/>
                                <field name="stage_model" invisible="1"/>
                                <field name="type" widget="radio" options="{'horizontal': True}"/>
                            </list>
                            <form>
                                <sheet>
                                    <group>
                                        <group>
                                            <field name="name"/>
                                        </group>
                                        <group>
                                            <field name="type" widget="radio" options="{'horizontal': True}"/>
                                        </group>
                                    </group>
                                </sheet>
                            </form>
                        </field>
                    </group>
                </group>
            </sheet>
        </form>
    </field>
    </record>

    <record id="action_policy" model="ir.actions.act_window">
    <field name="name">Policies</field>
    <field name="type">ir.actions.act_window</field>
    <field name="res_model">sla.policy</field>
    <field name="view_mode">list,form</field>
    <field name="context">{'active_test': False}</field>
    <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
            No policies yet
        </p>
        <p>
            Create policies for agreements easily
        </p>
    </field>
    </record>
</odoo>