<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="list_agreement" model="ir.ui.view">
    <field name="name">sla.agreement.list</field>
    <field name="model">sla.agreement</field>
    <field name="arch" type="xml">
        <list string="Agreements" sample="1">
            <field name="name" decoration-bf="1"/>
            <field name="create_date"/>
            <field name="partner_id"/>
            <field name="ticket_ids"/>
            <field name="state" widget="badge" decoration-success="state == 'confirm'"/>
            <field name="company_id" invisible="1"/>
        </list>
    </field>
    </record>
 
    <record id="form_agreement" model="ir.ui.view">
    <field name="name">sla.agreement.form</field>
    <field name="model">sla.agreement</field>
    <field name="arch" type="xml">
        <form string="Agreements">
            <header>
                <button name="action_confirm" type="object" class="btn-primary" string="Confirm" invisible="state != 'draft'"/>
                <button name="action_ticket" type="object" class="btn-primary" string="Create Ticket" invisible="state == 'draft'"/>
                <button name="action_draft" type="object" class="btn-secondary" string="Set to Draft" invisible="state == 'draft'"/>
                <field name="state" widget="statusbar" statusbar_visible="draft,confirm"/>
            </header>
            <sheet>
                <div class="oe_button_box" name="button_box">
                    <button name="action_view_tickets" type="object" class="oe_stat_button" icon="fa-tags" invisible="id == False or ticket_count == 0">
                        <div class="o_field_widget o_stat_info">
                            <span class="o_stat_value">
                                <field name="ticket_count" widget="statinfo" nolabel="1"/>
                            </span>
                            <span class="o_stat_text">Tickets</span>
                        </div>
                    </button>
                </div>
                <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active == True"/>
                <div class="oe_title">
                    <label for="name"/>
                    <h1><field name="name" class="oe_inline" readonly="state != 'draft'" placeholder="Agreement Name"/></h1>
                    <h3 class="text-muted mt-n3 mt-3"><field name="code" class="oe_inline" readonly="state != 'draft'" placeholder="Agreement Code"/></h3>
                </div>
                <field name="active" invisible="1"/>
                <group>
                    <group>
                        <field name="type" widget="radio" options="{'horizontal': True}" readonly="state != 'draft'"/>
                        <separator string="Partner" colspan="2" invisible="type != 'partner'"/>
                        <field name="partner_id" options="{'no_create': True}" invisible="type != 'partner'" readonly="state != 'draft'" required="type == 'partner'"/>
                        <separator string="User" colspan="2" invisible="type != 'user'"/>
                        <field name="user_id" options="{'no_create': True}" invisible="type != 'user'" readonly="state != 'draft'" required="type == 'user'"/>
                        <separator string="Team" colspan="2" invisible="type != 'team'"/>
                        <field name="team_id" options="{'no_create': True}" invisible="type != 'team'" readonly="state != 'draft'" required="type == 'team'"/>
                        <separator string="Policy" colspan="2"/>
                        <field name="policy_id" options="{'no_create': True}" readonly="state != 'draft'"/>
                        <field name="worksheet_id" options="{'no_create': True}" readonly="state != 'draft'"/>
                        <separator string="Hours" colspan="2"/>
                        <div colspan="2" class="position-relative">
                            <div colspan="2" class="position-absolute" style="top: -40px; right: 10px;">
                                <em class="mr16">Use Hour Model</em>
                                <field name="hour_model" widget="boolean_toggle" nolabel="1" class="oe_inline"/>
                            </div>
                        </div>
                        <field name="hour_total" widget="float_time" invisible="hour_model != False" readonly="state != 'draft'"/>
                        <label for="hour_model_id" invisible="hour_model == False"/>
                        <div class="d-flex" invisible="hour_model == False">
                            <field name="hour_model_id" class="oe_inline fw-bold flex-fill" options="{'no_create': True}" placeholder="No model specified" readonly="state != 'draft'"/>
                            <!--<button name="action_reset_hours" type="object" string="Reset" confirm="Are you want to reset all hour records?"/>-->
                            <button name="action_view_hours" type="object" string="View"/>
                        </div>
                    </group>
                    <group>
                        <separator string="Stages" colspan="2"/>
                        <field name="stage_model_name" invisible="1"/>
                        <field name="stage_ids" mode="list" readonly="state != 'draft'" nolabel="1" colspan="2">
                            <list editable="bottom">
                                <field name="sequence" widget="handle"/>
                                <field name="name" decoration-bf="1" column_invisible="parent.stage_model_name != False"/>
                                <field name="stage_ref" string="Name" options="{'no_create': True}" decoration-bf="1" column_invisible="parent.stage_model_name == False" class="o_sla_policy_stage_ref"/>
                                <field name="stage_id" invisible="1"/>
                                <field name="stage_model" invisible="1"/>
                                <field name="type" widget="radio" options="{'horizontal': True}"/>
                            </list>
                            <form>
                                <sheet>
                                    <group>
                                        <group>
                                            <field name="name"/>
                                        </group>
                                        <group>
                                            <field name="type" widget="radio" options="{'horizontal': True}"/>
                                        </group>
                                    </group>
                                </sheet>
                            </form>
                        </field>
                    </group>
                </group>
            </sheet>
            <chatter/>
        </form>
    </field>
    </record>

    <record id="action_agreement" model="ir.actions.act_window">
    <field name="name">Agreements</field>
    <field name="type">ir.actions.act_window</field>
    <field name="res_model">sla.agreement</field>
    <field name="view_mode">list,form</field>
    <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
            No agreements yet
        </p>
        <p>
            Create agreements and track their tickets efficiently
        </p>
    </field>
    </record>
</odoo>