<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="address" inherit_id="website_sale.address">
        <xpath expr="//label[@for='city']/.." position="replace"/>
        <xpath expr="//label[@for='street2']/.." position="replace"/>
        <xpath expr="//label[@for='street']/.." position="replace"/>
        <xpath expr="//label[@for='country_id']/.." position="replace"/>
        <xpath expr="//label[@for='state_id']/.." position="replace"/>
        <xpath expr="//label[@for='zip']/../.." position="replace"/>
        <xpath expr="//label[@for='zip']/../.." position="replace"/> 
        <xpath expr="//label[@for='company_name']/.." position="replace"/>             
        <xpath expr="//label[@for='vat']/.." position="replace"/>             
        <xpath expr="//label[@for='phone']/.." position="replace">
            <div t-attf-class="mb-3 #{error.get('phone') and 'o_has_error' or ''} col-lg-6" id="div_phone">
                <label class="col-form-label" for="phone">Phone</label>
                <input type="tel" name="phone" t-attf-class="form-control #{error.get('phone') and 'is-invalid' or ''}" t-att-value="'phone' in checkout and checkout['phone']"/>
            </div>

        </xpath>
        <!--<xpath expr="//input[@name='name']" position="attributes">
            <attribute name="t-att-value">contact or 'name' in checkout and checkout['name']</attribute>
        </xpath>-->
        <xpath expr="//label[@for='phone']/.." position="after">
            <h2 t-if="mode[1] == 'billing'" class="o_page_header mt8">Billing Address</h2>
            <div t-if="mode[1] == 'billing'" class="w-100"/>
            <div t-if="mode[1] == 'billing'" t-attf-class="mb-3 #{error.get('company_type') and 'o_has_error' or ''} col-lg-6 div_type w-100 d-flex justify-content-center">
                <div class="mr64">
                    <label class="col-form-label" for="type_person">Person</label>
                    <input type="radio" id="type_person" name="company_type"  t-attf-class="#{error.get('company_type') and 'is-invalid' or ''}" t-att-checked="not is_company" value="person"/>
                </div>
                <div>
                    <label class="col-form-label" for="type_company">Company</label>
                    <input type="radio" id="type_company" name="company_type" t-attf-class="#{error.get('company_type') and 'is-invalid' or ''}" t-att-checked="is_company" value="company"/>
                </div>
            </div>
            <div class="w-100"/>
            <t t-if="mode[1] != 'shipping'">
                <div t-attf-class="mb-3 #{error.get('company_name') and 'o_has_error' or ''}  mb-0 company" t-att-style="'display: none' if not is_company else ''">
                    <label class="col-form-label" for="company_name">Company Name</label>
                    <input type="text" name="company_name" t-attf-class="form-control #{error.get('company_name') and 'is-invalid' or ''}" t-att-value="'commercial_company_name' in checkout and checkout['commercial_company_name'] or 'company_name' in checkout and checkout['company_name']" t-att-readonly="'1' if vat_warning else None" />
                    <small t-if="vat_warning" class="form-text text-muted d-block d-lg-none">Changing company name is not allowed once document(s) have been issued for your account. Please contact us directly for this operation.</small>
                </div>
            </t>
            <div t-attf-class="mb-3 mb-0 div_table_name">
                <label class="col-form-label" for="table_name">Table Name</label>
                <input type="text" name="table_name" class="form-control"  t-att-value="'table_name' in checkout and checkout['table_name'] or 'table_name' in checkout and checkout['table_name']"/>
            </div>
            <div t-attf-class="mb-3 #{error.get('country_id') and 'o_has_error' or ''} col-lg-6 div_country" t-att-style="(country or country.state_ids) and 'display: none'">
                <label class="col-form-label" for="country_id">Country</label>
                <select id="country_id" name="country_id" t-attf-class="form-select #{error.get('country_id') and 'is-invalid' or ''}" t-att-mode="mode[1]">
                    <option value="" disabled="true">Country...</option>
                    <t t-foreach="countries" t-as="c">
                        <option t-att-value="c.id" t-att-selected="c.id == (country and country.id or -1)">
                            <t t-esc="c.name"/>
                        </option>
                    </t>
                </select>
            </div>
            <div t-attf-class="mb-3 #{error.get('state_id') and 'o_has_error' or ''} div_state" t-att-style="(not country or not country.state_ids) and 'display: none'">
                <label class="col-form-label" for="state_id">State / Province</label>
                <select name="state_id" t-attf-class="form-select #{error.get('state_id') and 'is-invalid' or ''}" data-init="1">
                    <option value="" disabled="true" selected="error.get('state_id')">State / Province...</option>
                    <t t-foreach="country_states" t-as="s">
                        <option t-att-value="s.id" t-att-selected="s.id == ('state_id' in checkout and country and checkout['state_id'] != '' and int(checkout['state_id']))">
                            <t t-esc="s.name" />
                        </option>
                    </t>
                </select>
            </div>
            <div class="w-100"/>
            <div t-if="field_town_selection" t-attf-class="mb-3 #{error.get('town_id') and 'o_has_error' or ''} div_city" t-att-style="(not country or not country.state_ids) and 'display: none'">
                <label class="col-form-label" for="town_id">Town</label>
                <select name="town_id" t-attf-class="form-select #{error.get('town_id') and 'is-invalid' or ''}" data-init="1">
                    <option value="" disabled="true" selected="error.get('town_id')">Town...</option>
                    <t t-foreach="country_towns" t-as="s">
                        <option t-att-value="s.id" t-att-selected="s.id == ('town_id' in checkout and checkout['town_id'] != '' and int(checkout['town_id']))">
                            <t t-esc="s.name"/>
                        </option>
                    </t>
                </select>
            </div>
            <div t-else="">
                <div t-attf-class="mb-3 #{error.get('city') and 'o_has_error' or ''} col-md-8 div_city" t-att-style="(not country or not country.state_ids) and 'display: none'">
                    <label class="col-form-label" for="city">City</label>
                    <input type="text" name="city" t-attf-class="form-control #{error.get('city') and 'is-invalid' or ''}" t-att-value="'city' in checkout and checkout['city']" />
                </div>
            </div>
            <div t-if="field_district_selection" t-attf-class="mb-3 #{error.get('district_id') and 'o_has_error' or ''} div_street" t-att-style="(not country or not country.state_ids) and 'display: none'">
                <label class="col-form-label" for="district_id">District</label>
                <select name="district_id" t-attf-class="form-select #{error.get('district_id') and 'is-invalid' or ''}" data-init="1">
                    <option value="" disabled="true" t-att-selected="error.get('district_id')">District...</option>
                    <t t-foreach="country_districts" t-as="s">
                        <option t-att-value="s.id" t-att-selected="s.id == ('district_id' in checkout and checkout['district_id'] != '' and int(checkout['district_id']))">
                            <t t-esc="s.name"/>
                        </option>
                    </t>
                </select>
            </div>
            <div t-else="">
                <div t-attf-class="mb-3 #{error.get('street') and 'o_has_error' or ''} col-lg-12 div_street" t-att-style="(not country or not country.state_ids) and 'display: none'">
                    <label class="col-form-label" for="street">District</label>
                    <input type="text" name="street" t-attf-class="form-control #{error.get('street') and 'is-invalid' or ''}" t-att-value="'street' in checkout and checkout['street']" />
                </div>
            </div>
            <div class="w-100"/>
            <div t-if="field_street_selection" t-attf-class="mb-3 #{error.get('street_id') and 'o_has_error' or ''} div_street2" t-att-style="(not country or not country.state_ids) and 'display: none'">
                <label for="street_id" class="col-form-label">Street</label>
                <select name="street_id" t-attf-class="form-select #{error.get('street_id') and 'is-invalid' or ''}" data-init="1">
                    <option value="" disabled="true" t-att-selected="error.get('street_id')">Street...</option>
                    <t t-foreach="country_streets" t-as="s">
                        <option t-att-value="s.id" t-att-selected="s.id == ('street_id' in checkout and checkout['street_id'] != '' and int(checkout['street_id']))">
                            <t t-esc="s.name"/>
                        </option>
                    </t>
                </select>
            </div>
            <div t-else="">
                <div t-attf-class="mb-3 #{error.get('street2') and 'o_has_error' or ''} col-lg-12 div_street2" t-att-style="(not country or not country.state_ids) and 'display: none'">
                    <label class="col-form-label label-optional" for="street2">Street</label>
                    <input type="text" name="street2" t-attf-class="form-control #{error.get('street2') and 'is-invalid' or ''}" t-att-value="'street2' in checkout and checkout['street2']" />
                </div>
            </div>
            <div t-attf-class="mb-3 #{error.get('street3') and 'o_has_error' or ''} col-md-3 div_street3" t-att-style="(not country or not country.state_ids) and 'display: none'">
                <label class="col-form-label" for="street3">Apartment / Flat Number</label>
                <input type="text" name="street3" t-attf-class="form-control #{error.get('street3') and 'is-invalid' or ''}" t-att-value="'street3' in checkout and checkout['street3']"/>
            </div>
            <div t-attf-class="mb-3 #{error.get('zip') and 'o_has_error' or ''} col-md-3 div_zip" t-att-style="(not country or not country.state_ids) and 'display: none'">
                <label class="col-form-label label-optional" for="zip">Zip Code</label>
                <input type="text" name="zip" t-attf-class="form-control #{error.get('zip') and 'is-invalid' or ''}" t-att-value="'zip' in checkout and checkout['zip']"/>
            </div>
            <t t-if="mode[1] != 'shipping'">
                <div t-attf-class="mb-3 #{error.get('vat') and 'o_has_error' or ''} col-md-3 div_vat mb-0">
                    <t t-if="not is_company">
                        <strong><label class="col-form-label" for="vat">VAT Number</label></strong>
                    </t>
                    <t t-else="">
                        <strong><label class="col-form-label" for="vat">Tax Number</label></strong>
                    </t>
                    <input type="text" name="vat" t-attf-class="form-control #{error.get('vat') and 'is-invalid' or ''}" t-att-value="'vat' in checkout and checkout['vat']" t-att-readonly="'1' if vat_warning else None"/>
                    <small t-if="vat_warning" class="form-text text-muted d-block d-lg-none">Changing VAT number is not allowed once document(s) have been issued for your account. Please contact us directly for this operation.</small>
                </div>
            </t>
            <t t-if="mode[1] != 'shipping'">
                <div t-attf-class="mb-3 #{error.get('tax_office_id') and 'o_has_error' or ''} div_street col-md-3 tax_office" t-att-style="'display: none' if not is_company else ''">
                    <label class="col-form-label" for="tax_office_id">Tax Offices</label>
                    <select name="tax_office_id" t-attf-class="form-select #{error.get('tax_office_id') and 'is-invalid' or ''}" data-init="1">
                        <option value="" disabled="true" t-att-selected="error.get('tax_office_id')">Tax Offices...</option>
                        <t t-foreach="tax_offices" t-as="s">
                            <option t-att-value="s.id" t-att-selected="s.id == ('tax_office_id' in checkout and checkout['tax_office_id'] != '' and int(checkout['tax_office_id']))">
                                <t t-esc="s.name"/>
                            </option>
                        </t>
                    </select>
                </div>
            </t>
        </xpath>
    </template>

    <template id="checkout" inherit_id="website_sale.checkout">
        <xpath expr="//t[@t-foreach='shippings']//t[@t-set='allow_edit']" position="attributes">
            <attribute name="t-value">not order.partner_id or (ship.id in order.partner_id.parent_id.child_ids.ids)</attribute>
        </xpath>
    </template>
</odoo>
