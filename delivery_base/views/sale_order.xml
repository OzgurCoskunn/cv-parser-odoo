<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form" model="ir.ui.view">
    <field name="model">sale.order</field>
    <field name="inherit_id" ref="sale.view_order_form"/>
    <field name="arch" type="xml">
        <xpath expr="//notebook" position="inside">
            <page name="cargo_status" string="Cargo Status">
                <notebook/>
            </page>
        </xpath>
        <xpath expr="//div[@name='button_box']" position="inside">
            <button type="object" name="action_picking_tracking_url" class="oe_stat_button" icon="fa-road">
                <div class="o_form_field o_stat_info mr3">
                    <span class="o_stat_value">View</span><span class="o_stat_text">Tracking Details</span>
                </div>
            </button>
        </xpath>
    </field>
    </record>
</odoo>
