<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="delivery_status_list" model="ir.ui.view">
    <field name="name">delivery.status.list</field>
    <field name="model">delivery.status</field>
    <field name="arch" type="xml">
        <list editable="bottom">
            <field name="name" decoration-bf="1"/>
            <field name="code"/>
        </list>
    </field>
    </record>

    <record id="action_delivery_status" model="ir.actions.act_window">
    <field name="name">Delivery Status</field>
    <field name="res_model">delivery.status</field>
    <field name="view_mode">list</field>
    </record>

    <menuitem
        id="menu_delivery_status"
        parent="stock.menu_delivery"
        name="Delivery Statuses"
        action="action_delivery_status"/>
</odoo>
