<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="log_tree" model="ir.ui.view">
    <field name="name">delivery.log.tree</field>
    <field name="model">delivery.log</field>
    <field name="arch" type="xml">
        <tree>
            <field name="create_date"/>
            <field name="events" options="{'no_create': True, 'no_open': True}"/>
            <field name="state" widget="badge" decoration-danger="status == False" decoration-success="status == True"/>
            <field name="message" optional="hide"/>
            <field name="company_id" groups="base.group_multi_company" options="{'no_create': True, 'no_open': True}"/>
            <field name="status" invisible="1"/>
        </tree>
    </field>
    </record>

    <record id="log_form" model="ir.ui.view">
    <field name="name">delivery.log.form</field>
    <field name="model">delivery.log</field>
    <field name="arch" type="xml">
        <form>
            <header>
                <field name="state" widget="statusbar" statusbar_visible="success"/>
            </header>
            <sheet>
                <group>
                    <group>
                        <field name="company_id" groups="base.group_multi_company" options="{'no_create': True, 'no_open': True}"/>
                        <field name="events" options="{'no_create': True}"/>
                        <field name="status" invisible="1"/>
                        <field name="is_webhook" invisible="1"/>
                    </group>
                    <group>
                        <field name="create_date" string="Date"/>
                        <field name="reference" string="Reference"/>
                        <field name="message"/>
                    </group>
                </group>
                <group class="mt-5">
                    <group string="Request" attrs="{'invisible': [('is_webhook', '=', False)]}">
                        <br/>
                        <field name="request_data" nolabel="1" colspan="2"/>
                        <br/>
                        <field name="request_raw" nolabel="1" colspan="2" class="text-400"/>
                    </group>
                    <group string="Response" attrs="{'invisible': [('is_webhook', '=', True)]}">
                        <br/>
                        <field name="response_data" nolabel="1" colspan="2"/>
                        <br/>
                        <field name="response_raw" nolabel="1" colspan="2" class="text-400"/>
                    </group>
                    <group string="Log" groups="base.group_no_one">
                        <field name="log_traceback" class="font-monospace" readonly="1"/>
                        <field name="log" invisible="1"/>
                    </group>
                </group>
            </sheet>
        </form>
    </field>
    </record>

    <record id="log_search" model="ir.ui.view">
    <field name="name">delivery.log.search</field>
    <field name="model">delivery.log</field>
    <field name="arch" type="xml">
        <search>
            <field name="events"/>
            <filter string="Failed Requests" name="filterby_error" domain="[('status', '=', False)]"/>
            <filter string="Successful Requests" name="filterby_success" domain="[('status', '=', True)]"/>
            <group expand="0">
                <filter string="Partner" name="groupby_partner" context="{'group_by': 'events'}"/>
                <filter string="Status" name="groupby_status" context="{'group_by': 'status'}"/>
            </group>
        </search>
    </field>
    </record>

    <record id="action_log" model="ir.actions.act_window">
    <field name="name">Logs</field>
    <field name="res_model">delivery.log</field>
    <field name="view_mode">tree,form</field>
    <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
            No logs yet
        </p>
        <p>
            Logs are listed here
        </p>
    </field>
    </record>

    <menuitem
        id="menu_delivery_log"
        parent="stock.menu_delivery"
        name="Delivery Log"
        action="action_log"/>
</odoo>
